---
export interface Props {
	text: string | string[];
	speed?: number;
	deleteSpeed?: number;
	pauseTime?: number;
	class?: string;
}

const {
	text,
	speed = 100,
	deleteSpeed = 50,
	pauseTime = 2000,
	class: className = "",
} = Astro.props;
const textData = Array.isArray(text) ? JSON.stringify(text) : text;
const initialText = Array.isArray(text)
	? (text.find((item) => item && item.trim()) ?? text[0] ?? "")
	: text;
---

<span
	class={`typewriter ${className}`}
	data-text={textData}
	data-speed={speed}
	data-delete-speed={deleteSpeed}
	data-pause-time={pauseTime}>{initialText || "\u00A0"}</span>

<script>
	// @ts-nocheck
	import { registerPageScript } from "../scripts/page-lifecycle.js";

	const activeTypewriters = new WeakMap();

	function parseTexts(textData) {
		try {
			const parsed = JSON.parse(textData);
			return Array.isArray(parsed) ? parsed : [String(parsed ?? "")];
		} catch {
			return [textData];
		}
	}

	function createTypewriterController(el) {
		const texts = parseTexts(el.getAttribute("data-text") || "").filter(Boolean);
		if (texts.length === 0) {
			el.innerHTML = "&nbsp;";
			return () => {};
		}

		const speed = parseInt(el.getAttribute("data-speed") || "100", 10);
		const deleteSpeed = parseInt(
			el.getAttribute("data-delete-speed") || "50",
			10,
		);
		const pauseTime = parseInt(el.getAttribute("data-pause-time") || "2000", 10);

		let timerId = null;
		let textIndex = 0;
		let charIndex = 0;
		let isDeleting = false;
		let destroyed = false;
		let hasPaintedInitialText = Boolean(el.textContent?.trim());

		const schedule = (delay) => {
			if (destroyed) return;
			timerId = window.setTimeout(tick, delay);
		};

		const tick = () => {
			if (destroyed) return;

			const currentText = texts[textIndex] || "";

			if (hasPaintedInitialText) {
				hasPaintedInitialText = false;
				charIndex = 0;
				el.textContent = "";
				schedule(speed);
				return;
			}

			if (!isDeleting) {
				charIndex += 1;
				el.textContent = currentText.substring(0, charIndex);

				if (charIndex < currentText.length) {
					schedule(speed);
					return;
				}

				if (texts.length === 1) {
					if (texts[0] === "") {
						el.innerHTML = "&nbsp;";
					}
					return;
				}

				isDeleting = true;
				schedule(pauseTime);
				return;
			}

			charIndex -= 1;
			el.textContent = currentText.substring(0, Math.max(charIndex, 0));

			if (charIndex > 0) {
				schedule(deleteSpeed);
				return;
			}

			isDeleting = false;
			textIndex = (textIndex + 1) % texts.length;
			schedule(speed);
		};

		el.textContent = "";
		tick();

		return () => {
			destroyed = true;
			if (timerId !== null) {
				window.clearTimeout(timerId);
			}
			activeTypewriters.delete(el);
		};
	}

	function initTypewriters() {
		document.querySelectorAll(".typewriter").forEach((el) => {
			if (activeTypewriters.has(el)) return;

			const cleanup = createTypewriterController(el);
			activeTypewriters.set(el, cleanup);
		});

		return () => {
			document.querySelectorAll(".typewriter").forEach((el) => {
				const cleanup = activeTypewriters.get(el);
				if (cleanup) {
					cleanup();
				}
			});
		};
	}

	registerPageScript("typewriter-text", {
		shouldRun() {
			return document.querySelector(".typewriter") !== null;
		},
		init() {
			return initTypewriters();
		},
	});
</script>

<style>
	.typewriter {
		position: relative;
		min-height: 1.5em;
		display: inline-block;
		vertical-align: baseline;
	}

	.typewriter:empty::before {
		content: "\00A0";
		visibility: hidden;
	}
</style>
