---
interface Props {
	envId: string;
	region?: string;
	path?: string;
	lang?: string;
}

const { envId, lang = 'auto' } = Astro.props;
---

<div id="cwd-comments" data-api-url={envId} data-lang={lang} class="cwd-wrapper mt-8 mb-6 relative w-full"></div>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.ts";

	let cwdInstance: any = null;

	function getTheme() {
		return document.documentElement.classList.contains("dark") ? "dark" : "light";
	}

	function initCWD(container: HTMLElement) {
		if (cwdInstance) {
			cwdInstance.unmount();
			cwdInstance = null;
		}

		const apiBaseUrl = container.getAttribute("data-api-url") || "";
		const lang = container.getAttribute("data-lang") || "auto";
		const postSlug = window.location.pathname;

		const CWDComments = (window as any).CWDComments;
		if (!CWDComments) return;

		cwdInstance = new CWDComments({
			el: container,
			apiBaseUrl: apiBaseUrl,
			lang: lang,
			postSlug: postSlug,
			theme: getTheme(),
		});

		cwdInstance.mount();
	}

	function loadCWDScript(container: HTMLElement) {
		if ((window as any).CWDComments) {
			initCWD(container);
			return;
		}

		const existingScript = document.getElementById("cwd-script");
		if (existingScript) return;

		const script = document.createElement("script");
		script.id = "cwd-script";
		script.src = "https://unpkg.com/cwd-widget@latest/dist/cwd.js";
		script.async = true;
		script.onload = () => {
			initCWD(container);
		};
		document.head.appendChild(script);
	}

	registerPageScript("cwd-comment", {
		shouldRun() {
			return document.getElementById("cwd-comments") !== null;
		},
		init() {
			const root = document.getElementById("cwd-comments");
			if (!root) return;

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							loadCWDScript(entry.target as HTMLElement);
							observer.unobserve(entry.target);
						}
					});
				},
				{ rootMargin: "200px" }
			);

			observer.observe(root);

			// Watch for theme changes
			const themeObserver = new MutationObserver(() => {
				if (cwdInstance) {
					cwdInstance.updateConfig({ theme: getTheme() });
				}
			});
			themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

			return () => {
				observer.disconnect();
				themeObserver.disconnect();
				if (cwdInstance) {
					cwdInstance.unmount();
					cwdInstance = null;
				}
			};
		},
	});
</script>
