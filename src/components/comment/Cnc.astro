---
interface Props {
	apiBasePath?: string;
	lang?: string;
	postSlug?: string;
	postUrl?: string;
	postTitle?: string;
}

const {
	apiBasePath = "/api/comments",
	lang = "zh-CN",
	postSlug = "",
	postUrl = "",
	postTitle = "",
} = Astro.props;
---

<div
	id="site-comments"
	data-api-base-path={apiBasePath}
	data-lang={lang}
	data-post-slug={postSlug}
	data-post-url={postUrl}
	data-post-title={postTitle}
	class="site-comments-root mt-8 mb-6 relative w-full"
>
	<div class="site-comments-boot px-0 py-0 text-sm text-[rgba(36,24,22,0.72)] dark:text-[rgba(244,237,231,0.72)]">
		站内评论系统正在加载…
	</div>
</div>

<script>
	import { registerPageScript } from "@/scripts/page-lifecycle.ts";

	registerPageScript("site-comments", {
		shouldRun() {
			return document.getElementById("site-comments") !== null;
		},
		async init() {
			const root = document.getElementById("site-comments");
			if (!root) return;

			const { mountSiteComments } = await import("@/scripts/site-comments.ts");

			return mountSiteComments(root, {
				apiBasePath:
					root.getAttribute("data-api-base-path") || "/api/comments",
				lang: root.getAttribute("data-lang") || "zh-CN",
				postSlug: root.getAttribute("data-post-slug") || window.location.pathname,
				postUrl: root.getAttribute("data-post-url") || window.location.href,
				postTitle: root.getAttribute("data-post-title") || document.title,
			});
		},
	});
</script>

<style is:global>
	.site-comments-root {
		--site-comments-font-family: "Zhuque Fangsong UI", "Zhuque Fangsong", "Crimson Pro", serif;
		--site-comments-font-size: 1rem;
		--site-comments-line-height: 1.85;
	}

	.site-comments-shell {
		border: 0;
		border-radius: 0;
		background: transparent;
		padding: 0;
		font-family: var(--site-comments-font-family) !important;
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
	}

	.dark .site-comments-shell {
		border-color: transparent;
		background: transparent;
	}

	.site-comments-root,
	.site-comments-root *,
	.site-comments-shell,
	.site-comments-shell button,
	.site-comments-shell input,
	.site-comments-shell textarea,
	.site-comments-shell select,
	.site-comments-shell option,
	.site-comments-shell .site-comment-content,
	.site-comments-shell .site-comment-author,
	.site-comments-shell .site-comment-time,
	.site-comments-shell .site-comments-title,
	.site-comments-shell .site-comments-subtitle,
	.site-comments-shell .site-comments-hint,
	.site-comments-shell .site-comments-empty,
	.site-comments-shell .site-comments-notice,
	.site-comments-shell .site-comments-replying,
	.site-comments-shell .link-btn {
		font-family: var(--site-comments-font-family) !important;
		font-size: var(--site-comments-font-size) !important;
		line-height: var(--site-comments-line-height) !important;
	}

	.site-comments-root input::placeholder,
	.site-comments-root textarea::placeholder {
		font-family: var(--site-comments-font-family) !important;
		font-size: var(--site-comments-font-size) !important;
	}

	.site-comments-head {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		margin-bottom: 1rem;
	}

	.site-comments-title {
		margin: 0;
		font-size: var(--site-comments-font-size);
		font-weight: 700;
		line-height: var(--site-comments-line-height);
		color: rgba(36, 24, 22, 0.92);
	}

	.dark .site-comments-title {
		color: rgba(244, 237, 231, 0.92);
	}

	.site-comments-subtitle,
	.site-comments-hint,
	.site-comments-empty,
	.site-comment-time {
		color: rgba(36, 24, 22, 0.64);
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
	}

	.dark .site-comments-subtitle,
	.dark .site-comments-hint,
	.dark .site-comments-empty,
	.dark .site-comment-time {
		color: rgba(244, 237, 231, 0.66);
	}

	.site-comments-form {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		margin-bottom: 1.2rem;
	}

	.site-comments-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.site-comments-field {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
		color: rgba(36, 24, 22, 0.78);
	}

	.dark .site-comments-field {
		color: rgba(244, 237, 231, 0.8);
	}

	.site-comments-field input,
	.site-comments-field textarea {
		width: 100%;
		border-radius: 12px;
		border: 1px solid var(--display-panel-border);
		background: var(--panel-bg);
		backdrop-filter: blur(20px) saturate(160%);
		-webkit-backdrop-filter: blur(20px) saturate(160%);
		padding: 0.8rem 0.95rem;
		color: rgba(36, 24, 22, 0.92);
		outline: none;
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
		transition: border-color 180ms ease, background-color 180ms ease, box-shadow 180ms ease;
	}

	.dark .site-comments-field input,
	.dark .site-comments-field textarea {
		border-color: var(--display-panel-border);
		background: var(--panel-bg);
		color: rgba(244, 237, 231, 0.92);
	}

	.site-comments-field input:focus,
	.site-comments-field textarea:focus {
		border-color: rgba(36, 24, 22, 0.42);
		box-shadow: 0 0 0 1px rgba(36, 24, 22, 0.08);
	}

	.dark .site-comments-field input:focus,
	.dark .site-comments-field textarea:focus {
		border-color: rgba(244, 237, 231, 0.34);
		box-shadow: 0 0 0 1px rgba(244, 237, 231, 0.08);
	}

	.site-comments-field input:-webkit-autofill,
	.site-comments-field input:-webkit-autofill:hover,
	.site-comments-field input:-webkit-autofill:focus,
	.site-comments-field input:-webkit-autofill:active {
		-webkit-text-fill-color: rgba(36, 24, 22, 0.92);
		caret-color: rgba(36, 24, 22, 0.92);
		-webkit-box-shadow:
			0 0 0 1000px var(--panel-bg) inset,
			0 0 0 1px var(--display-panel-border);
		box-shadow:
			0 0 0 1000px var(--panel-bg) inset,
			0 0 0 1px var(--display-panel-border);
		transition: background-color 9999s ease-out 0s;
		background-clip: padding-box;
		backdrop-filter: blur(20px) saturate(160%);
		-webkit-backdrop-filter: blur(20px) saturate(160%);
	}

	.dark .site-comments-field input:-webkit-autofill,
	.dark .site-comments-field input:-webkit-autofill:hover,
	.dark .site-comments-field input:-webkit-autofill:focus,
	.dark .site-comments-field input:-webkit-autofill:active {
		-webkit-text-fill-color: rgba(244, 237, 231, 0.92);
		caret-color: rgba(244, 237, 231, 0.92);
		-webkit-box-shadow:
			0 0 0 1000px var(--panel-bg) inset,
			0 0 0 1px var(--display-panel-border);
		box-shadow:
			0 0 0 1000px var(--panel-bg) inset,
			0 0 0 1px var(--display-panel-border);
	}

	.site-comments-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		align-items: center;
	}

	.site-comments-submit {
		border: 1px solid var(--display-panel-border);
		border-radius: 12px;
		padding: 0.75rem 1.15rem;
		background: var(--panel-bg);
		backdrop-filter: blur(20px) saturate(160%);
		-webkit-backdrop-filter: blur(20px) saturate(160%);
		color: rgba(36, 24, 22, 0.92);
		font-weight: 700;
		cursor: pointer;
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			background-color 0.18s ease,
			color 0.18s ease,
			border-color 0.18s ease;
	}

	.site-comments-submit:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.site-comments-submit:hover:not(:disabled) {
		transform: translateY(-1px) scale(1.03);
		background-color: color-mix(
			in oklab,
			var(--primary) 16%,
			var(--btn-plain-bg)
		);
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 42%, transparent),
			inset 0 0 0 999px color-mix(in oklab, var(--primary) 10%, transparent);
		color: var(--primary);
	}

	.dark .site-comments-submit {
		border-color: var(--display-panel-border);
		background: var(--panel-bg);
		color: rgba(244, 237, 231, 0.92);
	}

	.dark .site-comments-submit:hover:not(:disabled) {
		color: var(--primary);
	}

	.site-comments-submit:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 2px;
		background-color: color-mix(
			in oklab,
			var(--primary) 16%,
			var(--btn-plain-bg)
		);
		box-shadow:
			0 0 0 1px color-mix(in oklab, var(--primary) 42%, transparent),
			inset 0 0 0 999px color-mix(in oklab, var(--primary) 10%, transparent);
		color: var(--primary);
	}

	.site-comments-submit:active:not(:disabled) {
		transform: scale(0.96);
	}

	.site-comments-notice,
	.site-comments-replying {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.95rem;
		border-radius: 12px;
		padding: 0.75rem 0.95rem;
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
		border: 2px solid rgba(36, 24, 22, 0.14);
	}

	.site-comments-notice.is-error {
		background: rgba(200, 56, 44, 0.06);
		border-color: rgba(200, 56, 44, 0.22);
		color: rgba(142, 31, 21, 0.92);
	}

	.site-comments-notice.is-success {
		background: rgba(38, 132, 78, 0.06);
		border-color: rgba(38, 132, 78, 0.24);
		color: rgba(21, 94, 57, 0.92);
	}

	.site-comments-replying {
		background: rgba(36, 24, 22, 0.03);
		border-color: rgba(36, 24, 22, 0.16);
		color: rgba(36, 24, 22, 0.84);
	}

	.dark .site-comments-replying {
		background: rgba(244, 237, 231, 0.03);
		border-color: rgba(244, 237, 231, 0.16);
		color: rgba(244, 237, 231, 0.86);
	}

	.site-comments-list {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.site-comment-card {
		border-radius: 0;
		border: 0;
		padding: 0.55rem 0;
		background: transparent;
	}

	.dark .site-comment-card {
		border-color: transparent;
		background: transparent;
	}

	.site-comment-card.is-reply {
		margin-top: 0.5rem;
		margin-left: 0.9rem;
		padding-left: 0.75rem;
	}

	.site-comment-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.45rem;
	}

	.site-comment-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem 0.6rem;
		align-items: center;
	}

	.site-comment-author {
		font-weight: 700;
		color: rgba(36, 24, 22, 0.92);
	}

	.dark .site-comment-author {
		color: rgba(244, 237, 231, 0.92);
	}

	.site-comment-content {
		font-size: var(--site-comments-font-size);
		line-height: var(--site-comments-line-height);
		color: rgba(36, 24, 22, 0.86);
		word-break: break-word;
	}

	.dark .site-comment-content {
		color: rgba(244, 237, 231, 0.84);
	}

	.link-btn {
		border: 0;
		background: transparent;
		padding: 0;
		color: rgba(36, 24, 22, 0.88);
		cursor: pointer;
		text-decoration: none;
	}

	.dark .link-btn {
		color: rgba(244, 237, 231, 0.9);
	}

	.site-comment-reply-btn {
		font-weight: 400;
		font-size: 0.95rem !important;
		line-height: 1.5 !important;
		opacity: 0.78;
	}

	.site-comment-reply-btn:hover {
		opacity: 1;
		text-decoration: underline;
		text-underline-offset: 0.12em;
	}

	.site-comment-actions-inline {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.site-comment-delete-btn {
		font-weight: 400;
		font-size: 0.95rem !important;
		line-height: 1.5 !important;
		opacity: 0.65;
		color: rgba(200, 56, 44, 0.88) !important;
	}

	.dark .site-comment-delete-btn {
		color: rgba(255, 125, 115, 0.88) !important;
	}

	.site-comment-delete-btn:hover {
		opacity: 1;
		text-decoration: underline;
		text-underline-offset: 0.12em;
		color: rgba(200, 56, 44, 1) !important;
	}

	.dark .site-comment-delete-btn:hover {
		color: rgba(255, 145, 135, 1) !important;
	}

	@media (max-width: 720px) {
		.site-comments-grid {
			grid-template-columns: 1fr;
		}

		.site-comment-header,
		.site-comments-actions,
		.site-comments-replying {
			align-items: flex-start;
			flex-direction: column;
		}

		.site-comment-card.is-reply {
			margin-left: 0.5rem;
		}
	}
</style>
