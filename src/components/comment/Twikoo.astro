---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	envId: string;
	region?: string;
	path?: string;
	lang?: string;
}

const { envId, region = "", path = "", lang = "zh-CN" } = Astro.props;
---

<div class="twikoo-wrapper mt-8 mb-6">
	<div class="comment-header flex items-center gap-3 mb-4 onload-animation">
		<div class="flex items-center justify-center w-9 h-9 rounded-lg bg-(--btn-regular-bg)">
			<Icon
				name="material-symbols:chat-bubble-outline-rounded"
				class="text-lg text-(--primary)"
			/>
		</div>
		<h3 class="text-lg font-semibold text-90">
			{i18n(I18nKey.comments) || "评论"}
		</h3>
	</div>

	<div class="twikoo-container relative onload-animation">
		<div
			id="twikoo-comment"
			data-env-id={envId}
			data-region={region}
			data-path={path}
			data-lang={lang}
		></div>
	</div>
</div>

<style>
	.twikoo-wrapper {
		position: relative;
	}

	.twikoo-container {
		position: relative;
	}
</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.ts";

	type TwikooGlobal = {
		init: (options: Record<string, unknown>) => void;
	};

	/** inject a <style> that lives outside any Vue scope — HIGH specificity selectors */
	function injectGlobalStyles() {
		const id = "tk-custom-global";
		if (document.getElementById(id)) return;

		const s = document.createElement("style");
		// Push to the very end of <head> so our rules cascade over Vue scoped styles
		document.head.appendChild(s);
		s.id = id;
		const cssVars = getPrimaryColor(); // "var(--primary)" → fallback color
		s.textContent = `
		/* == hide unwanted elements — high-specificity selectors to beat scoped Vue styles == */
		body .tk-header { display: none!important; }
		body .tk-time { display: none!important; }
		body .tk-comments-title { display: none!important; }
		body .tk-divider { display: none!important; }
		body .tk-extras { display: none!important; }
		body .tk-extra { display: none!important; }
		body .tk-comment .tk-like,
		body .tk-comment .tk-revert-comment { display: none!important; }
		/* 隐藏字数计数 */
		body .tk-input-count { display: none!important; }
		body .tk-preview, body .tk-preview-btn { display: none!important; }

		/* reply link — prevent scroll-to-top on click */
		body .tk-action-link {
			cursor: pointer;
		}
		#twikoo-comment .tk-comments .tk-footer,
		.twikoo-container .tk-footer,
		body .tk-footer {
			display: none!important;
			visibility: hidden!important;
			height: 0!important;
			font-size: 0!important;
			overflow: hidden!important;
		}

		/* textarea */
		body .tk-input {
			background: rgba(128,128,128,0.03)!important;
			border: 1px solid var(--line-divider)!important;
			color: inherit!important;
			font-family: inherit!important;
			padding: 0.875rem 1rem!important;
			border-radius: 0.375rem!important;
		}
		body .tk-input:focus {
			border-color: var(--primary)!important;
			box-shadow: 0 0 0 3px color-mix(in oklch, var(--primary) 15%, transparent)!important;
		}
		body .tk-input::placeholder { color: rgba(128,128,128,0.4)!important; font-style: italic; }

		/* send button — override Element-UI blue */
		body .tk-comments .tk-submit .tk-send.el-button--primary,
		body .tk-comments .tk-submit .tk-send,
		body .tk-comments .tk-submit .el-button {
			background: linear-gradient(135deg, rgba(128,128,128,0.08), rgba(128,128,128,0.12))!important;
			background-color: rgba(128,128,128,0.1)!important;
			border: none!important;
			border-color: transparent!important;
			color: inherit!important;
			border-radius: 0.375rem!important;
			letter-spacing: 0.05em!important;
			font-weight: 500!important;
		}
		body .tk-comments .tk-submit .tk-send:hover,
		body .tk-comments .tk-submit .el-button:hover {
			color: var(--primary)!important;
		}

		/* comment cards */
		body .tk-comment {
			background: transparent!important;
			border: none!important;
			padding: 1rem 0!important;
			margin-bottom: 1.5rem!important;
		}
		body .tk-comment:hover { background: rgba(128,128,128,0.02)!important; }
		body .tk-comment::before {
			content: "";
			position: absolute;
			left: 0; top: 0; bottom: 0;
			width: 2px;
			background: linear-gradient(180deg, var(--primary) 0%, transparent 100%);
			opacity: 0;
			transition: opacity 0.35s;
		}
		body .tk-comment:hover::before { opacity: 1; }

		body .tk-avatar {
			border-radius: 50%!important;
			box-shadow: 0 2px 6px rgba(0,0,0,0.08), inset 0 1px 2px rgba(255,255,255,0.3)!important;
			border: 1px solid rgba(128,128,128,0.1)!important;
		}
		body .tk-nick { font-weight: 600!important; font-family: var(--font-serif)!important; }
		body .tk-nick:hover { color: var(--primary)!important; }
		body .tk-content {
			color: inherit!important;
			margin-top: 0.625rem!important;
			line-height: 1.7;
		}
		body .tk-content a {
			color: var(--primary)!important;
			text-decoration: underline;
			text-decoration-style: dashed;
			text-underline-offset: 4px;
		}
		body .tk-content blockquote {
			border-left: 2px solid var(--primary)!important;
			padding-left: 1rem!important;
			opacity: 0.75;
			font-style: italic;
		}
		body .tk-replies {
			border-top: none!important;
			margin-top: 1rem!important;
			margin-left: 2rem!important;
			padding: 0.5rem 0 0.5rem 1rem;
		}
		body .tk-reply {
			border: none!important;
			background: transparent!important;
			padding: 0.75rem 0!important;
		}
		/* 三级及更深层级回复再缩进 */
		body .tk-replies .tk-replies {
			margin-left: 1.5rem!important;
		}
		/* 回复按钮样式 */
		body .tk-action-link {
			opacity: 0.5!important;
			transition: opacity 0.2s!important;
			color: inherit!important;
			text-decoration: none!important;
		}
		body .tk-action-link:hover {
			opacity: 1!important;
			color: var(--primary)!important;
		}
		body .tk-expand {
			background: rgba(128,128,128,0.03)!important;
			border: none!important;
			color: inherit!important;
			padding: 0.75rem 2rem!important;
			font-size: 0.875rem;
			letter-spacing: 0.05em;
		}
		body .tk-expand:hover { color: var(--primary)!important; }
		body .tk-no-comment { color: inherit!important; opacity: 0.4!important; font-style: italic!important; }
	`;
	}

	/** read the computed --primary color for inline-style fallback */
	function getPrimaryColor() {
		return getComputedStyle(document.documentElement).getPropertyValue("--primary").trim() || "#b36147";
	}

	/** stop .tk-action-link (reply link) from scrolling to top */
	function disableReplyLinkScroll() {
		document.querySelectorAll(".tk-action-link[href='#']").forEach(el => {
			const a = el as HTMLAnchorElement;
			if (a.getAttribute("data-scroll-prevented")) return;
			a.addEventListener("click", (e) => e.preventDefault());
			a.setAttribute("data-scroll-prevented", "true");
			// also remove the hash anchor behavior
			a.setAttribute("href", "javascript:void(0)");
		});
	}

	/** force-hide elements & restyle buttons via setProperty() (bypasses all CSS conflicts) */
	function enforceInlineStyles(container: HTMLElement) {
		// remove unwanted DOM nodes（保留 .tk-action-link 回复按钮 + .tk-submit-action-icon）
		container.querySelectorAll(
			".tk-header, .tk-time, .tk-comments-title, .tk-divider, .tk-extras, .tk-extra, .tk-preview, .tk-preview-btn, .tk-revert-comment, .tk-like"
		).forEach(el => el.remove());
		// prevent reply links from scrolling to top
		disableReplyLinkScroll();

		// footer: remove + force inline style (Vue re-renders, so use setProperty with important)
		container.querySelectorAll(".tk-footer").forEach(el => {
			const h = el as HTMLElement;
			h.style.setProperty("display", "none", "important");
			h.style.setProperty("visibility", "hidden", "important");
			h.style.setProperty("height", "0", "important");
			h.style.setProperty("font-size", "0", "important");
			h.style.setProperty("overflow", "hidden", "important");
		});

		// send button: override Element-UI blue via setProperty
		container.querySelectorAll(".tk-submit .el-button").forEach(btn => {
			const b = btn as HTMLElement;
			b.style.setProperty("background", "transparent", "important");
			b.style.setProperty("background-color", "rgba(128,128,128,0.10)", "important");
			b.style.setProperty("border", "none", "important");
			b.style.setProperty("color", "inherit", "important");
			b.style.setProperty("border-radius", "0.375rem", "important");
			b.style.setProperty("letter-spacing", "0.05em", "important");
		});
	}

	/** observe container DOM + <head> + attribute changes */
	function startObservers(container: HTMLElement) {
		// 1. container DOM & attribute changes (Vue sets styles/attributes)
		const domObs = new MutationObserver((mutations) => {
			// Only react to child additions/removals or attribute changes on known elements
			let needsFix = false;
			for (const m of mutations) {
				if (m.type === "childList") { needsFix = true; break; }
				if (m.type === "attributes") {
					const t = m.target as Element;
					if (t.matches?.(".tk-footer, .el-button--primary, .tk-send, .tk-action-link, .tk-submit")) {
						needsFix = true; break;
					}
				}
			}
			if (needsFix) enforceInlineStyles(container);
		});
		domObs.observe(container, { childList: true, subtree: true, attributes: true, attributeFilter: ["style", "class"] });

		// 2. new <style> tags in <head>
		const headObs = new MutationObserver(() => {
			injectGlobalStyles();
		});
		headObs.observe(document.head, { childList: true });
	}

	function initTwikoo() {
		const container = document.getElementById("twikoo-comment");
		if (!container || container.querySelector("tk-time")) return;

		// inject our global styles FIRST
		injectGlobalStyles();

		const envId = container.getAttribute("data-env-id") || "";
		const region = container.getAttribute("data-region") || "";
		const path = container.getAttribute("data-path") || window.location.pathname;
		const lang = container.getAttribute("data-lang") || "zh-CN";

		const script = document.createElement("script");
		script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.7.4/dist/twikoo.all.min.js";
		script.async = true;

		script.onload = () => {
			const twikoo = (window as Window & { twikoo?: TwikooGlobal }).twikoo;
			if (!twikoo) return;

			twikoo.init({
				envId,
				el: "#twikoo-comment",
				region,
				path,
				lang,
				onCommentLoaded: () => {
					// wait two frames for Vue render to settle, then enforce
					requestAnimationFrame(() => {
						requestAnimationFrame(() => {
							enforceInlineStyles(container as HTMLElement);
							startObservers(container as HTMLElement);
						});
					});
				},
			});

			// re-inject styles AFTER Twikoo script loads (it may add extra <style> tags)
			setTimeout(injectGlobalStyles, 100);
			setTimeout(injectGlobalStyles, 300);
			setTimeout(injectGlobalStyles, 500);
		};

		document.head.appendChild(script);
	}

	const twikooObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					initTwikoo();
					twikooObserver.disconnect();
				}
			});
		},
		{ rootMargin: "200px" },
	);

	registerPageScript("twikoo-comment", {
		shouldRun() {
			return document.getElementById("twikoo-comment") !== null;
		},
		init() {
			const container = document.getElementById("twikoo-comment");
			if (container && !container.querySelector("tk-time")) {
				twikooObserver.observe(container);
			}
			return () => {
				twikooObserver.disconnect();
			};
		},
	});
</script>
