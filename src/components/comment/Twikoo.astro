---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	envId: string;
	region?: string;
	path?: string;
	lang?: string;
}

const { envId, region = "", path = "", lang = "zh-CN" } = Astro.props;
---

<div class="twikoo-wrapper mt-8 mb-6" id="comments">
	<div class="twikoo-container relative">
		<div
			id="twikoo-comment"
			data-env-id={envId}
			data-region={region}
			data-path={path}
			data-lang={lang}
		>
			<p class="twikoo-loading">{i18n(I18nKey.comments) || "评论"}加载中...</p>
		</div>
	</div>
</div>

<style>
	.twikoo-wrapper {
		position: relative;
		max-width: 100%;
		margin-inline: auto;
		padding-top: 1rem;
		border-top: 1px solid var(--line-divider);
	}

	.twikoo-container {
		position: relative;
	}

	.twikoo-loading {
		margin: 0;
		padding: 1rem 0 0.25rem;
		text-align: center;
		color: var(--content-meta);
	}
</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.ts";

	type TwikooGlobal = {
		init: (options: Record<string, unknown>) => void;
	};

	const FORM_LABELS = ["昵称*", "邮箱*", "网站"];

	function getCommentRoot(container?: HTMLElement) {
		if (container) return container;
		return (
			document.querySelector("#comments .twikoo") ||
			document.querySelector("#comments #twikoo-comment")
		) as HTMLElement | null;
	}

	function injectGlobalStyles() {
		const id = "tk-custom-global";
		if (document.getElementById(id)) return;

		const style = document.createElement("style");
		style.id = id;
		document.head.appendChild(style);
		style.textContent = `
		body .tk-header,
		body .tk-time,
		body .tk-comments-title,
		body .tk-divider,
		body .tk-extras,
		body .tk-extra,
		body .tk-input-count,
		body .tk-preview,
		body .tk-preview-btn,
		body .tk-comment .tk-like,
		body .tk-comment .tk-revert-comment {
			display: none !important;
		}

		#twikoo-comment .tk-comments,
		body .tk-comments {
			margin-top: 1rem !important;
		}

		body .tk-submit {
			margin-top: 0 !important;
		}

		body .tk-submit .tk-row {
			display: block !important;
		}

		body .tk-submit .tk-avatar {
			display: none !important;
		}

		body .tk-submit .tk-col {
			width: 100% !important;
		}

		body .tk-submit .tk-meta-input {
			display: grid !important;
			grid-template-columns: 1fr !important;
			gap: 0.75rem !important;
			margin-bottom: 0.75rem !important;
		}

		@media (min-width: 768px) {
			body .tk-submit .tk-meta-input {
				grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
			}
		}

		body .tk-submit .tk-meta-input > .el-input,
		body .tk-submit .el-input,
		body .tk-submit .el-input-group,
		body .tk-submit .el-input-group__prepend {
			display: block !important;
			width: 100% !important;
			min-width: 0 !important;
		}

		body .tk-submit .el-input-group__prepend {
			margin-bottom: 0.25rem !important;
			padding: 0 !important;
			border: none !important;
			background: transparent !important;
			color: inherit !important;
			font-size: 0.875rem !important;
			line-height: 1.25rem !important;
			text-align: left !important;
			font-weight: 500 !important;
			letter-spacing: 0.02em !important;
		}

		body .tk-submit .el-input__inner,
		body .tk-submit .tk-input textarea,
		body .tk-submit .el-textarea__inner {
			width: 100% !important;
			border: 1px solid var(--line-divider) !important;
			border-radius: 0.375rem !important;
			background: var(--card-bg) !important;
			background-color: var(--card-bg) !important;
			box-shadow: none !important;
			color: inherit !important;
			font-family: inherit !important;
			font-size: 0.875rem !important;
			line-height: 1.5 !important;
		}

		body .tk-submit .el-input__inner {
			height: auto !important;
			padding: 0.5rem !important;
		}

		body .tk-submit .tk-input,
		body .tk-submit .el-textarea {
			margin: 0 !important;
		}

		body .tk-submit .tk-input textarea,
		body .tk-submit .el-textarea__inner {
			padding: 0.75rem !important;
			min-height: 100px !important;
			resize: vertical !important;
		}

		body .tk-submit .el-input__inner:focus,
		body .tk-submit .tk-input textarea:focus,
		body .tk-submit .el-textarea__inner:focus {
			outline: none !important;
			border-color: var(--primary) !important;
			box-shadow: 0 0 0 1px color-mix(in oklch, var(--primary) 25%, transparent) !important;
		}

		body .tk-submit .tk-row.actions {
			display: flex !important;
			justify-content: flex-end !important;
			gap: 0.75rem !important;
			margin-top: 0.75rem !important;
		}

		body .tk-submit .tk-row-actions-start,
		body .tk-submit .tk-submit-action-icon,
		body .tk-submit .tk-input-image,
		body .tk-submit .tk-error-message,
		body .tk-submit .tk-preview {
			display: none !important;
		}

		body .tk-comments .tk-submit .tk-send.el-button--primary,
		body .tk-comments .tk-submit .tk-send,
		body .tk-comments .tk-submit .el-button {
			padding: 0.5rem 1rem !important;
			border: 1px solid var(--line-divider) !important;
			border-radius: 0.375rem !important;
			background: var(--card-bg) !important;
			background-color: var(--card-bg) !important;
			box-shadow: none !important;
			color: inherit !important;
			font-size: 0.875rem !important;
			font-weight: 500 !important;
			letter-spacing: 0 !important;
		}

		body .tk-comments .tk-submit .tk-send:hover,
		body .tk-comments .tk-submit .el-button:hover {
			background: var(--btn-regular-bg) !important;
			color: inherit !important;
		}

		#twikoo-comment .tk-comments .tk-footer,
		.twikoo-container .tk-footer,
		body .tk-footer {
			display: none !important;
			visibility: hidden !important;
			height: 0 !important;
			font-size: 0 !important;
			overflow: hidden !important;
		}

		body .tk-comment {
			margin-bottom: 0 !important;
			padding: 1rem 0 !important;
			border: none !important;
			border-bottom: 1px solid var(--line-divider) !important;
			background: transparent !important;
		}

		body .tk-comment:hover,
		body .tk-reply:hover {
			background: transparent !important;
		}

		body .tk-avatar {
			border: none !important;
			border-radius: 999px !important;
			box-shadow: none !important;
		}

		body .tk-comment > .tk-avatar,
		body .tk-reply > .tk-avatar {
			width: 2.5rem !important;
			height: 2.5rem !important;
			margin-right: 0.875rem !important;
		}

		body .tk-comment > .tk-avatar .tk-avatar-img,
		body .tk-reply > .tk-avatar .tk-avatar-img {
			width: 100% !important;
			height: 100% !important;
		}

		body .tk-main {
			width: auto !important;
		}

		body .tk-comment > .tk-main > .tk-row,
		body .tk-reply > .tk-main > .tk-row {
			display: flex !important;
			align-items: flex-start !important;
			justify-content: space-between !important;
			gap: 0.75rem !important;
		}

		body .tk-meta {
			display: flex !important;
			flex-wrap: wrap !important;
			align-items: center !important;
			gap: 0.375rem 0.75rem !important;
			min-width: 0 !important;
		}

		body .tk-nick {
			font-weight: 600 !important;
			font-family: var(--font-serif) !important;
		}

		body .tk-nick:hover {
			color: var(--primary) !important;
		}

		body .tk-content {
			margin-top: 0.625rem !important;
			color: inherit !important;
			line-height: 1.7 !important;
		}

		body .tk-content a {
			color: var(--primary) !important;
			text-decoration: underline;
			text-decoration-style: dashed;
			text-underline-offset: 4px;
		}

		body .tk-content blockquote {
			padding-left: 1rem !important;
			border-left: 2px solid var(--primary) !important;
			opacity: 0.75;
			font-style: italic;
		}

		body .tk-tag {
			display: inline-flex !important;
			align-items: center !important;
			padding: 0.125rem 0.5rem !important;
			border: 1px solid var(--line-divider) !important;
			border-radius: 999px !important;
			background: var(--btn-regular-bg) !important;
			font-size: 0.75rem !important;
			line-height: 1.2 !important;
		}

		body .tk-action {
			flex-shrink: 0 !important;
			opacity: 0.45 !important;
			transition: opacity 0.2s !important;
		}

		body .tk-comment:hover .tk-action,
		body .tk-reply:hover .tk-action {
			opacity: 1 !important;
		}

		body .tk-replies {
			margin-top: 1rem !important;
			margin-left: 3.375rem !important;
			padding: 0.25rem 0 0.25rem 1rem !important;
			border-top: none !important;
			border-left: 1px solid var(--line-divider) !important;
		}

		body .tk-replies .tk-replies {
			margin-left: 1.5rem !important;
		}

		body .tk-reply {
			padding: 0.75rem 0 !important;
			border: none !important;
			background: transparent !important;
		}

		body .tk-action-link {
			cursor: pointer;
			color: inherit !important;
			text-decoration: none !important;
			opacity: 0.5 !important;
			transition: opacity 0.2s !important;
		}

		body .tk-action-link:hover {
			color: var(--primary) !important;
			opacity: 1 !important;
		}

		body .tk-expand {
			padding: 0.75rem 2rem !important;
			border: none !important;
			background: rgba(128, 128, 128, 0.03) !important;
			color: inherit !important;
			font-size: 0.875rem !important;
			letter-spacing: 0.05em !important;
		}

		body .tk-expand:hover {
			color: var(--primary) !important;
		}

		body .tk-no-comment {
			padding: 1rem 0 !important;
			color: inherit !important;
			opacity: 0.65 !important;
			font-style: normal !important;
			text-align: center !important;
		}

		@media (max-width: 767px) {
			body .tk-comment > .tk-avatar,
			body .tk-reply > .tk-avatar {
				width: 2.25rem !important;
				height: 2.25rem !important;
				margin-right: 0.75rem !important;
			}

			body .tk-comment > .tk-main > .tk-row,
			body .tk-reply > .tk-main > .tk-row {
				flex-direction: column !important;
				gap: 0.5rem !important;
			}

			body .tk-action {
				opacity: 1 !important;
			}

			body .tk-replies {
				margin-left: 1.5rem !important;
				padding-left: 0.875rem !important;
			}
		}
		`;
	}

	function normalizeCommentLabels(container: HTMLElement) {
		const labels = Array.from(
			container.querySelectorAll(".tk-meta-input .el-input-group__prepend"),
		) as HTMLElement[];

		labels.slice(0, FORM_LABELS.length).forEach((label, index) => {
			label.textContent = FORM_LABELS[index];
		});
	}

	function normalizeCommentForm(container: HTMLElement) {
		const textarea = container.querySelector("textarea") as HTMLTextAreaElement | null;
		if (textarea) {
			textarea.placeholder = "欢迎评论";
		}

		const textInputs = Array.from(container.querySelectorAll("input")) as HTMLInputElement[];
		textInputs.forEach((input) => {
			if (input.type === "email") {
				input.placeholder = "请输入邮箱";
				input.setAttribute("autocomplete", "email");
				return;
			}
			if (input.name === "link" || input.type === "url") {
				input.placeholder = "https://";
				input.setAttribute("autocomplete", "url");
				return;
			}
			if (input.type === "text") {
				input.placeholder = "请输入昵称";
				input.setAttribute("autocomplete", "nickname");
			}
		});
	}

	function normalizeSubmitButton(container: HTMLElement) {
		const label = container.querySelector(".tk-send span");
		if (label) {
			label.textContent = "发送";
		}
	}

	function disableReplyLinkScroll(container: HTMLElement) {
		container.querySelectorAll(".tk-action-link[href='#']").forEach((el) => {
			const anchor = el as HTMLAnchorElement;
			if (anchor.getAttribute("data-scroll-prevented")) return;

			anchor.addEventListener("click", (event) => event.preventDefault());
			anchor.setAttribute("data-scroll-prevented", "true");
			anchor.setAttribute("href", "javascript:void(0)");
		});
	}

	function enforceInlineStyles(container: HTMLElement) {
		container
			.querySelectorAll(
				".tk-header, .tk-time, .tk-comments-title, .tk-divider, .tk-extras, .tk-extra, .tk-preview, .tk-preview-btn, .tk-revert-comment, .tk-like",
			)
			.forEach((el) => el.remove());

		normalizeCommentLabels(container);
		normalizeCommentForm(container);
		normalizeSubmitButton(container);
		disableReplyLinkScroll(container);

		container.querySelectorAll(".tk-footer").forEach((el) => {
			const footer = el as HTMLElement;
			footer.style.setProperty("display", "none", "important");
			footer.style.setProperty("visibility", "hidden", "important");
			footer.style.setProperty("height", "0", "important");
			footer.style.setProperty("font-size", "0", "important");
			footer.style.setProperty("overflow", "hidden", "important");
		});

		container.querySelectorAll(".tk-submit .el-button").forEach((button) => {
			const element = button as HTMLElement;
			element.style.setProperty("background", "var(--card-bg)", "important");
			element.style.setProperty("background-color", "var(--card-bg)", "important");
			element.style.setProperty("border", "1px solid var(--line-divider)", "important");
			element.style.setProperty("color", "inherit", "important");
			element.style.setProperty("border-radius", "0.375rem", "important");
			element.style.setProperty("box-shadow", "none", "important");
			element.style.setProperty("letter-spacing", "0", "important");
		});
	}

	function applyEnhancements(container?: HTMLElement) {
		const root = getCommentRoot(container);
		if (!root) return false;

		enforceInlineStyles(root);
		startObservers(root);
		return true;
	}

	function waitForTwikooReady(container: HTMLElement, attempt = 0) {
		const root = getCommentRoot(container);
		const isReady =
			root !== null &&
			(root.querySelector(".tk-comments") !== null || root.querySelector(".tk-submit") !== null);

		if (isReady) {
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					applyEnhancements(root);
				});
			});
			return;
		}

		if (attempt >= 40) return;
		window.setTimeout(() => {
			waitForTwikooReady(root, attempt + 1);
		}, 150);
	}

	function startObservers(container: HTMLElement) {
		if (container.dataset.tkObserversAttached === "true") return;
		container.dataset.tkObserversAttached = "true";

		const domObserver = new MutationObserver((mutations) => {
			let needsFix = false;
			for (const mutation of mutations) {
				if (mutation.type === "childList") {
					needsFix = true;
					break;
				}
				if (mutation.type === "attributes") {
					const target = mutation.target as Element;
					if (
						target.matches?.(
							".tk-footer, .el-button--primary, .tk-send, .tk-action-link, .tk-submit, .tk-meta-input",
						)
					) {
						needsFix = true;
						break;
					}
				}
			}
			if (needsFix) enforceInlineStyles(container);
		});

		domObserver.observe(container, {
			childList: true,
			subtree: true,
			attributes: true,
			attributeFilter: ["style", "class"],
		});

		const headObserver = new MutationObserver(() => {
			injectGlobalStyles();
		});
		headObserver.observe(document.head, { childList: true });
	}

	function mountTwikoo(container: HTMLElement, twikoo: TwikooGlobal) {
		const envId = container.getAttribute("data-env-id") || "";
		const region = container.getAttribute("data-region") || "";
		const path = container.getAttribute("data-path") || window.location.pathname;
		const lang = container.getAttribute("data-lang") || "zh-CN";

		// Generate a unique ID to prevent Swup crossfade duplicates from hijacking the selector
		const uniqueId = "twikoo-comment-" + Math.random().toString(36).substring(2, 9);
		container.id = uniqueId;

		twikoo.init({
			envId,
			el: "#" + uniqueId,
			region,
			path,
			lang,
			onCommentLoaded: () => {
				applyEnhancements(container);
			},
		});

		waitForTwikooReady(container);
	}

	function initTwikoo(container: HTMLElement) {
		if (!container || container.dataset.tkMounted === "true") return;

		injectGlobalStyles();
		container.dataset.tkMounted = "true";

		const existing = (window as Window & { twikoo?: TwikooGlobal }).twikoo;
		if (existing) {
			mountTwikoo(container, existing);
			return;
		}

		const script = document.createElement("script");
		script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.7.4/dist/twikoo.all.min.js";
		script.async = true;
		script.onload = () => {
			const twikoo = (window as Window & { twikoo?: TwikooGlobal }).twikoo;
			if (!twikoo) return;

			mountTwikoo(container, twikoo);
			setTimeout(injectGlobalStyles, 100);
			setTimeout(injectGlobalStyles, 300);
			setTimeout(injectGlobalStyles, 500);
		};

		document.head.appendChild(script);
	}

	const twikooObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const target = entry.target as HTMLElement;
					initTwikoo(target);
					twikooObserver.unobserve(target);
				}
			});
		},
		{ rootMargin: "200px" },
	);

	registerPageScript("twikoo-comment", {
		shouldRun() {
			return document.getElementById("comments") !== null;
		},
		init() {
			// Find the actual element within the wrapper
			const commentRoot = document.getElementById("comments");
			const container = commentRoot?.querySelector(".twikoo-container > div") as HTMLElement;
			if (container) {
				twikooObserver.observe(container);
			}
			return () => {
				twikooObserver.disconnect();
			};
		},
	});
</script>
