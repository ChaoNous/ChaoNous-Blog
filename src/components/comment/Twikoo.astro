---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	envId: string;
	region?: string;
	path?: string;
	lang?: string;
}

const { envId, region = "", path = "", lang = "zh-CN" } = Astro.props;
---

<div class="twikoo-wrapper mt-8 mb-6">
	<div class="comment-header flex items-center gap-3 mb-4 onload-animation">
		<div class="flex items-center justify-center w-9 h-9 rounded-lg bg-(--btn-regular-bg)">
			<Icon
				name="material-symbols:chat-bubble-outline-rounded"
				class="text-lg text-(--primary)"
			/>
		</div>
		<h3 class="text-lg font-semibold text-90">
			{i18n(I18nKey.comments) || "评论"}
		</h3>
	</div>

	<div class="twikoo-container relative onload-animation">
		<div
			id="twikoo-comment"
			data-env-id={envId}
			data-region={region}
			data-path={path}
			data-lang={lang}
		></div>
	</div>
</div>

<style>
	.twikoo-container {
		min-height: 200px;
	}

	:global(.tk-comments) {
		--twikoo-primary: var(--primary);
	}

	:global(.tk-comments *::selection) {
		background: var(--selection-bg, var(--primary));
		color: inherit;
	}

	:global(.tk-comments .tk-container) {
		background: transparent !important;
	}

	:global(.tk-comments .tk-header) {
		display: none !important;
	}

	:global(.tk-submit) {
		margin-bottom: 2.5rem !important;
	}

	:global(.tk-main-header) {
		margin-top: 2.5rem !important;
	}

	/* ===== 输入框区域 — 缣帛风格 ===== */
	:global(.tk-comments .tk-input),
	:global(.tk-comments .tk-preview) {
		background: rgba(128, 128, 128, 0.03) !important;
		border: none !important;
		color: inherit !important;
		font-family: inherit !important;
		transition: all 0.3s ease;
		padding: 0.875rem 1rem !important;
	}

	:global(.tk-comments .tk-input::placeholder) {
		color: rgba(128, 128, 128, 0.4) !important;
		font-style: italic;
	}

	:global(.tk-comments .tk-input:focus) {
		border-color: var(--primary) !important;
		background: rgba(128, 128, 128, 0.02) !important;
		box-shadow: 0 0 0 3px rgba(128, 128, 128, 0.05) !important;
	}

	:global(.tk-comments .tk-actions) {
		background: transparent !important;
		padding-top: 0.5rem !important;
	}

	:global(.tk-comments .tk-action-btn) {
		color: inherit !important;
		opacity: 0.5;
		transition: all 0.2s;
		font-size: 0.875rem;
	}

	:global(.tk-comments .tk-action-btn:hover) {
		color: var(--primary) !important;
		opacity: 1;
	}

	/* ===== 提交按钮 — 古风样式 ===== */
	:global(.tk-comments .tk-submit) {
		background: linear-gradient(135deg, rgba(128, 128, 128, 0.08) 0%, rgba(128, 128, 128, 0.12) 100%) !important;
		color: inherit !important;
		border: none !important;
		border-radius: 0 !important;
		font-weight: 500 !important;
		padding: 0.5rem 1.5rem !important;
		transition: all 0.3s ease;
		letter-spacing: 0.05em;
	}

	:global(.tk-comments .tk-submit:hover) {
		background: linear-gradient(135deg, rgba(128, 128, 128, 0.12) 0%, rgba(128, 128, 128, 0.18) 100%) !important;
		border-color: var(--primary) !important;
		color: var(--primary) !important;
	}

	:global(.tk-comments .tk-preview-btn) {
		background: rgba(128, 128, 128, 0.05) !important;
		color: inherit !important;
		border: none !important;
		border-radius: 0 !important;
		transition: all 0.3s;
		padding: 0.5rem 1rem !important;
	}

	:global(.tk-comments .tk-preview-btn:hover) {
		background: rgba(128, 128, 128, 0.12) !important;
		border-color: rgba(128, 128, 128, 0.2) !important;
	}

	/* ===== 评论卡片 — 缣帛质感 ===== */
	:global(.tk-comments .tk-comment) {
		background: transparent !important;
		border: none !important;
		border-radius: 0 !important;
		margin-bottom: 1.5rem !important;
		padding: 1rem 0 !important;
		transition: all 0.35s ease;
		position: relative;
	}

	:global(.tk-comments .tk-comment::before) {
		content: "";
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(180deg, var(--primary) 0%, transparent 100%);
		opacity: 0;
		transition: opacity 0.35s ease;
	}

	:global(.tk-comments .tk-comment:hover) {
		background: rgba(128, 128, 128, 0.02) !important;
	}

	:global(.tk-comments .tk-comment:hover::before) {
		opacity: 1;
	}

	/* ===== 头像 — 圆形带光泽 ===== */
	:global(.tk-comments .tk-avatar) {
		border-radius: 50% !important;
		box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08), inset 0 1px 2px rgba(255, 255, 255, 0.3);
		border: 1px solid rgba(128, 128, 128, 0.1) !important;
	}

	/* ===== 用户名 — 加粗带过渡 ===== */
	:global(.tk-comments .tk-nick) {
		color: inherit !important;
		font-weight: 600 !important;
		transition: color 0.25s ease;
		font-family: var(--font-serif);
	}

	:global(.tk-comments .tk-nick:hover) {
		color: var(--primary) !important;
	}

	/* ===== 时间戳 — 淡化处理 ===== */
	:global(.tk-comments .tk-time) {
		color: inherit !important;
		opacity: 0.4;
		font-size: 0.8125rem;
		font-style: italic;
	}

	:global(.tk-comments .tk-meta) {
		color: inherit !important;
		opacity: 0.5;
	}

	/* ===== 评论内容 — 正文样式 ===== */
	:global(.tk-comments .tk-content) {
		color: inherit !important;
		margin-top: 0.625rem !important;
		line-height: 1.7;
	}

	:global(.tk-comments .tk-content a) {
		color: var(--primary) !important;
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 4px;
		transition: color 0.2s;
	}

	:global(.tk-comments .tk-content a:hover) {
		text-decoration-style: solid;
	}

	/* ===== 回复区域 — 无边框层次 ===== */
	:global(.tk-comments .tk-replies) {
		border-top: none !important;
		background: transparent !important;
		margin-top: 1rem !important;
		margin-left: 2.5rem !important;
	}

	:global(.tk-comments .tk-reply) {
		border: none !important;
		border-left: 1px solid rgba(128, 128, 128, 0.15) !important;
		border-radius: 0 !important;
		background: transparent !important;
		padding-left: 1rem !important;
		margin-bottom: 0.75rem !important;
	}

	/* ===== 点赞等动作按钮 ===== */
	:global(.tk-comments .tk-action),
	:global(.tk-comments .tk-icon) {
		color: inherit !important;
		opacity: 0.5;
		transition: all 0.25s;
	}

	:global(.tk-comments .tk-action:hover),
	:global(.tk-comments .tk-icon:hover) {
		color: var(--primary) !important;
		opacity: 1;
	}

	/* ===== 加载更多按钮 ===== */
	:global(.tk-comments .tk-expand) {
		background: rgba(128, 128, 128, 0.03) !important;
		border: none !important;
		color: inherit !important;
		border-radius: 0 !important;
		transition: all 0.3s;
		padding: 0.75rem 2rem !important;
		font-size: 0.875rem;
		letter-spacing: 0.05em;
	}

	:global(.tk-comments .tk-expand:hover) {
		background: rgba(128, 128, 128, 0.08) !important;
		border-color: var(--primary) !important;
		color: var(--primary) !important;
	}

	/* ===== 表情弹窗 — 与主题一致 ===== */
	:global(.tk-comments .tk-owo-popup) {
		background: var(--card-bg, rgba(255, 255, 255, 0.95)) !important;
		border: none !important;
		border-radius: 0 !important;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
		backdrop-filter: none;
	}

	/* ===== 代码块样式 ===== */
	:global(.tk-comments .tk-content code) {
		background: rgba(128, 128, 128, 0.08) !important;
		padding: 0.15em 0.4em !important;
		border-radius: 0 !important;
		font-family: inherit !important;
	}

	:global(.tk-comments .tk-content pre) {
		background: rgba(128, 128, 128, 0.04) !important;
		padding: 1rem !important;
		border-radius: 0 !important;
		border: none !important;
	}

	:global(.tk-comments .tk-content blockquote) {
		border-left: 2px solid var(--primary) !important;
		padding-left: 1rem !important;
		color: inherit !important;
		opacity: 0.75;
		background: transparent !important;
		margin: 0.75rem 0 !important;
		font-style: italic;
	}

	/* ===== 加载中与元信息 ===== */
	:global(.tk-loading) {
		color: inherit !important;
		opacity: 0.4;
	}

	/* ===== 评论计数标题 ===== */
	:global(.tk-comments-title) {
		color: inherit !important;
	}

	/* ===== 评论数量为 0 时的提示 ===== */
	:global(.tk-comments .tk-no-comment) {
		color: inherit !important;
		opacity: 0.4;
		font-style: italic;
	}

	/* ===== 输入框的轮廓光 ===== */
	:global(.tk-comments textarea:focus, .tk-comments input:focus) {
		outline: none !important;
	}

	/* ===== 暗色模式微调 ===== */
	:global(.dark .tk-comments .tk-comment) {
		border-left-color: rgba(128, 128, 128, 0.3) !important;
	}

	:global(.dark .tk-comments .tk-submit) {
		background: linear-gradient(135deg, rgba(128, 128, 128, 0.12) 0%, rgba(128, 128, 128, 0.18) 100%) !important;
	}
</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.ts";

	type TwikooGlobal = {
		init: (options: Record<string, unknown>) => void;
	};

	function initTwikoo() {
		const container = document.getElementById("twikoo-comment");
		if (!container || container.querySelector("tk-time")) return;

		const envId = container.getAttribute("data-env-id") || "";
		const region = container.getAttribute("data-region") || "";
		const path =
			container.getAttribute("data-path") || window.location.pathname;
		const lang = container.getAttribute("data-lang") || "zh-CN";

		const script = document.createElement("script");
		script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.7.4/dist/twikoo.all.min.js";
		script.async = true;

		script.onload = () => {
			const twikoo = (window as Window & { twikoo?: TwikooGlobal }).twikoo;
			if (!twikoo) return;

			twikoo.init({
				envId,
				el: "#twikoo-comment",
				region,
				path,
				lang,
				onCommentLoaded: () => {
					fixTwikooScrollIssue();
				},
			});
		};

		document.head.appendChild(script);
	}

	function fixTwikooScrollIssue() {
		const container = document.getElementById("twikoo-comment");
		if (!container) return;

		let savedScrollPos = 0;

		container.addEventListener("click", (e) => {
			const target = e.target;
			if (!(target instanceof HTMLElement)) return;
			if (
				target.closest(".tk-like") ||
				target.closest(".tk-submit") ||
				target.closest(".tk-action") ||
				target.closest("button")
			) {
				savedScrollPos = window.scrollY;

				setTimeout(() => {
					if (window.scrollY !== savedScrollPos) {
						window.scrollTo({
							top: savedScrollPos,
							behavior: "auto",
						});
					}
				}, 50);

				setTimeout(() => {
					if (window.scrollY !== savedScrollPos) {
						window.scrollTo({
							top: savedScrollPos,
							behavior: "auto",
						});
					}
				}, 200);
			}
		});

		const form = container.querySelector("form");
		if (form) {
			form.addEventListener("submit", (e) => {
				e.preventDefault();
			});
		}

		const originalHash = window.location.hash;
		window.addEventListener(
			"hashchange",
			() => {
				if (
					(window.location.hash === "" || window.location.hash === "#") &&
					Math.abs(window.scrollY - savedScrollPos) > 100
				) {
					history.replaceState(
						null,
						"",
						window.location.pathname + originalHash,
					);
					window.scrollTo({
						top: savedScrollPos,
						behavior: "auto",
					});
				}
			},
			{ passive: true },
		);
	}

	const twikooObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					initTwikoo();
					twikooObserver.disconnect();
				}
			});
		},
		{ rootMargin: "200px" },
	);

	registerPageScript("twikoo-comment", {
		shouldRun() {
			return document.getElementById("twikoo-comment") !== null;
		},
		init() {
			const container = document.getElementById("twikoo-comment");
			if (container && !container.querySelector("tk-time")) {
				twikooObserver.observe(container);
			}
			return () => {
				twikooObserver.disconnect();
			};
		},
	});
</script>
