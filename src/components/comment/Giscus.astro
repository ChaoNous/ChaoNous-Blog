---
/**
 * Giscus 评论组件
 * 基于 GitHub Discussions 的评论系统，融入现有设计风格
 */
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	repo?: string;
	repoId?: string;
	category?: string;
	categoryId?: string;
	mapping?: "pathname" | "url" | "title" | "og:title" | "specific";
	term?: string;
	theme?: string;
	lang?: string;
	reactionsEnabled?: boolean;
	emitMetadata?: boolean;
	inputPosition?: "top" | "bottom";
	loading?: "lazy" | "eager";
}

const {
	repo = "ChaoNous/ChaoNous-Blog",
	repoId = "R_kgDORfrllQ",
	category = "Announcements",
	categoryId = "DIC_kwDORfrllc4C4vsF",
	mapping = "pathname",
	term = "",
	theme = "",
	lang = "zh-CN",
	reactionsEnabled = false,
	emitMetadata = false,
	inputPosition = "top",
	loading = "lazy",
} = Astro.props;

// 自定义主题 URL - 暗金风格
const customThemeUrl = "https://chaonous.com/giscus-theme.css";
---

<div class="giscus-wrapper mt-8 mb-6">
	<!-- 评论区域标题 -->
	<div class="comment-header flex items-center gap-3 mb-4 onload-animation">
		<div class="flex items-center justify-center w-9 h-9 rounded-lg bg-(--btn-regular-bg)">
			<Icon
				name="material-symbols:chat-bubble-outline-rounded"
				class="text-lg text-(--primary)"
			/>
		</div>
		<h3 class="text-lg font-semibold text-90">
			{i18n(I18nKey.comments) || "评论"}
		</h3>
	</div>

	<!-- Giscus 容器 -->
	<div class="giscus-container relative onload-animation">
		<!-- Giscus iframe 容器 -->
		<div
			class="giscus relative z-10"
			data-repo={repo}
			data-repo-id={repoId}
			data-category={category}
			data-category-id={categoryId}
			data-mapping={mapping}
			data-term={term}
			data-strict="0"
			data-reactions-enabled={reactionsEnabled ? "1" : "0"}
			data-emit-metadata={emitMetadata ? "1" : "0"}
			data-input-position={inputPosition}
			data-theme={customThemeUrl}
			data-lang={lang}
			data-loading={loading}
		>
		</div>

		<!-- 加载占位符 -->
		<div
			class="giscus-loading absolute inset-0 flex flex-col items-center justify-center bg-(--card-bg) z-20"
		>
			<div class="loading-spinner w-8 h-8 mb-3">
				<svg
					class="animate-spin text-(--primary)"
					viewBox="0 0 24 24"
					fill="none"
				>
					<circle
						class="opacity-25"
						cx="12"
						cy="12"
						r="10"
						stroke="currentColor"
						stroke-width="3"></circle>
					<path
						class="opacity-75"
						fill="currentColor"
						d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
					></path>
				</svg>
			</div>
			<p class="text-sm text-50">正在加载评论...</p>
		</div>
	</div>
</div>

<style>
	.giscus-container {
		min-height: 200px;
	}

	.giscus-loading {
		opacity: 1;
		transition: opacity 0.3s ease;
	}

	.giscus-loading.hidden {
		opacity: 0;
		pointer-events: none;
	}

	@keyframes spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}
</style>

<script>
	// 基础主题 CSS URL
	const baseThemeUrl = "https://chaonous.com/giscus-theme.css";

	// 获取当前主题色
	function getThemeHue(): number {
		const hue = getComputedStyle(document.documentElement).getPropertyValue('--hue');
		return hue ? parseFloat(hue.trim()) : 70;
	}

	// 生成动态主题 CSS
	function generateThemeCss(hue: number): string {
		const primary = `oklch(0.70 0.14 ${hue})`;
		const primaryLight = `oklch(0.75 0.14 ${hue})`;
		const primaryDark = `oklch(0.65 0.14 ${hue})`;

		return `
			:root {
				--giscus-primary: ${primary};
				--giscus-primary-light: ${primaryLight};
				--giscus-primary-dark: ${primaryDark};
				--giscus-text: rgba(255, 255, 255, 0.85);
				--giscus-muted: rgba(255, 255, 255, 0.5);
				--giscus-border: rgba(255, 255, 255, 0.1);
			}
		`;
	}

	// 动态加载 Giscus 脚本
	function initGiscus() {
		const giscusContainer = document.querySelector(".giscus");
		const loadingEl = document.querySelector(".giscus-loading");
		if (!giscusContainer || giscusContainer.querySelector("iframe")) return;

		const hue = getThemeHue();
		const dynamicCss = generateThemeCss(hue);
		const themeUrl = `${baseThemeUrl}?inline=${encodeURIComponent(dynamicCss)}`;

		const script = document.createElement("script");
		script.src = "https://giscus.app/client.js";
		script.setAttribute(
			"data-repo",
			giscusContainer.getAttribute("data-repo") || "",
		);
		script.setAttribute(
			"data-repo-id",
			giscusContainer.getAttribute("data-repo-id") || "",
		);
		script.setAttribute(
			"data-category",
			giscusContainer.getAttribute("data-category") || "",
		);
		script.setAttribute(
			"data-category-id",
			giscusContainer.getAttribute("data-category-id") || "",
		);
		script.setAttribute(
			"data-mapping",
			giscusContainer.getAttribute("data-mapping") || "pathname",
		);
		script.setAttribute("data-strict", "0");
		script.setAttribute(
			"data-reactions-enabled",
			giscusContainer.getAttribute("data-reactions-enabled") || "0",
		);
		script.setAttribute(
			"data-emit-metadata",
			giscusContainer.getAttribute("data-emit-metadata") || "0",
		);
		script.setAttribute(
			"data-input-position",
			giscusContainer.getAttribute("data-input-position") || "top",
		);
		script.setAttribute("data-theme", themeUrl);
		script.setAttribute(
			"data-lang",
			giscusContainer.getAttribute("data-lang") || "zh-CN",
		);
		script.setAttribute(
			"data-loading",
			giscusContainer.getAttribute("data-loading") || "lazy",
		);
		script.setAttribute("crossorigin", "anonymous");
		script.async = true;

		script.onload = () => {
			const checkIframe = setInterval(() => {
				const iframe = giscusContainer.querySelector("iframe");
				if (iframe) {
					clearInterval(checkIframe);
					if (loadingEl) {
						loadingEl.classList.add("hidden");
					}
				}
			}, 100);
		};

		giscusContainer.appendChild(script);
	}

	// 更新 Giscus 主题色
	function updateGiscusTheme() {
		const iframe = document.querySelector(".giscus iframe") as HTMLIFrameElement;
		if (!iframe) return;

		const hue = getThemeHue();
		const primary = `oklch(0.70 0.14 ${hue})`;

		iframe.contentWindow?.postMessage(
			{
				giscus: {
					setConfig: {
						theme: `${baseThemeUrl}?inline=${encodeURIComponent(generateThemeCss(hue))}`
					}
				}
			},
			"https://giscus.app",
		);
	}

	// 使用 IntersectionObserver 延迟加载评论
	const giscusObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					initGiscus();
					giscusObserver.disconnect();
				}
			});
		},
		{ rootMargin: "200px" },
	);

	// 监听主题色变化
	let themeChangeTimer: number | null = null;
	const styleObserver = new MutationObserver(() => {
		if (themeChangeTimer) return;
		themeChangeTimer = window.setTimeout(() => {
			themeChangeTimer = null;
			updateGiscusTheme();
		}, 200);
	});

	// 初始化
	document.addEventListener("DOMContentLoaded", () => {
		const giscusContainer = document.querySelector(".giscus");
		if (giscusContainer) {
			giscusObserver.observe(giscusContainer);
		}
		// 监听 style 属性变化（主题色可能通过 style 更新）
		styleObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["style", "class"],
		});
	});

	// 页面导航后重新初始化
	document.addEventListener("astro:page-load", () => {
		const giscusContainer = document.querySelector(".giscus");
		if (giscusContainer && !giscusContainer.querySelector("iframe")) {
			giscusObserver.observe(giscusContainer);
		}
	});
</script>
