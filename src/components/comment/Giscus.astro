---
/**
 * Giscus 评论组件
 * 基于 GitHub Discussions 的评论系统，融入现有设计风格
 */
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	repo?: string;
	repoId?: string;
	category?: string;
	categoryId?: string;
	mapping?: "pathname" | "url" | "title" | "og:title" | "specific";
	term?: string;
	theme?: string;
	lang?: string;
	reactionsEnabled?: boolean;
	emitMetadata?: boolean;
	inputPosition?: "top" | "bottom";
	loading?: "lazy" | "eager";
}

const {
	repo = "ChaoNous/ChaoNous-Blog",
	repoId = "R_kgDORfrllQ",
	category = "Announcements",
	categoryId = "DIC_kwDORfrllc4C4vsF",
	mapping = "pathname",
	term = "",
	theme = "",
	lang = "zh-CN",
	reactionsEnabled = false,
	emitMetadata = false,
	inputPosition = "top",
	loading = "lazy",
} = Astro.props;

// 自定义主题 URL - 暗金风格
const customThemeUrl = "https://chaonous.com/giscus-theme.css";
---

<div class="giscus-wrapper mt-8 mb-6">
	<!-- 评论区域标题 -->
	<div class="comment-header flex items-center gap-3 mb-4 onload-animation">
		<div class="flex items-center justify-center w-9 h-9 rounded-lg bg-(--btn-regular-bg)">
			<Icon
				name="material-symbols:chat-bubble-outline-rounded"
				class="text-lg text-(--primary)"
			/>
		</div>
		<h3 class="text-lg font-semibold text-90">
			{i18n(I18nKey.comments) || "评论"}
		</h3>
	</div>

	<!-- Giscus 容器 -->
	<div class="giscus-container relative onload-animation">
		<!-- Giscus iframe 容器 -->
		<div
			class="giscus relative z-10"
			data-repo={repo}
			data-repo-id={repoId}
			data-category={category}
			data-category-id={categoryId}
			data-mapping={mapping}
			data-term={term}
			data-strict="0"
			data-reactions-enabled={reactionsEnabled ? "1" : "0"}
			data-emit-metadata={emitMetadata ? "1" : "0"}
			data-input-position={inputPosition}
			data-theme={customThemeUrl}
			data-lang={lang}
			data-loading={loading}
		>
		</div>

		<!-- 加载占位符 -->
		<div
			class="giscus-loading absolute inset-0 flex flex-col items-center justify-center bg-(--card-bg) z-20"
		>
			<div class="loading-spinner w-8 h-8 mb-3">
				<svg
					class="animate-spin text-(--primary)"
					viewBox="0 0 24 24"
					fill="none"
				>
					<circle
						class="opacity-25"
						cx="12"
						cy="12"
						r="10"
						stroke="currentColor"
						stroke-width="3"></circle>
					<path
						class="opacity-75"
						fill="currentColor"
						d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
					></path>
				</svg>
			</div>
			<p class="text-sm text-50">正在加载评论...</p>
		</div>
	</div>
</div>

<style>
	.giscus-container {
		min-height: 200px;
	}

	.giscus-loading {
		opacity: 1;
		transition: opacity 0.3s ease;
	}

	.giscus-loading.hidden {
		opacity: 0;
		pointer-events: none;
	}

	@keyframes spin {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}
</style>

<script>
	// 获取当前主题色 hue
	function getThemeHue(): number {
		const hue = getComputedStyle(document.documentElement).getPropertyValue('--hue');
		return hue ? parseFloat(hue.trim()) : 70;
	}

	// 生成完整的主题 CSS（内联所有样式）
	function generateThemeCss(hue: number): string {
		const primary = `oklch(0.70 0.14 ${hue})`;

		return `
/* 隐藏预览按钮 */
.gsc-comment-box-tab-link[href*="preview"],
.gsc-comment-box-tab-link[data-tab="preview"],
.gsc-comment-box-tabs button:nth-child(2) {
  display: none !important;
}

/* 隐藏 Powered by giscus */
.gsc-powered-by {
  display: none !important;
}

/* 整体容器：透明背景 */
.gsc-main, .gsc-comment-box, .gsc-comments, .gsc-header, .gsc-footer {
  background: transparent !important;
}

/* 评论输入框 */
.gsc-comment-box {
  border: 1px solid rgba(255,255,255,0.1) !important;
  border-radius: 0.75rem !important;
  overflow: hidden;
}

.gsc-comment-box-tabs {
  border-bottom: 1px solid rgba(255,255,255,0.1) !important;
}

.gsc-comment-box-tab-link {
  color: rgba(255,255,255,0.6) !important;
}

.gsc-comment-box-tab-link.selected,
.gsc-comment-box-tab-link[aria-selected="true"] {
  border-bottom-color: ${primary} !important;
  color: ${primary} !important;
}

.gsc-comment-box-textarea {
  background: rgba(0,0,0,0.3) !important;
  color: rgba(255,255,255,0.85) !important;
  border: none !important;
  font-family: 'Cinzel','Noto Serif SC',Georgia,serif !important;
}

.gsc-comment-box-textarea::placeholder {
  color: rgba(255,255,255,0.4) !important;
}

/* 评论卡片 */
.gsc-comment {
  border: 1px solid rgba(255,255,255,0.1) !important;
  border-radius: 0.75rem !important;
  background: rgba(0,0,0,0.2) !important;
  margin-bottom: 1rem;
  overflow: hidden;
}

.gsc-comment:hover {
  border-color: ${primary} !important;
}

.gsc-comment-header {
  background: rgba(255,255,255,0.03) !important;
  border-bottom: 1px solid rgba(255,255,255,0.08) !important;
}

.gsc-comment-author a {
  color: rgba(255,255,255,0.85) !important;
  text-decoration: none !important;
}

.gsc-comment-author a:hover {
  color: ${primary} !important;
}

.gsc-comment-time, .gsc-comment-time a {
  color: rgba(255,255,255,0.5) !important;
}

.gsc-comment-content {
  color: rgba(255,255,255,0.85) !important;
  font-family: 'Cinzel','Noto Serif SC',Georgia,serif !important;
}

.gsc-comment-content a {
  color: ${primary} !important;
}

/* 回复区域 */
.gsc-replies {
  border-top: 1px solid rgba(255,255,255,0.08) !important;
  background: rgba(0,0,0,0.1) !important;
}

.gsc-reply {
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: 0.5rem !important;
  background: rgba(0,0,0,0.15) !important;
}

/* 按钮 */
.gsc-comment-box-buttons button,
.gsc-pagination button,
.gsc-replies-count,
.gsc-reply-count {
  background: rgba(255,255,255,0.05) !important;
  border: 1px solid rgba(255,255,255,0.1) !important;
  color: rgba(255,255,255,0.85) !important;
  border-radius: 0.5rem !important;
}

.gsc-comment-box-buttons button:hover,
.gsc-pagination button:hover,
.gsc-replies-count:hover {
  background: rgba(255,255,255,0.1) !important;
  border-color: ${primary} !important;
}

.gsc-comment-box-buttons button.btn-primary,
.gsc-comment-box-buttons button[type="submit"] {
  background: ${primary} !important;
  border-color: ${primary} !important;
  color: #000 !important;
}

.gsc-login-button {
  background: ${primary} !important;
  border-color: ${primary} !important;
  color: #000 !important;
}

/* 字体 */
.gsc-main, .gsc-comment-box, .gsc-comments {
  font-family: 'Cinzel','Noto Serif SC',Georgia,serif !important;
}

/* 代码块 */
.gsc-comment-content code {
  background: rgba(255,255,255,0.08) !important;
  padding: 0.2em 0.4em !important;
  border-radius: 0.25rem !important;
  font-family: 'JetBrains Mono',monospace !important;
}

.gsc-comment-content pre {
  background: rgba(0,0,0,0.3) !important;
  padding: 1rem !important;
  border-radius: 0.5rem !important;
}

/* 引用 */
.gsc-comment-content blockquote {
  border-left: 3px solid ${primary} !important;
  padding-left: 1rem !important;
  color: rgba(255,255,255,0.6) !important;
}

/* 表情反应 */
.gsc-social-reaction-summary-item {
  border-color: rgba(255,255,255,0.15) !important;
  color: rgba(255,255,255,0.6) !important;
}

.gsc-social-reaction-summary-item:hover,
.gsc-social-reaction-summary-item.has-reacted {
  background: rgba(255,255,255,0.1) !important;
  border-color: ${primary} !important;
  color: ${primary} !important;
}
`;
	}

	// 创建 data URL 主题
	function createThemeUrl(hue: number): string {
		const css = generateThemeCss(hue);
		return 'data:text/css;base64,' + btoa(unescape(encodeURIComponent(css)));
	}

	// 动态加载 Giscus 脚本
	function initGiscus() {
		const giscusContainer = document.querySelector(".giscus");
		const loadingEl = document.querySelector(".giscus-loading");
		if (!giscusContainer || giscusContainer.querySelector("iframe")) return;

		const hue = getThemeHue();
		const themeUrl = createThemeUrl(hue);

		const script = document.createElement("script");
		script.src = "https://giscus.app/client.js";
		script.setAttribute("data-repo", giscusContainer.getAttribute("data-repo") || "");
		script.setAttribute("data-repo-id", giscusContainer.getAttribute("data-repo-id") || "");
		script.setAttribute("data-category", giscusContainer.getAttribute("data-category") || "");
		script.setAttribute("data-category-id", giscusContainer.getAttribute("data-category-id") || "");
		script.setAttribute("data-mapping", giscusContainer.getAttribute("data-mapping") || "pathname");
		script.setAttribute("data-strict", "0");
		script.setAttribute("data-reactions-enabled", giscusContainer.getAttribute("data-reactions-enabled") || "0");
		script.setAttribute("data-emit-metadata", giscusContainer.getAttribute("data-emit-metadata") || "0");
		script.setAttribute("data-input-position", giscusContainer.getAttribute("data-input-position") || "top");
		script.setAttribute("data-theme", themeUrl);
		script.setAttribute("data-lang", giscusContainer.getAttribute("data-lang") || "zh-CN");
		script.setAttribute("data-loading", giscusContainer.getAttribute("data-loading") || "lazy");
		script.setAttribute("crossorigin", "anonymous");
		script.async = true;

		script.onload = () => {
			const checkIframe = setInterval(() => {
				const iframe = giscusContainer.querySelector("iframe");
				if (iframe) {
					clearInterval(checkIframe);
					if (loadingEl) loadingEl.classList.add("hidden");
				}
			}, 100);
		};

		giscusContainer.appendChild(script);
	}

	// 更新 Giscus 主题色
	function updateGiscusTheme() {
		const iframe = document.querySelector(".giscus iframe") as HTMLIFrameElement;
		if (!iframe) return;

		const hue = getThemeHue();
		const themeUrl = createThemeUrl(hue);

		iframe.contentWindow?.postMessage(
			{ giscus: { setConfig: { theme: themeUrl } } },
			"https://giscus.app",
		);
	}

	// IntersectionObserver 延迟加载
	const giscusObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					initGiscus();
					giscusObserver.disconnect();
				}
			});
		},
		{ rootMargin: "200px" },
	);

	// 监听主题色变化
	let themeChangeTimer: number | null = null;
	const styleObserver = new MutationObserver(() => {
		if (themeChangeTimer) return;
		themeChangeTimer = window.setTimeout(() => {
			themeChangeTimer = null;
			updateGiscusTheme();
		}, 200);
	});

	// 初始化
	document.addEventListener("DOMContentLoaded", () => {
		const giscusContainer = document.querySelector(".giscus");
		if (giscusContainer) giscusObserver.observe(giscusContainer);
		styleObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["style", "class"],
		});
	});

	// 页面导航后重新初始化
	document.addEventListener("astro:page-load", () => {
		const giscusContainer = document.querySelector(".giscus");
		if (giscusContainer && !giscusContainer.querySelector("iframe")) {
			giscusObserver.observe(giscusContainer);
		}
	});
</script>
