---
import { Icon } from "astro-icon/components";
---

<button
	id="back-to-top-btn"
	class="back-to-top-btn"
	aria-label="Back to top"
>
	<Icon name="material-symbols:arrow-upward-rounded" class="text-xl" />
</button>

<style>
	.back-to-top-btn {
		position: fixed;
		left: 1.5rem;
		bottom: 2rem;
		z-index: 40;
		width: 5rem;
		height: 5rem;
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		opacity: 0;
		visibility: hidden;
		transform: translateY(1rem);
		transition:
			opacity 0.3s ease,
			transform 0.3s ease,
			visibility 0.3s ease;
		cursor: pointer;
	}

	.back-to-top-btn:hover {
		background: var(--btn-plain-bg-hover);
		transform: translateY(0);
	}

	.back-to-top-btn.visible {
		opacity: 0.85;
		visibility: visible;
		transform: translateY(0);
	}

	.back-to-top-btn.visible:hover {
		opacity: 1;
	}

	@media (max-width: 768px) {
		.back-to-top-btn {
			left: 1rem;
			bottom: 1.5rem;
			width: 3rem;
			height: 3rem;
		}
	}

	/* 减少动画的用户偏好设置 */
	@media (prefers-reduced-motion: reduce) {
		.back-to-top-btn {
			transition-duration: 0.01ms !important;
		}
	}
</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.js";

	class BackToTop {
		private btn: HTMLElement | null;
		private threshold = 300;
		private handleScroll = () => {
			this.updateVisibility();
		};
		private handleClick = () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		};

		constructor() {
			this.btn = document.getElementById("back-to-top-btn");
			this.init();
		}

		private init() {
			window.addEventListener("scroll", this.handleScroll, { passive: true });
			this.btn?.addEventListener("click", this.handleClick);
			this.updateVisibility();
		}

		private updateVisibility() {
			if (!this.btn) return;

			const scrollTop =
				window.scrollY || document.documentElement.scrollTop;

			if (scrollTop > this.threshold) {
				this.btn.classList.add("visible");
			} else {
				this.btn.classList.remove("visible");
			}
		}

		destroy() {
			window.removeEventListener("scroll", this.handleScroll);
			this.btn?.removeEventListener("click", this.handleClick);
		}
	}

	registerPageScript("back-to-top", {
		shouldRun() {
			return document.getElementById("back-to-top-btn") !== null;
		},
		init() {
			const instance = new BackToTop();
			return () => instance.destroy();
		},
	});
</script>