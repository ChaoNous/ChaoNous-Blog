---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import ImageWrapper from "./misc/ImageWrapper.astro";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import DropdownMenu from "./widget/DropdownMenu.astro";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
const navbarTransparentMode =
  siteConfig.banner?.navbar?.transparentMode || "semi";
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

let links: NavBarLink[] = navBarConfig.links.map(
  (item: NavBarLink | LinkPreset): NavBarLink => {
    if (typeof item === "number") {
      return LinkPresets[item];
    }
    return item;
  },
);

const rawLogo = siteConfig.navbarTitle?.logo || "assets/home/default-logo.webp";
const logoSrc = rawLogo;

const rawIcon = siteConfig.navbarTitle?.icon || "assets/home/home.webp";
const iconSrc = rawIcon;
const hasNavbarIcon = Boolean(siteConfig.navbarTitle?.icon);

function toMathSansBoldItalic(text: string): string {
  return Array.from(text)
    .map((char) => {
      const code = char.codePointAt(0);
      if (!code) return char;

      if (code >= 0x41 && code <= 0x5a) {
        return String.fromCodePoint(0x1d63c + (code - 0x41));
      }

      if (code >= 0x61 && code <= 0x7a) {
        return String.fromCodePoint(0x1d656 + (code - 0x61));
      }

      if (code >= 0x30 && code <= 0x39) {
        return String.fromCodePoint(0x1d7ec + (code - 0x30));
      }

      return char;
    })
    .join("");
}

const navbarBrandText = siteConfig.navbarTitle?.text
  ? toMathSansBoldItalic(siteConfig.navbarTitle.text)
  : siteConfig.title;
---

<div
  id="navbar"
  class="z-50 onload-animation group"
  data-transparent-mode={navbarTransparentMode}
  data-is-home={isHomePage}
>
  <div class="absolute h-8 left-0 right-0 -top-8 bg-transparent transition">
  </div>
  <div
    class:list={[
      className,
      "navbar-shell overflow-visible! max-w-(--page-width) h-18 mx-auto grid grid-cols-[auto_1fr_auto] items-center px-4 md:px-5",
    ]}
  >
    <a
      href={url("/")}
      class="navbar-brand btn-plain scale-animation rounded-lg h-10 md:h-13 md:in-[.enable-banner]:h-10 md:in-[.enable-banner]:group-[.scrolled]:h-13 px-3 md:px-4 font-bold active:scale-95 shrink-0 transition-all duration-300"
    >
      <div class="flex flex-row items-center text-md">
        {
          siteConfig.navbarTitle ? (
            siteConfig.navbarTitle.mode === "logo" ? (
              <ImageWrapper
                src={logoSrc}
                alt={siteConfig.navbarTitle.text}
                class="h-10 md:h-13 md:in-[.enable-banner]:h-10 md:in-[.enable-banner]:group-[.scrolled]:h-13 max-w-full object-contain transition-all duration-300"
                loading="lazy"
                width={200}
              />
            ) : (
              <>
                {hasNavbarIcon && (
                  <ImageWrapper
                    src={iconSrc}
                    alt={siteConfig.navbarTitle.text}
                    class="h-7 w-7 mr-2 object-contain"
                    loading="lazy"
                    width={28}
                  />
                )}
                <span class="navbar-brand-text">{navbarBrandText}</span>
              </>
            )
          ) : (
            <>
              <Icon
                name="material-symbols:home-pin-outline"
                class="text-[1.75rem] mr-2"
              />
              <span>{siteConfig.title}</span>
            </>
          )
        }
      </div>
    </a>
    <div
      id="navbar-links-container"
      class="navbar-links hidden lg:flex items-center justify-center gap-1 transition-all duration-300"
    >
      {
        links.map((l) => {
          return <DropdownMenu link={l} />;
        })
      }
    </div>
    <div class="navbar-actions flex items-center gap-1">
      <!-- 搜索：桌面端用 Search 组件，移动端用图标按钮 -->
      <div id="search-container" class="hidden lg:block">
        <Search client:media="(min-width: 1024px)" />
      </div>
      <button
        aria-label="Search"
        class="btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90 lg:hidden"
        id="mobile-search-switch"
      >
        <Icon name="material-symbols:search" class="text-[1.25rem]" />
      </button>
      <!-- 主题色切换 -->
      {
        !siteConfig.themeColor.fixed && (
          <button
            aria-label="Display Settings"
            class="btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90"
            id="display-settings-switch"
          >
            <Icon
              name="material-symbols:palette-outline"
              class="text-[1.25rem]"
            />
          </button>
        )
      }
      <!-- 深浅色切换 -->
      <div class="w-9 h-9 flex items-center justify-center">
        <LightDarkSwitch client:idle />
      </div>
      <!-- 移动端菜单按钮 -->
      <button
        aria-label="Mobile Controls"
        name="Mobile Controls"
        class="btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90 lg:hidden"
        id="nav-menu-switch"
      >
        <Icon name="material-symbols:unfold-more" class="text-[1.25rem]" />
      </button>
    </div>
    <NavMenuPanel links={links} />
    <DisplaySettings client:idle />
  </div>
</div>

<script>
  import { registerPageScript } from "../scripts/page-lifecycle.ts";

  const pagefindScriptUrl = import.meta.env.PROD ? "/pagefind/pagefind.js" : "";
  type NavbarPanelId = "display-setting" | "nav-menu-panel";

  function initSemifullScrollDetection() {
    const navbar = document.getElementById("navbar");
    if (!(navbar instanceof HTMLElement)) return () => {};
    const navbarElement = navbar;

    if (window.semifullScrollHandler) {
      window.removeEventListener("scroll", window.semifullScrollHandler);
      window.semifullScrollHandler = undefined;
    }

    const isHomePage = navbarElement.dataset.isHome === "true";

    if (!isHomePage) {
      navbarElement.classList.add("scrolled");
      return () => {
        navbarElement.classList.remove("scrolled");
      };
    }

    let ticking = false;

    function updateNavbarState() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const threshold = 50;

      if (scrollTop > threshold) {
        navbarElement.classList.add("scrolled");
      } else {
        navbarElement.classList.remove("scrolled");
      }

      ticking = false;
    }

    function requestTick() {
      if (!ticking) {
        requestAnimationFrame(updateNavbarState);
        ticking = true;
      }
    }

    window.semifullScrollHandler = requestTick;
    window.addEventListener("scroll", requestTick, { passive: true });
    updateNavbarState();

    return () => {
      window.removeEventListener("scroll", requestTick);
      if (window.semifullScrollHandler === requestTick) {
        window.semifullScrollHandler = undefined;
      }
    };
  }

  window.initSemifullScrollDetection = initSemifullScrollDetection;

  registerPageScript("navbar-interactions", {
    shouldRun() {
      return document.getElementById("navbar") !== null;
    },
    init() {
      const cleanups: Array<() => void> = [];
      const loadPanelManager = () => import("../utils/panel-manager");

      const wirePanelButton = (buttonId: string, panelId: NavbarPanelId) => {
        const button = document.getElementById(buttonId);
        if (!(button instanceof HTMLElement)) return;

        const handleClick = async (event: MouseEvent) => {
          event.preventDefault();
          event.stopPropagation();

          try {
            const { panelManager } = await loadPanelManager();
            await panelManager.togglePanel(panelId);
          } catch (error) {
            console.error("Failed to load panel manager:", error);
            document
              .getElementById(panelId)
              ?.classList.toggle("float-panel-closed");
          }
        };

        button.addEventListener("click", handleClick);
        cleanups.push(() => button.removeEventListener("click", handleClick));
      };

      wirePanelButton("display-settings-switch", "display-setting");
      wirePanelButton("nav-menu-switch", "nav-menu-panel");

      // Mobile search button — directly toggle search panel
      const mobileSearchBtn = document.getElementById("mobile-search-switch");
      if (mobileSearchBtn instanceof HTMLElement) {
        const handleMobileSearch = async (event: MouseEvent) => {
          event.preventDefault();
          event.stopPropagation();
          try {
            const { panelManager } = await loadPanelManager();
            await panelManager.togglePanel("search-panel", true);
          } catch (error) {
            console.error("Failed to open search panel:", error);
          }
        };
        mobileSearchBtn.addEventListener("click", handleMobileSearch);
        cleanups.push(() =>
          mobileSearchBtn.removeEventListener("click", handleMobileSearch),
        );
      }

      const cleanupSemifullScrollDetection = initSemifullScrollDetection();
      cleanups.push(cleanupSemifullScrollDetection);

      return () => {
        cleanups.forEach((cleanup) => cleanup());
      };
    },
  });

  if (pagefindScriptUrl) {
    registerPageScript("navbar-pagefind-loader", {
      shouldRun() {
        return document.getElementById("search-container") !== null;
      },
      init() {
        let cancelled = false;
        let timerId: number | undefined;
        let pagefindLoaded = false;
        const searchContainer = document.getElementById("search-container");

        async function initPagefind() {
          if (pagefindLoaded || cancelled) return;
          pagefindLoaded = true;

          try {
            const response = await fetch(pagefindScriptUrl, {
              method: "HEAD",
            });
            if (!response.ok) {
              throw new Error(`Pagefind script not found: ${response.status}`);
            }

            const pagefind = await import(pagefindScriptUrl);
            await pagefind.options({ excerptLength: 20 });
            window.pagefind = pagefind;
            document.dispatchEvent(new CustomEvent("pagefindready"));
          } catch (error) {
            console.error("Failed to load Pagefind:", error);
            window.pagefind = {
              search: () => Promise.resolve({ results: [] }),
            };
            document.dispatchEvent(new CustomEvent("pagefindloaderror"));
          }
        }

        if (searchContainer) {
          searchContainer.addEventListener("click", initPagefind, {
            once: true,
          });
          searchContainer.addEventListener("focusin", initPagefind, {
            once: true,
          });
        }

        if (window.matchMedia("(min-width: 1024px)").matches) {
          timerId = window.setTimeout(initPagefind, 5000);
        }

        return () => {
          cancelled = true;
          if (timerId !== undefined) {
            window.clearTimeout(timerId);
          }
        };
      },
    });
  }
</script>
