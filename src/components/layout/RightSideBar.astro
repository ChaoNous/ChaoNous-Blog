---
import type { MarkdownHeading } from "astro";
import WidgetGroup from "@components/layout/WidgetGroup.astro";
import { widgetManager } from "@/utils/widget-manager";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className, headings } = Astro.props;

const topComponents = widgetManager.getComponentsByPosition("top", "right");
const stickyComponents = widgetManager.getComponentsByPosition(
	"sticky",
	"right",
);
---

<div
	id="right-sidebar"
	class:list={[
		className,
		"flex flex-col w-full pt-0",
	]}
>
	<div
		id="right-sidebar-sticky"
		class="transition-all duration-700 flex flex-col w-full mt-0 gap-4"
	>
		{
			topComponents.length > 0 && (
				<WidgetGroup
					components={topComponents}
					headings={headings}
					wrapperClass="flex flex-col w-full gap-4"
				/>
			)
		}

		{
			stickyComponents.length > 0 && (
				<WidgetGroup
					components={stickyComponents}
					headings={headings}
					wrapperClass="transition-all duration-700 flex flex-col w-full gap-4"
				/>
			)
		}
	</div>
</div>

<style>
	@media (max-width: 768px) {
		#right-sidebar {
			display: var(--sidebar-mobile-display, block);
		}
	}

	@media (min-width: 769px) and (max-width: 1280px) {
		#right-sidebar {
			display: var(--sidebar-tablet-display, block);
		}
	}

	@media (min-width: 1281px) {
		#right-sidebar {
			display: var(--sidebar-desktop-display, block);
		}
	}

</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.js";
	import { widgetManager } from "../../utils/widget-manager";

	class RightSidebarManager {
		handleResize = () => this.updateResponsiveDisplay();

		constructor() {
			this.init();
		}

		init() {
			this.updateResponsiveDisplay();
			window.addEventListener("resize", this.handleResize);
		}

		updateResponsiveDisplay() {
			const breakpoints = widgetManager.getBreakpoints();
			const width = window.innerWidth;

			let deviceType: "mobile" | "tablet" | "desktop";
			if (width < breakpoints.mobile) {
				deviceType = "mobile";
			} else if (width < breakpoints.tablet) {
				deviceType = "tablet";
			} else {
				deviceType = "desktop";
			}

			const shouldShow = widgetManager.shouldShowSidebar(deviceType);
			const sidebar = document.getElementById("right-sidebar");

			if (sidebar) {
				sidebar.style.setProperty(
					`--sidebar-${deviceType}-display`,
					shouldShow ? "block" : "none",
				);
			}
		}

		destroy() {
			window.removeEventListener("resize", this.handleResize);
		}
	}

	type RightSidebarWindow = Window & {
		__rightSidebarManager?: RightSidebarManager | null;
	};

	registerPageScript("right-sidebar-manager", {
		shouldRun() {
			return document.getElementById("right-sidebar") !== null;
		},
		init() {
			const rightSidebarWindow = window as RightSidebarWindow;
			rightSidebarWindow.__rightSidebarManager?.destroy();
			rightSidebarWindow.__rightSidebarManager =
				new RightSidebarManager();
			return () => {
				rightSidebarWindow.__rightSidebarManager?.destroy();
				rightSidebarWindow.__rightSidebarManager = null;
			};
		},
	});
</script>
