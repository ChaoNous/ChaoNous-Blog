---
import {
	normalizeBannerSources,
	type ResolvedBannerImages,
} from "../../utils/banner-utils";
import { url } from "../../utils/url-utils";
import { getImage } from "astro:assets";

// Desktop banner images
import desktopBanner1 from "../../assets/desktop-banner/banner1.webp";
import desktopBanner2 from "../../assets/desktop-banner/banner2.webp";
import desktopBanner3 from "../../assets/desktop-banner/banner3.webp";

// Mobile banner images
import mobileBanner1 from "../../assets/mobile-banner/banner1.webp";
import mobileBanner2 from "../../assets/mobile-banner/banner2.webp";
import mobileBanner3 from "../../assets/mobile-banner/banner3.webp";

interface Props {
	bannerImages: ResolvedBannerImages;
	position?: string;
	carouselEnabled?: boolean;
	carouselInterval?: number;
}

const {
	bannerImages,
	position = "center",
	carouselEnabled = false,
	carouselInterval = 3,
} = Astro.props;

const desktopImages = normalizeBannerSources(bannerImages.desktop);
const mobileImages = normalizeBannerSources(bannerImages.mobile);
const count = Math.max(desktopImages.length, mobileImages.length);

// Map config string paths to imported image modules
const desktopImageMap: Record<string, ImageMetadata> = {
	"/assets/desktop-banner/banner1.webp": desktopBanner1,
	"/assets/desktop-banner/banner2.webp": desktopBanner2,
	"/assets/desktop-banner/banner3.webp": desktopBanner3,
};

const mobileImageMap: Record<string, ImageMetadata> = {
	"/assets/mobile-banner/banner1.webp": mobileBanner1,
	"/assets/mobile-banner/banner2.webp": mobileBanner2,
	"/assets/mobile-banner/banner3.webp": mobileBanner3,
};

// Image sizes for srcset (width in pixels)
const desktopSizes = [800, 1200, 1600];
const mobileSizes = [480, 640, 768];

// Build optimized image with srcset
async function getOptimizedImage(
	imageMap: Record<string, ImageMetadata>,
	configPath: string,
	sizes: number[],
) {
	const imported = imageMap[configPath];
	if (!imported) {
		// Fallback to original URL if image not found in map
		return { src: url(configPath), srcset: undefined, width: undefined };
	}

	const widthToUse = Math.min(imported.width, Math.max(...sizes));
	const validSizes = sizes.filter((s) => s <= imported.width);
	if (validSizes.length === 0) {
		validSizes.push(widthToUse);
	}

	const srcsetParts: string[] = [];
	for (const size of validSizes) {
		const optimized = await getImage({
			src: imported,
			width: size,
			format: "webp",
			quality: 75,
		});
		srcsetParts.push(`${optimized.src} ${size}w`);
	}

	const fallback = await getImage({
		src: imported,
		width: widthToUse,
		format: "webp",
		quality: 75,
	});

	return {
		src: fallback.src,
		srcset: srcsetParts.join(", "),
		width: widthToUse,
	};
}

// Pre-compute all optimized images
const desktopOptimized: Awaited<ReturnType<typeof getOptimizedImage>>[] = [];
const mobileOptimized: Awaited<ReturnType<typeof getOptimizedImage>>[] = [];

for (let i = 0; i < count; i++) {
	const desktopSrc = desktopImages[i] || desktopImages[0];
	const mobileSrc = mobileImages[i] || mobileImages[0];
	desktopOptimized.push(
		await getOptimizedImage(desktopImageMap, desktopSrc, desktopSizes),
	);
	mobileOptimized.push(
		await getOptimizedImage(mobileImageMap, mobileSrc, mobileSizes),
	);
}

// Object-position style
const imageStyle = `object-position: ${position}`;

// First image index for LCP optimization
const firstImageIndex = 0;
---

<div id="banner-container" class="banner-container relative h-full w-full">
	<ul id="banner-list" class="h-full w-full relative overflow-hidden">
		{
			Array.from({ length: count }).map((_, index) => {
				const desktop = desktopOptimized[index];
				const mobile = mobileOptimized[index];
				const isFirstImage = index === firstImageIndex;
				const imageLoading = isFirstImage ? "eager" : "lazy";
				const imagePriority = isFirstImage ? "high" : "low";

				return (
					<li
						class:list={[
							"banner-item carousel-item absolute inset-0 overflow-hidden bg-black",
							isFirstImage
								? "opacity-100 scale-100"
								: "opacity-0 scale-110",
						]}
						data-index={index}
						style={isFirstImage ? "z-index: 2;" : "z-index: 1;"}
					>
						<picture class="absolute inset-0 block h-full w-full">
							{/* Mobile image srcset */}
							{mobile.srcset && (
								<source
									srcset={mobile.srcset}
									sizes="(max-width: 767px) 100vw"
									media="(max-width: 767px)"
								/>
							)}
							{/* Desktop image srcset */}
							{desktop.srcset && (
								<source
									srcset={desktop.srcset}
									sizes="(max-width: 1279px) 80vw, 100vw"
								/>
							)}
							{/* Fallback img with Astro-optimized src */}
							<img
								src={desktop.src}
								alt={`Banner image ${index + 1}`}
								class="w-full h-full object-cover"
								style={imageStyle}
								loading={imageLoading}
								fetchpriority={imagePriority}
								decoding={isFirstImage ? "sync" : "async"}
								draggable="false"
							/>
						</picture>
					</li>
				);
			})
		}
	</ul>

	<script
		is:inline
		define:vars={{
			carouselType: carouselEnabled ? "carousel" : "random",
			interval: carouselInterval * 1000,
		}}
	>
		(function () {
			const container = document.getElementById("banner-container");
			if (!container) return;

			const previousCleanup = container.__bannerCarouselCleanup;
			if (typeof previousCleanup === "function") {
				previousCleanup();
			}

			const items = Array.from(
				container.querySelectorAll(".banner-item"),
			);
			if (items.length === 0) return;

			let currentIndex = 0;
			let timer = null;

			if (carouselType === "random") {
				const savedIndex = sessionStorage.getItem("banner_index");
				if (savedIndex !== null && items[Number(savedIndex)]) {
					currentIndex = Number(savedIndex);
				} else {
					currentIndex = Math.floor(Math.random() * items.length);
					sessionStorage.setItem(
						"banner_index",
						String(currentIndex),
					);
				}
			}

			const preloadImage = (index) => {
				const item = items[index];
				if (!item) return;

				const img = item.querySelector("img");
				if (!img || img.dataset.bannerPreloaded === "true") return;

				const preloadSrc = img.currentSrc || img.src;
				if (!preloadSrc) return;

				const preloadImg = new Image();
				preloadImg.src = preloadSrc;
				img.dataset.bannerPreloaded = "true";
			};

			const showItem = (index, immediate = false) => {
				items.forEach((item, itemIndex) => {
					if (immediate) {
						item.style.transition = "none";
					} else {
						item.style.removeProperty("transition");
					}

					const isActive = itemIndex === index;
					item.classList.toggle("opacity-100", isActive);
					item.classList.toggle("scale-100", isActive);
					item.classList.toggle("opacity-0", !isActive);
					item.classList.toggle("scale-110", !isActive);
					item.style.zIndex = isActive ? "2" : "1";
				});

				if (immediate) {
					requestAnimationFrame(() => {
						items.forEach((item) =>
							item.style.removeProperty("transition"),
						);
					});
				}
			};

			const stop = () => {
				if (timer) {
					clearInterval(timer);
					timer = null;
				}
			};

			const start = () => {
				if (carouselType !== "carousel" || items.length <= 1 || timer) {
					return;
				}

				timer = setInterval(() => {
					currentIndex = (currentIndex + 1) % items.length;
					preloadImage((currentIndex + 1) % items.length);
					showItem(currentIndex);
				}, interval);
			};

			const handleVisibilityChange = () => {
				if (document.hidden) {
					stop();
				} else {
					start();
				}
			};

			preloadImage(currentIndex);
			preloadImage((currentIndex + 1) % items.length);
			showItem(currentIndex, true);
			start();

			document.addEventListener(
				"visibilitychange",
				handleVisibilityChange,
			);

			container.__bannerCarouselCleanup = () => {
				stop();
				document.removeEventListener(
					"visibilitychange",
					handleVisibilityChange,
				);
			};
		})();
	</script>
</div>
