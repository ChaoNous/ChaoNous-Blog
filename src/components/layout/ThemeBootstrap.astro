---
import {
  DARK_MODE,
  DEFAULT_THEME,
  LIGHT_MODE,
  PAGE_SCALING_MIN_SCALE,
  PAGE_SCALING_TARGET_WIDTH,
  PAGE_WIDTH,
} from "../../constants/constants";

interface Props {
  configHue: number;
}

const { configHue } = Astro.props;
---

<script
  is:inline
  define:vars={{
    DEFAULT_THEME,
    LIGHT_MODE,
    DARK_MODE,
    PAGE_SCALING_MIN_SCALE,
    PAGE_SCALING_TARGET_WIDTH,
    PAGE_WIDTH,
    configHue,
  }}
>
  const storedTheme = localStorage.getItem("theme");
  const initialColorScheme =
    DEFAULT_THEME === LIGHT_MODE || DEFAULT_THEME === DARK_MODE
      ? DEFAULT_THEME
      : "";
  function getPreferredTheme() {
    if (storedTheme === LIGHT_MODE || storedTheme === DARK_MODE) {
      return storedTheme;
    }
    if (initialColorScheme) {
      return initialColorScheme;
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? DARK_MODE
      : LIGHT_MODE;
  }
  const themeValue = getPreferredTheme();
  const isDark = themeValue === DARK_MODE;
  document.documentElement.setAttribute(
    "data-theme",
    isDark ? DARK_MODE : LIGHT_MODE,
  );
  document.documentElement.setAttribute(
    "data-color-scheme",
    isDark ? "dark" : "light",
  );
  document.documentElement.setAttribute(
    "data-shiki-theme",
    isDark ? "github-dark" : "github-light",
  );
  window.theme = {
    themeValue,
    setTheme: (value) => {
      window.theme.themeValue = value;
    },
  };
  const hue = localStorage.getItem("hue") || configHue;
  document.documentElement.style.setProperty("--hue", hue);
  document.documentElement.style.setProperty("--page-width", `${PAGE_WIDTH}rem`);
  document.documentElement.setAttribute("data-theme-material", "silk");
  (function () {
    function updateViewportHeightVar() {
      document.documentElement.style.setProperty(
        "--vh",
        `${window.innerHeight * 0.01}px`,
      );
    }
    updateViewportHeightVar();
    window.__cncUpdateViewportHeight = updateViewportHeightVar;
  })();
  (function () {
    function adjustPageScale() {
      const isTouch =
        (window.matchMedia &&
          (window.matchMedia("(pointer: coarse)").matches ||
            window.matchMedia("(hover: none)").matches)) ||
        "ontouchstart" in window;
      const isPortrait =
        window.matchMedia &&
        window.matchMedia("(orientation: portrait)").matches;
      if (isTouch || isPortrait || window.innerWidth <= 1280) {
        document.documentElement.style.fontSize = "";
        return;
      }

      const targetWidth = PAGE_SCALING_TARGET_WIDTH || 2000;
      const minScale = PAGE_SCALING_MIN_SCALE || 0.85;
      const viewportWidth = document.documentElement.clientWidth;
      const scale = Math.min(
        1,
        Math.max(minScale, viewportWidth / targetWidth),
      );
      document.documentElement.style.fontSize = `${scale * 100}%`;
    }

    adjustPageScale();
    window.addEventListener("resize", adjustPageScale);
    window.addEventListener("orientationchange", adjustPageScale);
    document.addEventListener("swup:page:view", adjustPageScale);
  })();
</script>

<style
  define:vars={{
    configHue,
    "page-width": `${PAGE_WIDTH}rem`,
  }}
></style>
