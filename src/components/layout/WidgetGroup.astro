---
import type { MarkdownHeading } from "astro";
import type { WidgetComponentConfig } from "../../types/config";
import CardTOC from "@components/widget/CardTOC.astro";
import Categories from "@components/widget/Categories.astro";
import MusicPlayer from "@components/widget/MusicPlayer.svelte";
import Profile from "@components/widget/Profile.astro";
import SiteStats from "@components/widget/SiteStats.astro";
import TOC from "@components/widget/TOC.astro";
import { widgetManager } from "@utils/widget-manager";

interface Props {
  components: WidgetComponentConfig[];
  headings?: MarkdownHeading[];
  wrapperClass?: string;
}

const { components, headings, wrapperClass } = Astro.props;

const componentMap = {
  profile: Profile,
  categories: Categories,
  toc: TOC,
  "card-toc": CardTOC,
  "music-player": MusicPlayer,
  "site-stats": SiteStats,
};
---

<div class:list={wrapperClass}>
  {
    components.map((component, index) => {
      const ComponentToRender = componentMap[
        component.type as keyof typeof componentMap
      ] as any;

      if (!ComponentToRender) {
        return null;
      }

      const sharedProps = {
        class: widgetManager.getComponentClass(component, index),
        style: widgetManager.getComponentStyle(component, index),
        ...component.customProps,
      };

      const showDivider = index > 0;

      return (
        <>
          {showDivider && <div class="sidebar-divider" />}
          {(component.type === "toc" || component.type === "card-toc") &&
          headings ? (
            <ComponentToRender {...sharedProps} headings={headings} />
          ) : (
            <ComponentToRender {...sharedProps} />
          )}
        </>
      );
    })
  }
</div>
