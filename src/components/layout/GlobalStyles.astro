---
const { configHue } = Astro.props;

interface Props {
  configHue: number;
}
---

<style
  is:global
  define:vars={{
    hue: configHue,
  }}
>
  @import "../../styles/main.css";

  :root {
    --hue: var(--hue, ${configHue});
  }

  .goog-te-banner-frame,
  .goog-te-menu-frame,
  .goog-te-balloon-frame,
  #goog-gt-tt,
  .goog-tooltip,
  .goog-text-highlight {
    display: none !important;
  }

  body {
    top: 0 !important;
  }

  @layer components {
    .navbar-hidden {
      @apply opacity-0 -translate-y-16;
    }
  }
</style>
