---
import { Icon } from "astro-icon/components";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { getCategoryUrl } from "../utils/url-utils";

export interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	hideUpdateDate?: boolean;
	isHome?: boolean;
	className?: string;
	id?: string;
	words?: number;
	showWordCount?: boolean;
}

const {
	published,
	updated,
	category,
	hideUpdateDate,
	isHome,
	className = "",
	id,
	words,
	showWordCount = false,
} = Astro.props;
---

<div class:list={["post-meta-group flex flex-wrap text-50 leading-6 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <!-- publish date -->
    <div class="flex items-center">
        <div class="meta-icon">
            <Icon name="material-symbols:calendar-today-outline-rounded" class="text-xl"></Icon>
        </div>
        <span class="text-50 font-medium">{formatDateToYYYYMMDD(published)}</span>
    </div>

    <!-- update date -->
    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <!-- categories -->
    <div class="flex items-center">
        <div class="meta-icon">
            <Icon name="material-symbols:book-2-outline-rounded" class="text-xl"></Icon>
        </div>
        <a href={getCategoryUrl(category || "")}
           class="category-pill transition text-50 font-medium whitespace-nowrap">
            {category || i18n(I18nKey.uncategorized)}
        </a>
    </div>

    <!-- word count -->
    {showWordCount && words && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:article-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">
                {words} {words > 1 ? i18n(I18nKey.wordsCount) : i18n(I18nKey.wordCount)}
            </span>
        </div>
    )}

    <!-- 访问量 -->
    {!isHome && id && (
        <div class="flex items-center umami-page-views hidden" data-id={id}>
            <div class="meta-icon">
                <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 font-medium page-views-display">{i18n(I18nKey.pageViewsLoading)}</span>
        </div>
    )}
</div>

<style>
	.post-meta-group {
		font-size: 1rem;
		letter-spacing: 0.015em;
		row-gap: 0.45rem;
	}

	.post-meta-group a,
	.post-meta-group span {
		opacity: 0.9;
	}

	.category-pill {
		padding: 0.15em 0.6em;
		border-radius: 0.375rem;
		transition: color 300ms ease-in-out, background-color 300ms ease-in-out;
	}

	.category-pill:hover {
		color: var(--primary);
		background-color: color-mix(in oklch, var(--primary) 6%, transparent);
	}

	@media (max-width: 767px) {
		.post-meta-group {
			font-size: 1rem;
			gap: 0.65rem 0.9rem;
		}
	}
</style>

{!isHome && id && (
<script is:inline define:vars={{
    pageViewsText: i18n(I18nKey.profileStatsPageViews),
    visitsText: i18n(I18nKey.profileStatsVisits)
}}>
    function generateStatsText(pageViews, visits) {
        // @ts-ignore - pageViewsText and visitsText injected via define:vars at build time
        return `${pageViewsText} ${pageViews} · ${visitsText} ${visits}`;
    }

    async function fetchPageViews() {
        const container = document.querySelector('.umami-page-views');

        if (!window.oddmisc) {
            container?.classList.add('hidden');
            return;
        }

        const id = container?.dataset.id;
        if (!id) return;

        try {
            const stats = await window.oddmisc.getStats(`/posts/${id}/`);
            const pageViews = stats.pageviews || 0;
            const visits = stats.visits || 0;

            if (pageViews === 0 && visits === 0) {
                container?.classList.add('hidden');
                return;
            }

            container?.classList.remove('hidden');
            container.querySelector('.page-views-display').textContent = generateStatsText(pageViews, visits);
        } catch (error) {
            console.error('Error fetching page views:', error);
            container?.classList.add('hidden');
        }
    }

    (async () => {
        const { registerPageScript } = await import("../scripts/page-lifecycle.ts");
        registerPageScript("post-meta-page-views", {
            shouldRun() {
                return document.querySelector(".umami-page-views") !== null;
            },
            init() {
                fetchPageViews();
            },
        });
    })();
</script>
)}
