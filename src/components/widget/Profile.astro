---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
---

<div class="card-base p-3">
	<a
		aria-label="Go to About Page"
		href={url("/about/")}
		class="group block relative mx-auto mt-1 mb-3
       w-[200px] h-[200px] overflow-hidden rounded-xl active:scale-95"
	>
		<div
			class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center rounded-xl"
		>
			<Icon
				name="fa7-regular:address-card"
				class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
			/>
		</div>
		<ImageWrapper
			src={profileConfig.avatar || ""}
			alt="Profile Image of the Author"
			class="w-full h-full object-cover"
			width={300}
			height={300}
			aspectRatio="1/1"
		/>
	</a>
	<div class="px-2">
		<div
			class="font-bold text-xl text-center mb-1 transition"
			style="color: var(--text-main);"
		>
			{profileConfig.name}
		</div>
		<div
			class="h-1 w-5 bg-(--primary) mx-auto rounded-full mb-3 transition"
		>
		</div>

		<div
			class="text-[1.05rem] leading-relaxed text-center font-medium mb-4 transition whitespace-pre-line"
			style="color: var(--text-main);"
		>
			<span
				class="profile-bio"
				data-profile-bio
				data-typewriter-enabled={profileConfig.typewriter?.enable ? "true" : "false"}
				data-typewriter-speed={String(profileConfig.typewriter?.speed ?? 140)}
				data-bio={profileConfig.bio ?? ""}
			>
				{profileConfig.bio}
			</span>
			<span class="profile-bio-cursor" aria-hidden="true"></span>
		</div>

		<div class="flex flex-wrap gap-2 justify-center mb-1">
			{
				profileConfig.links.length > 1 &&
					profileConfig.links.map((item) => (
						<a
							rel="me"
							aria-label={item.name}
							href={item.url}
							target="_blank"
							class="btn-regular rounded-lg h-10 w-10 active:scale-90"
						>
							<Icon name={item.icon} class="text-[1.5rem]" />
						</a>
					))
			}
			{
				profileConfig.links.length == 1 && (
					<a
						rel="me"
						aria-label={profileConfig.links[0].name}
						href={profileConfig.links[0].url}
						target="_blank"
						class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
					>
						<Icon
							name={profileConfig.links[0].icon}
							class="text-[1.5rem]"
						/>
						{profileConfig.links[0].name}
					</a>
				)
			}
		</div>

		<div class="site-stats-container hidden">
						<hr
				class="my-2 border-none transition-colors duration-150"
			/>
			<div
				class="text-base leading-6 text-50 mt-2 text-center transition-colors duration-150"
			>
				<Icon
					name="fa7-solid:eye"
					class="inline-block mr-1 text-50 text-base align-middle"
				/>
				<span class="site-stats-display"
					>{i18n(I18nKey.profileStatsLoading)}</span
				>
			</div>
		</div>
	</div>
</div>

<style>
	.profile-bio-cursor {
		display: inline-block;
		width: 0.08em;
		height: 1em;
		margin-left: 0.2em;
		vertical-align: -0.08em;
		background: currentColor;
		opacity: 0;
		animation: profile-bio-cursor-blink 1.15s steps(1, end) infinite;
	}

	.profile-bio-cursor.is-active {
		opacity: 1;
	}

	@keyframes profile-bio-cursor-blink {
		0%,
		45% {
			opacity: 1;
		}

		55%,
		100% {
			opacity: 0;
		}
	}
</style>

<script
	is:inline
	define:vars={{
		profileBio: profileConfig.bio ?? "",
		profileTypewriterEnabled: profileConfig.typewriter?.enable ?? false,
		profileTypewriterSpeed: profileConfig.typewriter?.speed ?? 140,
		profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
		profileStatsVisits: i18n(I18nKey.profileStatsVisits),
		profileStatsUnavailable: i18n(I18nKey.profileStatsUnavailable),
	}}
>
	function generateStatsText(pageViews, visits) {
		return `${profileStatsPageViews} ${pageViews} · ${profileStatsVisits} ${visits}`;
	}

	function createTypewriterController() {
		const bioElement = document.querySelector("[data-profile-bio]");
		if (!(bioElement instanceof HTMLElement)) {
			return {
				cleanup() {},
			};
		}

		const cursor = bioElement.parentElement?.querySelector(".profile-bio-cursor");
		const shouldAnimate = profileTypewriterEnabled && profileBio.trim().length > 0;

		if (!shouldAnimate) {
			bioElement.textContent = profileBio;
			cursor?.classList.remove("is-active");
			return {
				cleanup() {},
			};
		}

		let frameId = 0;
		let timeoutId = 0;
		let charIndex = 0;
		let isDisposed = false;
		const speed = Math.max(110, Number(profileTypewriterSpeed) || 140);

		cursor?.classList.add("is-active");
		bioElement.textContent = "";

		const step = () => {
			if (isDisposed) return;
			charIndex += 1;
			bioElement.textContent = profileBio.slice(0, charIndex);
			if (charIndex >= profileBio.length) {
				cursor?.classList.remove("is-active");
				return;
			}
			timeoutId = window.setTimeout(() => {
				frameId = window.requestAnimationFrame(step);
			}, speed);
		};

		frameId = window.requestAnimationFrame(step);

		return {
			cleanup() {
				isDisposed = true;
				window.cancelAnimationFrame(frameId);
				window.clearTimeout(timeoutId);
				bioElement.textContent = profileBio;
				cursor?.classList.remove("is-active");
			},
		};
	}

	async function fetchSiteStats() {
		const container = document.querySelector(".site-stats-container");
		if (!container) {
			return;
		}

		try {
			const response = await fetch("/api/analytics/site");
			if (!response.ok) {
				throw new Error(`analytics status ${response.status}`);
			}

			const stats = await response.json();
			const pageViews = stats.pageviews || 0;
			const visits = stats.visits || 0;

			if (pageViews === 0 && visits === 0) {
				container.classList.add("hidden");
				return;
			}

			container.classList.remove("hidden");
			document.querySelectorAll(".site-stats-display").forEach((el) => {
				el.textContent = generateStatsText(pageViews, visits);
			});
		} catch (error) {
			console.error("Error fetching site stats:", error);
			container.classList.remove("hidden");
			document.querySelectorAll(".site-stats-display").forEach((el) => {
				el.textContent = profileStatsUnavailable;
			});
		}
	}

	(async () => {
		const { registerPageScript } = await import("../../scripts/page-lifecycle.ts");
		registerPageScript("profile-bio-typewriter", {
			shouldRun() {
				return document.querySelector("[data-profile-bio]") !== null;
			},
			init() {
				return createTypewriterController();
			},
		});
		registerPageScript("profile-site-stats", {
			shouldRun() {
				return document.querySelector(".site-stats-container") !== null;
			},
			init() {
				fetchSiteStats();
			},
		});
	})();
</script>
