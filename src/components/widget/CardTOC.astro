---
import type { MarkdownHeading } from "astro";
import { siteConfig } from "../../config";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
	headings?: MarkdownHeading[];
}

const { headings = [] } = Astro.props;
const className = Astro.props.class;
const style = Astro.props.style;
const tocDepth = siteConfig.toc.depth;
const useJapaneseBadge = siteConfig.toc.useJapaneseBadge;

// 序列化 headings 为 JSON 字符串，供客户端脚本使用
const headingsJson = JSON.stringify(headings);
---

<WidgetLayout
	id="card-toc"
	name="目录"
	class={className}
	style={style}
>
	<div
		class="card-toc-wrapper"
		data-depth={tocDepth}
		data-japanese-badge={useJapaneseBadge}
		data-headings={headingsJson}
	>
		<div class="toc-scroll-container max-h-[60vh] overflow-y-auto overflow-x-hidden">
			<div class="toc-content" data-card-toc-content></div>
		</div>
	</div>
</WidgetLayout>

<style>
	.toc-scroll-container::-webkit-scrollbar {
		width: 4px;
	}

	.toc-scroll-container::-webkit-scrollbar-track {
		background: transparent;
	}

	.toc-scroll-container::-webkit-scrollbar-thumb {
		background: var(--line-color);
		border-radius: 2px;
	}

	:global(.card-toc-item) {
		display: flex;
		align-items: center;
		padding: 0.5rem 0.75rem;
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.875rem;
		line-height: 1.5;
		border-radius: 0.5rem;
		transition: all 0.2s;
		cursor: pointer;
	}

	:global(.card-toc-item:hover) {
		background-color: var(--btn-regular-bg);
		color: var(--primary);
	}

	:global(.card-toc-item.active) {
		background-color: var(--btn-card-bg-active);
		color: var(--primary);
		font-weight: 500;
	}

	:global(.card-toc-badge) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.25rem;
		height: 1.25rem;
		background: var(--btn-regular-bg);
		color: var(--primary);
		border-radius: 0.25rem;
		font-size: 0.75rem;
		font-weight: bold;
		margin-right: 0.5rem;
		flex-shrink: 0;
	}

	:global(.card-toc-item.active .card-toc-badge) {
		background: var(--primary);
		color: var(--btn-content);
	}

	:global(.card-toc-dot) {
		width: 0.5rem;
		height: 0.5rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.25rem;
		flex-shrink: 0;
	}

	:global(.card-toc-dot-small) {
		width: 0.35rem;
		height: 0.35rem;
		background: var(--line-divider);
		border-radius: 50%;
		margin-right: 0.75rem;
		margin-left: 0.35rem;
		flex-shrink: 0;
	}

	:global(.card-toc-item.active .card-toc-dot),
	:global(.card-toc-item.active .card-toc-dot-small) {
		background: var(--primary);
	}

	:global(.card-toc-text) {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>

<script>
	interface HeadingData {
		depth: number;
		slug: string;
		text: string;
	}

	class CardTOC {
		private wrapper: HTMLElement | null;
		private content: HTMLElement | null;
		private headings: HTMLElement[] = [];
		private tocItems: HTMLElement[] = [];
		private activeIndex = -1;

		constructor() {
			this.wrapper = document.querySelector(".card-toc-wrapper");
			this.content = document.querySelector("[data-card-toc-content]");
			this.init();
		}

		private init() {
			// 优先使用服务端通过 data 属性传入的 headings
			const headingsAttr = this.wrapper?.dataset.headings;
			if (headingsAttr) {
				try {
					const headingsData: HeadingData[] = JSON.parse(headingsAttr);
					if (headingsData && headingsData.length > 0) {
						this.generateTOCFromHeadingsData(headingsData);
						this.bindEvents();
						return;
					}
				} catch (e) {
					console.warn("Failed to parse headings data:", e);
				}
			}
			// 如果没有服务端数据，则从 DOM 获取
			this.generateTOC();
			this.bindEvents();
			this.observeContent();
		}

		private generateTOCFromHeadingsData(headingsData: HeadingData[]) {
			if (!this.wrapper || !this.content) return;

			const maxLevel = parseInt(this.wrapper.dataset.depth || "3");
			const useJapaneseBadge = this.wrapper.dataset.japaneseBadge === "true";

			const japaneseKatakana = [
				"ア", "イ", "ウ", "エ", "オ", "カ", "キ", "ク", "ケ", "コ",
				"サ", "シ", "ス", "セ", "ソ", "タ", "チ", "ツ", "テ", "ト",
				"ナ", "ニ", "ヌ", "ネ", "ノ", "ハ", "ヒ", "フ", "ヘ", "ホ",
			];

			let minLevel = 6;
			headingsData.forEach((h) => {
				if (h.depth < minLevel) minLevel = h.depth;
			});

			let html = "";
			let h1Count = 0;
			headingsData.forEach((heading) => {
				const level = heading.depth;

				if (level >= minLevel + maxLevel) return;

				// 获取对应的 DOM 元素
				const domElement = document.getElementById(heading.slug);
				if (domElement) {
					this.headings.push(domElement as HTMLElement);
				}

				const indent = (level - minLevel) * 1;
				let badge = "";

				if (level === minLevel) {
					h1Count++;
					const badgeText =
						useJapaneseBadge && h1Count - 1 < japaneseKatakana.length
							? japaneseKatakana[h1Count - 1]
							: h1Count.toString();
					badge = `<span class="card-toc-badge">${badgeText}</span>`;
				} else if (level === minLevel + 1) {
					badge = '<span class="card-toc-dot"></span>';
				} else {
					badge = '<span class="card-toc-dot-small"></span>';
				}

				const text = heading.text.replace(/#+\s*$/, "");
				html += `<div class="card-toc-item" style="padding-left: ${0.5 + indent}rem" data-heading-id="${heading.slug}">${badge}<span class="card-toc-text">${text}</span></div>`;
			});

			if (this.content) {
				this.content.innerHTML = html;
				this.tocItems = Array.from(
					this.content.querySelectorAll(".card-toc-item"),
				);
			}

			this.wrapper.classList.remove("hidden");
			this.updateActiveHeading();
		}

		private observeContent() {
			const contentWrapper = document.getElementById("post-container");
			if (contentWrapper) {
				const observer = new MutationObserver(() => {
					this.generateTOC();
				});
				observer.observe(contentWrapper, {
					childList: true,
					subtree: true,
				});
			}
		}

		private generateTOC() {
			const container = document.getElementById("post-container");

			if (!container) {
				this.wrapper?.classList.add("hidden");
				return;
			}

			const allHeadings = container.querySelectorAll(
				"h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]",
			);

			if (allHeadings.length === 0) {
				this.wrapper?.classList.add("hidden");
				this.headings = [];
				return;
			}

			this.wrapper?.classList.remove("hidden");
			this.headings = [];

			const maxLevel = parseInt(this.wrapper?.dataset.depth || "3");
			const useJapaneseBadge =
				this.wrapper?.dataset.japaneseBadge === "true";

			const japaneseKatakana = [
				"ア", "イ", "ウ", "エ", "オ", "カ", "キ", "ク", "ケ", "コ",
				"サ", "シ", "ス", "セ", "ソ", "タ", "チ", "ツ", "テ", "ト",
				"ナ", "ニ", "ヌ", "ネ", "ノ", "ハ", "ヒ", "フ", "ヘ", "ホ",
			];

			let minLevel = 6;
			allHeadings.forEach((h) => {
				const level = parseInt(h.tagName[1]);
				if (level < minLevel) minLevel = level;
			});

			let html = "";
			let h1Count = 0;
			allHeadings.forEach((heading) => {
				const level = parseInt(heading.tagName[1]);

				if (level >= minLevel + maxLevel) return;

				this.headings.push(heading as HTMLElement);

				const indent = (level - minLevel) * 1;
				let badge = "";

				if (level === minLevel) {
					h1Count++;
					const badgeText =
						useJapaneseBadge && h1Count - 1 < japaneseKatakana.length
							? japaneseKatakana[h1Count - 1]
							: h1Count.toString();
					badge = `<span class="card-toc-badge">${badgeText}</span>`;
				} else if (level === minLevel + 1) {
					badge = '<span class="card-toc-dot"></span>';
				} else {
					badge = '<span class="card-toc-dot-small"></span>';
				}

				const text = (heading.textContent || "").replace(/#+\s*$/, "");
				html += `<div class="card-toc-item" style="padding-left: ${0.5 + indent}rem" data-heading-id="${heading.id}">${badge}<span class="card-toc-text">${text}</span></div>`;
			});

			if (this.content) {
				this.content.innerHTML = html;
				this.tocItems = Array.from(
					this.content.querySelectorAll(".card-toc-item"),
				);
			}

			this.updateActiveHeading();
		}

		private updateActiveHeading() {
			if (!this.content || this.headings.length === 0) return;

			const scrollY = window.scrollY;
			const offsetTop = 150;

			let newActiveIndex = -1;
			for (let i = 0; i < this.headings.length; i++) {
				const heading = this.headings[i];
				if (
					heading.getBoundingClientRect().top + scrollY <
					scrollY + offsetTop
				) {
					newActiveIndex = i;
				} else {
					break;
				}
			}

			if (newActiveIndex !== this.activeIndex) {
				this.activeIndex = newActiveIndex;

				this.tocItems.forEach((item, index) => {
					if (index === this.activeIndex) {
						item.classList.add("active");
					} else {
						item.classList.remove("active");
					}
				});
			}
		}

		private bindEvents() {
			window.addEventListener("scroll", () => this.updateActiveHeading(), {
				passive: true,
			});

			window.addEventListener("resize", () => this.updateActiveHeading(), {
				passive: true,
			});

			this.content?.addEventListener("click", (e) => {
				const item = (e.target as HTMLElement).closest(".card-toc-item");
				if (item) {
					const id = item.getAttribute("data-heading-id");
					if (id) {
						const element = document.getElementById(id);
						if (element) {
							const top =
								element.getBoundingClientRect().top +
								window.scrollY -
								80;
							window.scrollTo({ top, behavior: "smooth" });
						}
					}
				}
			});

			// Swup 支持
			if ((window as any).swup) {
				(window as any).swup.hooks.on("page:view", () => {
					setTimeout(() => {
						this.generateTOC();
					}, 200);
				});
			}
		}
	}

	document.addEventListener("DOMContentLoaded", () => new CardTOC());
	document.addEventListener("swup:page:view", () => new CardTOC());
</script>