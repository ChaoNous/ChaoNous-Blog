---
import type { MarkdownHeading } from "astro";
import WidgetGroup from "@components/layout/WidgetGroup.astro";
import { widgetManager } from "../../utils/widget-manager";

interface Props {
  class?: string;
  headings?: MarkdownHeading[];
  isPostPage?: boolean;
}

const { class: className, headings, isPostPage = false } = Astro.props;

const mobileTopComponents = widgetManager.getComponentsByPosition(
  "top",
  "drawer",
  "mobile",
);
const mobileStickyComponents = widgetManager.getComponentsByPosition(
  "sticky",
  "drawer",
  "mobile",
);

const tabletTopComponents = widgetManager.getComponentsByPosition(
  "top",
  "left",
  "tablet",
);
const tabletStickyComponents = widgetManager.getComponentsByPosition(
  "sticky",
  "left",
  "tablet",
);

const desktopTopComponents = widgetManager.getComponentsByPosition(
  "top",
  "left",
  "desktop",
);
const desktopStickyComponents = widgetManager.getComponentsByPosition(
  "sticky",
  "left",
  "desktop",
);

const visibleMobileTopComponents = widgetManager.getVisibleComponentsForPage(
  mobileTopComponents,
  isPostPage,
);
const visibleMobileStickyComponents = widgetManager.getVisibleComponentsForPage(
  mobileStickyComponents,
  isPostPage,
);
const visibleTabletTopComponents = widgetManager.getVisibleComponentsForPage(
  tabletTopComponents,
  isPostPage,
);
const visibleTabletStickyComponents = widgetManager.getVisibleComponentsForPage(
  tabletStickyComponents,
  isPostPage,
);
const visibleDesktopTopComponents = widgetManager.getVisibleComponentsForPage(
  desktopTopComponents,
  isPostPage,
);
const visibleDesktopStickyComponents =
  widgetManager.getVisibleComponentsForPage(
    desktopStickyComponents,
    isPostPage,
  );

type RenderGroup = {
  components: typeof mobileTopComponents;
  wrapperClass: string;
};

function normalizeComponentsForPage(components: typeof mobileTopComponents) {
  return widgetManager.getVisibleComponentsForPage(components, isPostPage);
}

function sameComponents(
  left: typeof mobileTopComponents,
  right: typeof mobileTopComponents,
) {
  return (
    JSON.stringify(normalizeComponentsForPage(left)) ===
    JSON.stringify(normalizeComponentsForPage(right))
  );
}

function buildResponsiveGroups(
  mobileComponents: typeof mobileTopComponents,
  tabletComponents: typeof mobileTopComponents,
  desktopComponents: typeof mobileTopComponents,
): RenderGroup[] {
  const normalizedMobileComponents =
    normalizeComponentsForPage(mobileComponents);
  const normalizedTabletComponents =
    normalizeComponentsForPage(tabletComponents);
  const normalizedDesktopComponents =
    normalizeComponentsForPage(desktopComponents);

  if (
    normalizedMobileComponents.length > 0 &&
    sameComponents(normalizedMobileComponents, normalizedTabletComponents) &&
    sameComponents(normalizedTabletComponents, normalizedDesktopComponents)
  ) {
    return [
      {
        components: normalizedMobileComponents,
        wrapperClass: "flex flex-col w-full gap-3",
      },
    ];
  }

  const groups: RenderGroup[] = [];

  if (normalizedMobileComponents.length > 0) {
    groups.push({
      components: normalizedMobileComponents,
      wrapperClass: "flex flex-col w-full gap-3 lg:hidden",
    });
  }

  if (
    normalizedTabletComponents.length > 0 &&
    sameComponents(normalizedTabletComponents, normalizedDesktopComponents)
  ) {
    groups.push({
      components: normalizedTabletComponents,
      wrapperClass: "hidden lg:flex flex-col w-full gap-3",
    });
    return groups;
  }

  if (normalizedTabletComponents.length > 0) {
    groups.push({
      components: normalizedTabletComponents,
      wrapperClass:
        "sidebar-content hidden lg:flex xl:hidden flex-col w-full gap-3",
    });
  }

  if (normalizedDesktopComponents.length > 0) {
    groups.push({
      components: normalizedDesktopComponents,
      wrapperClass: "sidebar-content hidden xl:flex flex-col w-full gap-3",
    });
  }

  return groups;
}

const topGroups = buildResponsiveGroups(
  mobileTopComponents,
  tabletTopComponents,
  desktopTopComponents,
);

const stickyGroups = buildResponsiveGroups(
  mobileStickyComponents,
  tabletStickyComponents,
  desktopStickyComponents,
);
---

<div
  id="sidebar"
  class:list={[className, "sidebar-root flex flex-col w-full pt-0"]}
  data-breakpoint-mobile={String(widgetManager.getBreakpoints().mobile)}
  data-breakpoint-tablet={String(widgetManager.getBreakpoints().tablet)}
  data-show-mobile={widgetManager.shouldShowSidebar("mobile")
    ? "true"
    : "false"}
  data-show-tablet={widgetManager.shouldShowSidebar("tablet")
    ? "true"
    : "false"}
  data-show-desktop={widgetManager.shouldShowSidebar("desktop")
    ? "true"
    : "false"}
  data-has-mobile={visibleMobileTopComponents.length > 0 ||
  visibleMobileStickyComponents.length > 0
    ? "true"
    : "false"}
  data-has-tablet={visibleTabletTopComponents.length > 0 ||
  visibleTabletStickyComponents.length > 0
    ? "true"
    : "false"}
  data-has-desktop={visibleDesktopTopComponents.length > 0 ||
  visibleDesktopStickyComponents.length > 0
    ? "true"
    : "false"}
>
  <div
    id="sidebar-sticky"
    class="transition-all duration-700 flex flex-col w-full mt-0 gap-3"
  >
    {
      topGroups.map((group) => (
        <WidgetGroup
          components={group.components}
          headings={headings}
          isPostPage={isPostPage}
          wrapperClass={group.wrapperClass}
        />
      ))
    }

    {
      stickyGroups.map((group) => (
        <WidgetGroup
          components={group.components}
          headings={headings}
          isPostPage={isPostPage}
          wrapperClass={group.wrapperClass}
        />
      ))
    }
  </div>
</div>

<style>
  @media (max-width: 1023px) {
    #sidebar {
      display: var(--sidebar-mobile-display, block);
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    #sidebar {
      display: var(--sidebar-tablet-display, block);
    }
  }

  @media (min-width: 1280px) {
    #sidebar {
      display: var(--sidebar-desktop-display, block);
    }
  }
</style>

<script>
  import "../../scripts/sidebar-runtime.ts";
</script>
