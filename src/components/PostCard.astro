---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import { getFileDirFromPath, getPostUrl } from "@/utils/url-utils";
import ImageWrapper from "./misc/ImageWrapper.astro";
import PostMetadata from "./PostMeta.astro";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	style?: string;
}

const { entry, style } = Astro.props;
const className = Astro.props.class;

const { title, published, updated, category, image, description, pinned } =
	entry.data;

const url = getPostUrl(entry);
const hasCover = image !== undefined && image !== null && image !== "";
const coverWidth = "28%";

const { remarkPluginFrontmatter } = await render(entry);
---

<div
	class:list={[
		"card-base post-card-shell flex flex-col-reverse md:flex-col w-full rounded-(--radius-large) overflow-hidden relative",
		className,
	]}
	style={style}
>
	<div
		class:list={[
			"post-card-body pl-6 md:pl-10 pr-6 md:pr-4 pt-6 md:pt-8 pb-6 md:pb-7 relative",
			{
				"w-full md:w-[calc(100%-3.25rem-0.75rem)]": !hasCover,
				"w-full md:w-[calc(100%-var(--coverWidth)-0.75rem)]": hasCover,
			},
		]}
	>
		<a
			href={url}
			class="post-card-title btn-plain rounded-lg transition group w-full block font-black mb-3 text-3xl text-100
				hover:text-(--primary) dark:hover:text-(--primary)
				active:text-(--primary) dark:active:text-(--primary)"
			>
			{
				pinned && (
					<Icon
						name="mdi:pin"
						class="inline text-(--primary) text-2xl mr-2 -translate-y-0.5"
					/>
				)
			}
			{title}
		</a>

		<PostMetadata
			published={published}
			updated={updated}
			category={category || ""}
			hideUpdateDate={true}
			className="mb-4"
			words={remarkPluginFrontmatter.words}
			showWordCount={true}
		/>

		<div
			class:list={[
				"post-card-excerpt transition text-100 font-bold text-lg leading-8 mb-1 pr-0 md:pr-8",
				{ "line-clamp-3 md:line-clamp-2": !description },
			]}
		>
			{description || remarkPluginFrontmatter.excerpt}
		</div>
	</div>

	{
		hasCover && (
			<a
				href={url}
				aria-label={title}
				class:list={[
					"group post-card-cover",
					"max-h-[28vh] md:max-h-none mx-4 mt-4 -mb-1 md:mb-0 md:mx-0 md:mt-0",
					"md:w-(--coverWidth) relative md:absolute md:top-4 md:bottom-4 md:right-4 rounded-xl overflow-hidden active:scale-95",
				]}
				style="aspect-ratio: 16/9;"
			>
				<div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/18 group-active:bg-black/28 transition" />
				<div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="transition opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 text-white text-5xl"
					/>
				</div>
				<ImageWrapper
					src={image}
					basePath={getFileDirFromPath(entry.filePath || "")}
					alt="Cover Image of the Post"
					class="w-full h-full"
					blur={true}
				/>
			</a>
		)
	}

	{
		!hasCover && (
			<a
				href={url}
				aria-label={title}
				class="post-card-enter !hidden md:flex! btn-regular w-13 absolute right-4 top-4 bottom-4 rounded-xl bg-(--enter-btn-bg) hover:bg-(--enter-btn-bg-hover) active:bg-(--enter-btn-bg-active) active:scale-95"
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="transition text-(--primary) text-4xl mx-auto"
				/>
			</a>
		)
	}
</div>

<style define:vars={{ coverWidth }}></style>
<style>
	.post-card-shell {
		padding-block: 0.25rem;
		content-visibility: auto;
		contain-intrinsic-size: 26rem;
	}

	.post-card-body {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.post-card-title {
		font-size: clamp(2rem, 2.3vw, 3rem);
		line-height: 1.04;
		letter-spacing: -0.03em;
		text-wrap: balance;
	}

	.post-card-excerpt {
		font-size: clamp(1rem, 1.02rem + 0.18vw, 1.18rem);
		line-height: 1.8;
		font-weight: 430;
		color: color-mix(in oklch, currentColor 72%, transparent);
		text-wrap: pretty;
		max-width: 42rem;
	}

	.post-card-cover img {
		transform: scale(1.01);
		transition:
			transform 360ms ease,
			filter 360ms ease;
	}

	.post-card-cover:hover img {
		transform: scale(1.045);
		filter: saturate(1.03) contrast(1.02);
	}

	.post-card-enter {
		opacity: 0.82;
		border: 1px solid var(--line-divider) !important;
		outline: 1px solid var(--line-divider);
		outline-offset: -1px;
	}

	.post-card-enter:hover {
		opacity: 1;
		border-color: var(--primary) !important;
		outline-color: var(--primary);
	}

	@media (max-width: 767px) {
		.post-card-title {
			font-size: 1.7rem;
			line-height: 1.12;
			letter-spacing: -0.02em;
		}

		.post-card-excerpt {
			font-size: 1rem;
			line-height: 1.72;
		}
	}
</style>
