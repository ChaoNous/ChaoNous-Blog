---
import type { CollectionEntry } from "astro:content";
import type { Page } from "astro";
import PostCard from "./PostCard.astro";

interface Props {
	page: Page<CollectionEntry<"posts">>;
}

const { page } = Astro.props;
---

<div
	id="post-list-container"
	class="post-list-container list-mode transition-all duration-500 ease-in-out rounded-(--radius-large) bg-(--card-bg) md:bg-transparent mb-4"
	data-default-layout="list"
	data-layout="list"
>
	{
		page.data.map((entry, index) => (
			<PostCard
				entry={entry}
				class:list="onload-animation"
				style={`--i: ${index}; --interval: 50ms;`}
			/>
		))
	}
</div>

<script>
	import { registerPageScript } from "../scripts/page-lifecycle.js";

	function initPostList() {
		const postListContainer = document.getElementById(
			"post-list-container",
		);
		if (!postListContainer) return;

		postListContainer.classList.remove(
			"grid-mode",
			"grid",
			"grid-cols-1",
			"md:grid-cols-2",
			"lg:grid-cols-2",
			"gap-6",
		);
		postListContainer.classList.add("list-mode", "js-initialized");
		postListContainer.dataset.layout = "list";

		const rightSidebar = document.querySelector(".right-sidebar-container");
		if (rightSidebar) {
			rightSidebar.classList.remove("hidden-in-grid-mode");
		}

		const mainGrid = document.getElementById("main-grid");
		if (mainGrid) {
			mainGrid.setAttribute("data-layout-mode", "list");
		}

		window.dispatchEvent(
			new CustomEvent("layoutInit", { detail: { layout: "list" } }),
		);
	}

	registerPageScript("post-list-layout", {
		shouldRun() {
			return document.getElementById("post-list-container") !== null;
		},
		init() {
			requestAnimationFrame(initPostList);
		},
	});
</script>

<style>
	@reference "tailwindcss";

	#post-list-container {
		min-height: 200px;
		transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	#post-list-container.list-mode {
		@apply flex flex-col gap-4;
	}

	/* 优化 Speed Index：移除初始 opacity: 0 */
	#post-list-container > :global(*) {
		/* 性能优化：使用 content-visibility */
		content-visibility: auto;
		contain-intrinsic-size: 0 200px;
	}
</style>
