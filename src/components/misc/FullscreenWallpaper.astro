---
import { siteConfig } from "../../config";
import type { FullscreenWallpaperConfig } from "../../types/config";
import { url } from "../../utils/url-utils";

interface Props {
	config: FullscreenWallpaperConfig;
	className?: string;
}

const { config, className } = Astro.props;

const getImageSources = async () => {
	let srcConfig = config.src;

	if (siteConfig.banner.imageApi?.enable && siteConfig.banner.imageApi?.url) {
		try {
			const response = await fetch(siteConfig.banner.imageApi.url);
			const text = await response.text();
			const apiImages = text.split("\n").filter((line) => line.trim());
			if (apiImages.length > 0) {
				return { desktop: apiImages, mobile: apiImages };
			}
		} catch (error) {
			console.warn("Failed to fetch images from API:", error);
		}
	}

	const toArray = (src: string | string[] | undefined): string[] =>
		Array.isArray(src) ? src : typeof src === "string" ? [src] : [];

	if (
		typeof srcConfig === "object" &&
		srcConfig !== null &&
		!Array.isArray(srcConfig)
	) {
		const desktop = toArray(srcConfig.desktop);
		const mobile = toArray(srcConfig.mobile);
		return {
			desktop: desktop.length > 0 ? desktop : mobile,
			mobile: mobile.length > 0 ? mobile : desktop,
		};
	}

	const allImages = toArray(srcConfig as string | string[]);
	return { desktop: allImages, mobile: allImages };
};

const imageSources = await getImageSources();
const hasImages =
	imageSources.desktop.length > 0 || imageSources.mobile.length > 0;

if (!hasImages) return null;

const isCarouselEnabled =
	config.carousel?.enable &&
	(imageSources.desktop.length > 1 || imageSources.mobile.length > 1);
const carouselInterval = config.carousel?.interval || 5;

const position = config.position || "center";
const zIndex = config.zIndex || -1;
const opacity = config.opacity || 0.8;
const blurAmount = config.blur || 0;
const positionClass = (() => {
	switch (position) {
		case "top":
			return "object-top";
		case "bottom":
			return "object-bottom";
		default:
			return "object-center";
	}
})();

const maxCount = Math.max(
	imageSources.desktop.length,
	imageSources.mobile.length,
);
---

<div
	class:list={[
		"fixed inset-0 w-full h-full overflow-hidden pointer-events-none",
		className,
	]}
	style={`z-index: ${zIndex}; opacity: ${opacity}; transform: translateZ(0); perspective: 1000px;`}
	data-fullscreen-wallpaper
>
	<script is:inline>
		(function () {
			const mode = localStorage.getItem("wallpaperMode") || "banner";
			if (mode !== "fullscreen") {
				document.currentScript.parentElement.style.display = "none";
			}
		})();
	</script>

	{
		isCarouselEnabled ? (
			imageSources.desktop.length > 0 && (
				<div
					class="w-full h-full relative"
					data-carousel-container
					style="transform: translateZ(0);"
				>
					{Array.from({ length: maxCount }).map((_, index) => {
						const desktopSrc =
							imageSources.desktop[index] || imageSources.desktop[0];
						const mobileSrc =
							imageSources.mobile[index] || imageSources.mobile[0];
						return (
							<picture
								class="absolute inset-0 w-full h-full"
								data-carousel-item
								data-index={index}
								style={`transform: translateZ(0); backface-visibility: hidden; will-change: opacity; ${blurAmount > 0 ? `filter: blur(${blurAmount}px); ` : ""}opacity: ${index === 0 ? 1 : 0}; transition: opacity 1s;`}
							>
								<source
									srcset={url(mobileSrc)}
									media="(max-width: 767px)"
								/>
								<img
									src={url(desktopSrc)}
									alt={`Wallpaper ${index + 1}`}
									class={`w-full h-full object-cover ${positionClass}`}
									decoding={index === 0 ? "sync" : "async"}
									loading={index === 0 ? "eager" : "lazy"}
									fetchpriority={index === 0 ? "high" : "low"}
								/>
							</picture>
						);
					})}
				</div>
			)
		) : (
			<div
				id="wallpaper-single-container"
				class="w-full h-full relative"
				data-single-wallpaper
			>
				<script
					is:inline
					define:vars={{
						desktopImages: imageSources.desktop,
						mobileImages: imageSources.mobile,
						positionClass,
						blurAmount,
					}}
				>
					(function () {
						const container = document.getElementById(
							"wallpaper-single-container",
						);
						if (!container) return;

						const mode =
							localStorage.getItem("wallpaperMode") || "banner";
						if (mode !== "fullscreen") return;

						const getRandomImage = (imageList, storageKey) => {
							if (imageList.length === 0) return null;
							if (imageList.length === 1) return imageList[0];

							const lastIndex = sessionStorage.getItem(storageKey);
							let newIndex;

							do {
								newIndex = Math.floor(
									Math.random() * imageList.length,
								);
							} while (newIndex === parseInt(lastIndex || "-1"));

							sessionStorage.setItem(
								storageKey,
								newIndex.toString(),
							);
							return imageList[newIndex];
						};

						const desktopSrc = getRandomImage(
							desktopImages,
							"wallpaper_desktop_index",
						);
						const mobileSrc = getRandomImage(
							mobileImages,
							"wallpaper_mobile_index",
						);

						if (desktopSrc) {
							const picture = document.createElement("picture");
							picture.className = "w-full h-full relative";
							picture.style.transform = "translateZ(0)";
							picture.style.opacity = "1";

							if (mobileSrc) {
								const source = document.createElement("source");
								source.srcset = mobileSrc;
								source.media = "(max-width: 767px)";
								picture.appendChild(source);
							}

							const img = document.createElement("img");
							img.src = desktopSrc;
							img.alt = "wallpaper";
							img.className = `absolute inset-0 w-full h-full object-cover ${positionClass}`;
							img.style.cssText = `transform: translateZ(0); backface-visibility: hidden; will-change: opacity; ${blurAmount > 0 ? `filter: blur(${blurAmount}px); ` : ""}opacity: 1;`;
							img.decoding = "sync";
							img.loading = "eager";
							img.fetchPriority = "high";

							picture.appendChild(img);
							container.appendChild(picture);
						}
					})();
				</script>
			</div>
		)
	}
</div>

{
	isCarouselEnabled && (
		<script is:inline define:vars={{ carouselInterval }}>
			function initFullscreenWallpaperCarousel() {
				const container = document.querySelector(
					"[data-fullscreen-wallpaper]",
				);
				if (!container) return;

				const mode = localStorage.getItem("wallpaperMode") || "banner";
				if (mode !== "fullscreen") {
					if (window.__wallpaper_cleanup) {
						window.__wallpaper_cleanup();
						window.__wallpaper_cleanup = null;
					}
					return;
				}

				if (window.__wallpaper_cleanup) {
					window.__wallpaper_cleanup();
					window.__wallpaper_cleanup = null;
				}

				const STORAGE_KEY = "chaonous_wallpaper_index";
				let savedIndex = parseInt(
					sessionStorage.getItem(STORAGE_KEY) || "0",
				);

				const carouselContainer = container.querySelector(
					"[data-carousel-container]",
				);
				if (!carouselContainer) return;

				const items = carouselContainer.querySelectorAll(
					"[data-carousel-item]",
				);
				const imageCount = items.length;

				if (imageCount === 0) return;

				let currentIndex =
					savedIndex >= 0 && savedIndex < imageCount ? savedIndex : 0;
				let timer = null;

				function initImages() {
					items.forEach((item, i) => {
						item.style.opacity = i === currentIndex ? "1" : "0";
					});
				}

				function switchNextImage() {
					const nextIndex = (currentIndex + 1) % imageCount;

					items.forEach((item, i) => {
						item.style.opacity = i === nextIndex ? "1" : "0";
					});

					currentIndex = nextIndex;
					sessionStorage.setItem(STORAGE_KEY, nextIndex.toString());
				}

				function start() {
					if (!timer && imageCount > 1) {
						timer = setInterval(() => {
							const hasElements =
								items.length > 0 && document.body.contains(items[0]);
							if (!hasElements) {
								stop();
								return;
							}
							switchNextImage();
						}, carouselInterval * 1000);
					}
				}

				function stop() {
					if (timer) {
						clearInterval(timer);
						timer = null;
					}
				}

				const handleVisibilityChange = () => {
					if (document.hidden) {
						stop();
					} else {
						start();
					}
				};

				initImages();
				start();

				document.addEventListener(
					"visibilitychange",
					handleVisibilityChange,
				);

				window.__wallpaper_cleanup = () => {
					stop();
					document.removeEventListener(
						"visibilitychange",
						handleVisibilityChange,
					);
				};
			}

			const registerWithLifecycle = () => {
				if (typeof window.registerPageScript !== "function") {
					return false;
				}

				window.registerPageScript("fullscreen-wallpaper-carousel", {
					shouldRun() {
						return (
							document.querySelector("[data-fullscreen-wallpaper]") !==
							null
						);
					},
					init() {
						initFullscreenWallpaperCarousel();
						return () => {
							if (window.__wallpaper_cleanup) {
								window.__wallpaper_cleanup();
								window.__wallpaper_cleanup = null;
							}
						};
					},
				});

				return true;
			};

			if (!registerWithLifecycle()) {
				if (document.readyState === "loading") {
					document.addEventListener(
						"DOMContentLoaded",
						initFullscreenWallpaperCarousel,
						{ once: true },
					);
				} else {
					initFullscreenWallpaperCarousel();
				}
			}

			window.addEventListener(
				"wallpaper-mode-change",
				initFullscreenWallpaperCarousel,
			);
		</script>
	)
}
