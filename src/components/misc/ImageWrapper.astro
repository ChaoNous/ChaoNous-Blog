---
import fs from "node:fs/promises";
import path from "node:path";
import sharp from "sharp";

interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "eager" | "lazy";
	width?: number;
	height?: number;
	widths?: number[];
	fetchpriority?: "high" | "low" | "auto";
	decoding?: "async" | "sync" | "auto";
	aspectRatio?: string;
	blur?: boolean;
}

import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	width,
	height,
	widths,
	fetchpriority = "auto",
	decoding = "async",
	aspectRatio,
	blur = false,
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// Astro dynamic import workaround - issue #3373
let img: ImageMetadata | undefined;
let blurDataURL: string | undefined;

if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	} else {
		img = await file();

		// Generate LQIP: resize to 8px wide, output as tiny base64 WebP
		if (blur) {
			try {
				// normalizedPath is relative to this file (e.g., "../../content/posts/guide/cover.webp")
				// Resolve from project root using the src/ directory
				const srcRelative = normalizedPath.replace(/^\.\/+/, "").replace(/^\.\.\//, "");
				const imgPath = path.join(process.cwd(), "src", srcRelative.replace(/^src\//, "").replace(/^\.\.\//, ""));
				const buffer = await sharp(imgPath)
					.resize(8, undefined, { fit: "inside" })
					.webp({ quality: 15 })
					.toBuffer();
				blurDataURL = `data:image/webp;base64,${buffer.toString("base64")}`;
			} catch (e) {
				// Fallback: skip blur placeholder on error
				console.warn(`[ImageWrapper] Blur generation failed for ${src}:`, e);
			}
		}
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;

// 检查是否是 Bilibili 图片
const isBilibiliImage = !isLocal && src.includes("hdslb.com");
// 对于外部图片（特别是Bilibili），需要设置referrerpolicy避免403错误
const referrerPolicy = !isLocal && isBilibiliImage ? "no-referrer" : undefined;
---

<div
	id={id}
	class:list={[className, "overflow-hidden relative"]}
	style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
>
	<!-- Blur placeholder (local images only) -->
	{
		blurDataURL && (
			<div
				class="absolute inset-0 z-0 bg-cover bg-center blur-placeholder transition-opacity duration-500"
				style={`background-image: url(${blurDataURL})`}
			/>
		)
	}
	<div
		class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"
	>
	</div>
	{
		isLocal && img && (
			<Image
				src={img}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				width={width}
				height={height}
				widths={
					widths ||
					(img.width > 800
						? [400, 800, 1200, 1600, img.width]
						: undefined)
				}
				fetchpriority={fetchpriority}
				decoding={decoding}
				class:list={[{ "relative z-10": blurDataURL }]}
			/>
		)
	}
	{
		!isLocal && (
			<img
				src={isPublic ? url(src) : src}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				referrerpolicy={referrerPolicy}
				crossorigin={isBilibiliImage ? "anonymous" : undefined}
				width={width}
				height={height}
				fetchpriority={fetchpriority}
				decoding={decoding}
			/>
		)
	}
</div>

<style>
	.blur-placeholder {
		filter: blur(8px) saturate(1.2);
		transform: scale(1.1);
	}
</style>
