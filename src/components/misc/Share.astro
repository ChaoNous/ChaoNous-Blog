---
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import SharePoster from "./SharePoster.svelte";

interface Props {
	title: string;
	id: string;
	pubDate: Date;
	url: string;
	class?: string;
	author?: string;
	description?: string;
	coverImage?: string;
	avatar?: string;
}

const { title, pubDate, author, description, coverImage, avatar, url } = Astro.props;
const className = Astro.props.class || "";
const copyLabel = i18n(I18nKey.copyLink);
const copiedLabel = i18n(I18nKey.copied);
const displayUrl = (() => {
	try {
		const parsedUrl = new URL(url);
		const pathname = parsedUrl.pathname.replace(/\/$/, "") || "/";
		return `${parsedUrl.host}${pathname}`;
	} catch {
		return url;
	}
})();
---

<div class={`share-component ${className}`}>
	<div class="share-left">
		<div class="share-icon">
			<svg width="1.5em" height="1.5em" viewBox="0 0 24 24">
				<path fill="currentColor" d="M17 22q-1.25 0-2.125-.875T14 19q0-.15.075-.7L7.05 14.2q-.4.375-.925.588T5 15q-1.25 0-2.125-.875T2 12t.875-2.125T5 9q.6 0 1.125.213t.925.587l7.025-4.1q-.05-.175-.062-.337T14 5q0-1.25.875-2.125T17 2t2.125.875T20 5t-.875 2.125T17 8q-.6 0-1.125-.213T14.95 7.2l-7.025 4.1q.05.175.063.338T8 12t-.012.363t-.063.337l7.025 4.1q.4-.375.925-.587T17 16q1.25 0 2.125.875T20 19t-.875 2.125T17 22"/>
			</svg>
		</div>
		<div class="share-text">
			<div class="share-title">{i18n(I18nKey.shareArticle)}</div>
			<p class="share-desc">{i18n(I18nKey.shareOnSocialDescription)}</p>
		</div>
	</div>
	<div class="share-right">
		<div class="share-link-card">
			<div class="share-link-label">URL</div>
			<div class="share-link-value" title={url}>{displayUrl}</div>
		</div>
		<button
			type="button"
			class="share-action-btn share-copy-btn"
			data-share-copy
			data-share-url={url}
			data-copy-label={copyLabel}
			data-copied-label={copiedLabel}
			aria-live="polite"
		>
			<svg width="1.1em" height="1.1em" viewBox="0 0 24 24" aria-hidden="true">
				<path
					fill="currentColor"
					d="M9 16q-.825 0-1.412-.587T7 14V4q0-.825.588-1.412T9 2h10q.825 0 1.413.588T21 4v10q0 .825-.587 1.413T19 15zm0-2h10V4H9zm-4 6q-.825 0-1.412-.587T3 18V7h2v11h11v2z"
				/>
			</svg>
			<span>{copyLabel}</span>
		</button>
		<SharePoster
			client:visible
			title={title}
			url={url}
			description={description || ""}
			author={author || ""}
			pubDate={pubDate.toISOString()}
			coverImage={coverImage}
			avatar={avatar}
			siteTitle={siteConfig.title}
		/>
	</div>
</div>

<script is:inline>
	const feedbackDuration = 2000;
	for (const button of document.querySelectorAll("[data-share-copy]")) {
		if (button instanceof HTMLButtonElement && !button.dataset.bound) {
			button.dataset.bound = "true";
			button.addEventListener("click", async () => {
				const shareUrl = button.dataset.shareUrl || "";
				const copyText = button.dataset.copyLabel || "Copy Link";
				const copiedText = button.dataset.copiedLabel || "Copied";

				try {
					if (navigator.clipboard?.writeText) {
						await navigator.clipboard.writeText(shareUrl);
					} else {
						const textarea = document.createElement("textarea");
						textarea.value = shareUrl;
						textarea.style.position = "fixed";
						textarea.style.left = "-9999px";
						document.body.appendChild(textarea);
						textarea.select();
						document.execCommand("copy");
						document.body.removeChild(textarea);
					}

					const label = button.querySelector("span");
					if (label) {
						label.textContent = copiedText;
						window.setTimeout(() => {
							label.textContent = copyText;
						}, feedbackDuration);
					}
				} catch (error) {
					console.error("Failed to copy share url:", error);
				}
			});
		}
	}
</script>

<style>
	.share-component {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.5rem;
		background: var(--license-block-bg);
		border-radius: 0.75rem;
		border: 1px solid var(--line-divider);
	}

	@media (min-width: 640px) {
		.share-component {
			flex-direction: row;
			align-items: center;
		}
	}

	.share-left {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex: 1;
	}

	.share-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 0.75rem;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		color: var(--primary);
		flex-shrink: 0;
	}

	.share-text {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.share-title {
		font-size: 1rem;
		line-height: 1.4;
		color: var(--text-secondary);
	}

	.share-desc {
		font-size: 1rem;
		line-height: 1.4;
		color: var(--text-secondary);
		margin: 0;
	}

	.share-right {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.75rem;
		width: 100%;
	}

	@media (min-width: 640px) {
		.share-right {
			width: auto;
			min-width: min(26rem, 100%);
		}
	}

	.share-link-card {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		padding: 0.875rem 1rem;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		border-radius: 0.75rem;
	}

	.share-link-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-tertiary);
	}

	.share-link-value {
		font-family: var(--font-mono, "SFMono-Regular", Consolas, monospace);
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--text-primary);
		word-break: break-all;
	}

	.share-action-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 100%;
		padding: 0.75rem 1rem;
		border-radius: 0.75rem;
		border: 1px solid var(--line-divider);
		background: var(--card-bg);
		color: var(--text-primary);
		font-size: 0.9375rem;
		font-weight: 500;
		cursor: pointer;
		transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
	}

	.share-action-btn:hover {
		background: var(--btn-regular-bg-hover);
		border-color: var(--primary);
	}

	.share-action-btn:active {
		transform: scale(0.98);
	}

	.share-copy-btn {
		color: var(--primary);
	}
</style>
