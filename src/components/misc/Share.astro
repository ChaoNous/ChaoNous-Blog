---
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import ShareButtons from "./ShareButtons.svelte";

interface Props {
	title: string;
	id: string;
	pubDate: Date;
	class?: string;
	author?: string;
	description?: string;
	coverImage?: string;
	avatar?: string;
}

const { title, pubDate, author, description, coverImage, avatar } = Astro.props;
const className = Astro.props.class || "";
const postUrl = Astro.url.toString();
---

<div class={`share-component ${className}`}>
	<div class="share-label">{i18n(I18nKey.shareArticle)}</div>
	<ShareButtons
		client:load
		title={title}
		url={postUrl}
		description={description || ""}
		author={author || ""}
		pubDate={pubDate.toISOString()}
		coverImage={coverImage}
		avatar={avatar}
		siteTitle={siteConfig.title}
	/>
</div>

<style>
	.share-component {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding: 1.5rem;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		border-radius: 1rem;
	}

	.share-label {
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--text-secondary);
	}

	@media (max-width: 640px) {
		.share-component {
			padding: 1.25rem;
		}
	}
</style>