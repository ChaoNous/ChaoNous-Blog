---
import { licenseConfig, profileConfig, siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import SharePoster from "./SharePoster.svelte";

interface Props {
	title: string;
	id: string;
	pubDate: Date;
	class: string;
	author: string;
	sourceLink: string;
	licenseName: string;
	licenseUrl: string;
	description?: string;
	coverImage?: string;
	avatar?: string;
}

const { title, pubDate, author, sourceLink, licenseName, licenseUrl, description, coverImage, avatar } =
	Astro.props;
const className = Astro.props.class;
const profileConf = profileConfig;
const licenseConf = licenseConfig;
const postUrl = sourceLink || decodeURIComponent(Astro.url.toString());
---

<div
	class={`relative transition overflow-hidden bg-(--license-block-bg) py-5 px-6 ${className}`}
>
	<div class="transition font-bold text-75">
		{title}
	</div>
	<a href={postUrl} class="link text-(--primary)">
		{postUrl}
	</a>
	<div class="flex gap-6 mt-2">
		<div>
			<div class="transition text-30 text-base">{i18n(I18nKey.author)}</div>
			<div class="transition text-75 line-clamp-2">
				{author || profileConf.name}
			</div>
		</div>
		<div>
			<div class="transition text-30 text-base">
				{i18n(I18nKey.publishedAt)}
			</div>
			<div class="transition text-75 line-clamp-2">
				{formatDateToYYYYMMDD(pubDate)}
			</div>
		</div>
		<div>
			<div class="transition text-30 text-base">
				{i18n(I18nKey.license)}
			</div>
			<a
				href={licenseName ? licenseUrl || undefined : licenseConf.url}
				target="_blank"
				class="link text-(--primary) line-clamp-2"
				>{licenseName || licenseConf.name}</a
			>
		</div>
	</div>
	<div
		class="absolute right-4 top-1/2 -translate-y-1/2"
	>
		<SharePoster
			client:load
			title={title}
			author={author || profileConf.name}
			description={description || ""}
			pubDate={formatDateToYYYYMMDD(pubDate)}
			coverImage={coverImage}
			url={postUrl}
			siteTitle={siteConfig.title}
			avatar={avatar}
		/>
	</div>
</div>
