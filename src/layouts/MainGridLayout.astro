---
import FloatingTOC from "@components/control/FloatingTOC.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";

const tocMode = siteConfig.toc.mode || "float";
const isFloatTOC = tocMode === "float";
const isSidebarTOC = tocMode === "sidebar";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  setOGTypeArticle?: boolean;
  postSlug?: string;
  canonicalUrl?: string;
  headings?: MarkdownHeading[];
  isPostPage?: boolean;
}

const {
  title,
  description,
  lang,
  setOGTypeArticle,
  postSlug,
  canonicalUrl,
  headings = [],
  isPostPage = false,
} = Astro.props;

const hasTOCHeadings = headings.length > 0;

const hasLeftSidebarComponents =
  widgetManager.getComponentsByPosition("top", "left", "desktop").length > 0 ||
  widgetManager.getComponentsByPosition("sticky", "left", "desktop").length >
    0;

const hasMobileDrawerComponents =
  widgetManager.getComponentsByPosition("top", "drawer", "mobile").length > 0 ||
  widgetManager.getComponentsByPosition("sticky", "drawer", "mobile").length >
    0;

const hasTabletLeftSidebarComponents =
  widgetManager.getComponentsByPosition("top", "left", "tablet").length > 0 ||
  widgetManager.getComponentsByPosition("sticky", "left", "tablet").length > 0;

const mobileShowSidebar = hasMobileDrawerComponents;
const tabletShowSidebar = hasTabletLeftSidebarComponents;
const desktopShowLeftSidebar = hasLeftSidebarComponents;
const desktopGridCols = desktopShowLeftSidebar
  ? "lg:grid-cols-[21rem_1fr]"
  : "lg:grid-cols-1";

const gridCols = `
  grid-cols-1
  ${desktopGridCols}
`
  .trim()
  .replace(/\s+/g, " ");

const sidebarClass = `
  ${mobileShowSidebar && hasMobileDrawerComponents ? "block" : "hidden"}
  ${desktopShowLeftSidebar ? "lg:block lg:mb-4 lg:row-start-1 lg:row-end-2 lg:max-w-80 lg:col-start-1 lg:col-end-2 lg:min-w-0" : "lg:hidden"}
`
  .trim()
  .replace(/\s+/g, " ");

const desktopMainPos = desktopShowLeftSidebar
  ? "lg:col-start-2 lg:col-end-3"
  : "lg:col-span-1";

const mainContentClass = `
  transition-swup-fade overflow-hidden w-full min-w-0
  col-span-1 row-start-1 row-end-2
  ${desktopShowLeftSidebar ? desktopMainPos : "lg:col-span-1"}
`
  .trim()
  .replace(/\s+/g, " ");
---

<Layout
  title={title}
  description={description}
  lang={lang}
  setOGTypeArticle={setOGTypeArticle}
  postSlug={postSlug}
  canonicalUrl={canonicalUrl}
>
  <script
    is:inline
    define:vars={{
      navbarTransparentMode:
        siteConfig.banner?.navbar?.transparentMode || "semi",
    }}
  >
    window.__mainGridRuntimeConfig = {
      navbarTransparentMode,
    };
  </script>

  <slot slot="head" name="head" />

  <div
    id="top-row"
    class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
    class:list={[""]}
  >
    <div
      id="navbar-wrapper"
      class="pointer-events-auto sticky top-0 transition-all"
    >
      <Navbar />
    </div>
  </div>

  <div
    id="main-content-shell"
    class="relative w-full z-30 pointer-events-none"
  >
    <div class="relative max-w-(--page-width) mx-auto pointer-events-auto">
      <div
        id="main-grid"
        class={`w-full left-0 right-0 grid ${gridCols} grid-rows-none md:grid-rows-[auto] md:items-start mx-auto gap-8 px-1 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? "mobile-no-sidebar" : ""}`}
        data-layout-mode="list"
      >
        {
          (mobileShowSidebar || tabletShowSidebar || desktopShowLeftSidebar) && (
            <div id="left-sidebar-wrapper" class="contents">
              <div
                id="left-sidebar-column"
                class={`${sidebarClass} flex flex-col w-full pt-0 self-start lg:sticky lg:top-0`}
              >
                <SideBar
                  class="w-full"
                  headings={headings}
                  isPostPage={isPostPage}
                />
                <slot name="left-sidebar" />
              </div>
            </div>
          )
        }

        <main
          id="swup-container"
          data-is-post-page={isPostPage ? "true" : "false"}
          data-swup-transition
          class={`${mainContentClass}`}
        >
          <div id="content-wrapper" class="onload-animation">
            <!-- Keep overflow hidden so long text cannot break the page width. -->
            <!-- Use an id that does not collide with the global swup object. -->
            <slot />
            <div class="footer col-span-full onload-animation hidden lg:block">
              <Footer />
            </div>
          </div>
          {
            siteConfig.toc.enable &&
              isFloatTOC &&
              hasTOCHeadings &&
              !isPostPage && <FloatingTOC />
          }
        </main>

        <div class="footer col-span-full onload-animation block lg:hidden">
          <Footer />
        </div>
      </div>
    </div>
  </div>

  {
    siteConfig.toc.enable && isSidebarTOC && hasTOCHeadings && (
      <div class="absolute w-full z-0 hidden 2xl:block">
        <div class="relative max-w-(--page-width) mx-auto">
          <div
            id="toc-wrapper"
            class:list={[
              "hidden xl:block transition absolute top-0 w-(--toc-width) items-center",
              "-left-(--toc-width)",
              {
                "toc-hide": true,
              },
            ]}
          >
            <div
              id="toc-inner-wrapper"
              class="fixed top-14 w-(--toc-width) h-[calc(100vh-10rem)] overflow-hidden"
            >
              <div
                id="toc-container"
                class="h-full w-full transition-swup-fade"
              >
                <TOC headings={headings} />
              </div>
            </div>
          </div>
        </div>
      </div>
    )
  }

  <!-- Keep a hidden TOC mount point when the sidebar TOC is not active. -->
  {
    (!siteConfig.toc.enable || isFloatTOC || !hasTOCHeadings) && (
      <div id="toc-container" class="hidden" />
    )
  }
</Layout>
