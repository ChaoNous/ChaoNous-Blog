---
import FloatingTOC from "@components/control/FloatingTOC.astro";
import Footer from "@components/Footer.astro";
import BannerCarousel from "@components/layout/BannerCarousel.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import FullscreenWallpaper from "../components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "../components/misc/IconifyLoader.astro";
import TypewriterText from "../components/TypewriterText.astro";
import TOC from "../components/widget/TOC.astro";
import { fullscreenWallpaperConfig, siteConfig } from "../config";
import { BANNER_HEIGHT, BANNER_HEIGHT_EXTEND } from "../constants/constants";
import { resolveBannerImages } from "../utils/banner-utils";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";
import "../styles/main-grid-layout.css";

const tocMode = siteConfig.toc.mode || "float";
const isFloatTOC = tocMode === "float";
const isSidebarTOC = tocMode === "sidebar";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
	isPostPage?: boolean;
}

const bannerImages = await resolveBannerImages(
	siteConfig.banner.src,
	siteConfig.banner.imageApi,
);

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
	isPostPage = false,
} = Astro.props;
const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
const showHomeText = siteConfig.banner.homeText?.enable && isHomePage;

const mainPanelTop =
	siteConfig.wallpaperMode.defaultMode === "banner"
		? `${BANNER_HEIGHT}vh`
		: "5.5rem";

const finalMainPanelTop =
	siteConfig.wallpaperMode.defaultMode === "banner"
		? isHomePage
			? `calc(${BANNER_HEIGHT + BANNER_HEIGHT_EXTEND}vh + 2rem)`
			: mainPanelTop
		: "5.5rem";

const hasLeftSidebarComponents =
	widgetManager.getComponentsByPosition("top", "left", "desktop").length >
		0 ||
	widgetManager.getComponentsByPosition("sticky", "left", "desktop").length >
		0;

const hasRightSidebarComponents =
	widgetManager.getComponentsByPosition("top", "right", "desktop").length >
		0 ||
	widgetManager.getComponentsByPosition("sticky", "right", "desktop").length >
		0;

const hasMobileDrawerComponents =
	widgetManager.getComponentsByPosition("top", "drawer", "mobile").length >
		0 ||
	widgetManager.getComponentsByPosition("sticky", "drawer", "mobile").length >
		0;

const hasTabletLeftSidebarComponents =
	widgetManager.getComponentsByPosition("top", "left", "tablet").length > 0 ||
	widgetManager.getComponentsByPosition("sticky", "left", "tablet").length >
		0;

const mobileShowSidebar = hasMobileDrawerComponents;
const tabletShowSidebar = hasTabletLeftSidebarComponents;
const desktopShowSidebar =
	hasLeftSidebarComponents || hasRightSidebarComponents;

const desktopShowLeftSidebar = hasLeftSidebarComponents;
const desktopShowRightSidebar = hasRightSidebarComponents;

const tabletShowLeftSidebar = hasTabletLeftSidebarComponents;
const tabletShowRightSidebar = false; // 平板端暂不显示右侧边栏，与 tabletShowLeftSidebar 保持对称
const tabletAnySidebar = tabletShowLeftSidebar;

let desktopGridCols = "lg:grid-cols-1";
if (desktopShowLeftSidebar && desktopShowRightSidebar) {
	desktopGridCols = "lg:grid-cols-[18rem_1fr_18rem]";
} else if (desktopShowLeftSidebar) {
	desktopGridCols = "lg:grid-cols-[18rem_1fr]";
} else if (desktopShowRightSidebar) {
	desktopGridCols = "lg:grid-cols-[1fr_18rem]";
}

const gridCols = `
	grid-cols-1
	${desktopGridCols}
`
	.trim()
	.replace(/\s+/g, " ");

const sidebarClass = `
	${mobileShowSidebar && hasMobileDrawerComponents ? "block" : "hidden"}
	${desktopShowLeftSidebar ? "lg:block lg:mb-4 lg:row-start-1 lg:row-end-2 lg:max-w-80 lg:col-start-1 lg:col-end-2 lg:min-w-0" : "lg:hidden"}
`
	.trim()
	.replace(/\s+/g, " ");

const rightSidebarClass = `
	hidden
	${desktopShowRightSidebar ? `lg:block lg:mb-4 lg:row-start-1 lg:row-end-2 lg:max-w-80 lg:min-w-0 ${desktopShowLeftSidebar ? "lg:col-start-3 lg:col-end-4" : "lg:col-start-2 lg:col-end-3"} lg:col-span-1` : "lg:hidden"}

`
	.trim()
	.replace(/\s+/g, " ");

let desktopMainPos = "lg:col-span-1";
if (desktopShowLeftSidebar && desktopShowRightSidebar) {
	desktopMainPos = "lg:col-start-2 lg:col-end-3";
} else if (desktopShowLeftSidebar) {
	desktopMainPos = "lg:col-start-2 lg:col-end-3";
} else if (desktopShowRightSidebar) {
	desktopMainPos = "lg:col-start-1 lg:col-end-2";
}

const mainContentClass = `
	transition-swup-fade overflow-hidden w-full min-w-0
	col-span-1 row-start-1 row-end-2
	${desktopShowSidebar ? desktopMainPos : "lg:col-span-1"}
`
	.trim()
	.replace(/\s+/g, " ");

const shouldEnableTransparency =
	siteConfig.wallpaperMode.defaultMode === "fullscreen";

const transparentClass = shouldEnableTransparency
	? "wallpaper-transparent"
	: "";
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
	postSlug={postSlug}
>
	<script
		is:inline
		define:vars={{
			navbarTransparentMode:
				siteConfig.banner?.navbar?.transparentMode || "semi",
			defaultWallpaperMode: siteConfig.wallpaperMode.defaultMode,
			BANNER_HEIGHT: BANNER_HEIGHT,
			BANNER_HEIGHT_EXTEND: BANNER_HEIGHT_EXTEND,
			pageScaling: siteConfig.pageScaling,
		}}
	>
		window.__mainGridRuntimeConfig = {
			navbarTransparentMode,
			defaultWallpaperMode,
			BANNER_HEIGHT,
			BANNER_HEIGHT_EXTEND,
			pageScaling,
		};
	</script>

	<script>
		import "../scripts/main-grid-runtime.js?rev=sticky-home-banner";
	</script>

	<!-- 全屏壁纸组件 - 在 banner 模式下由 JS 控制显隐 -->
	<FullscreenWallpaper config={fullscreenWallpaperConfig} />

	<!-- Iconify 图标加载器 -->
	<IconifyLoader />

	<!-- Navbar -->
	<slot slot="head" name="head" />
	<div
		id="top-row"
		class="z-50 pointer-events-none relative transition-all duration-700 max-w-(--page-width) px-0 md:px-4 mx-auto"
		class:list={[""]}
	>
		<div
			id="navbar-wrapper"
			class="pointer-events-auto sticky top-0 transition-all"
		>
			<Navbar />
		</div>
	</div>

	<!-- Banner - 仅在 banner 模式下显示，由 JS 控制高度和过渡动画 -->
	<div
		id="banner-wrapper"
		class="absolute z-10 w-full transition duration-700 overflow-hidden h-[var(--banner-height-home)]"
		style={`top: -${BANNER_HEIGHT_EXTEND}vh`}
	>
		<BannerCarousel
			bannerImages={bannerImages}
			position={siteConfig.banner.position}
			carouselEnabled={siteConfig.banner.carousel?.enable}
			carouselInterval={siteConfig.banner.carousel?.interval || 3}
		/>

		<!-- Home page text overlay -->
		{
			siteConfig.banner.homeText?.enable && (
				<div
					class:list={[
						"banner-text-overlay absolute inset-0 z-20 flex items-center justify-center",
						{ hidden: !showHomeText },
					]}
				>
					<div class="max-w-(--page-width) w-full px-0 md:px-4 mx-auto flex items-center justify-center h-full">
						<div class="w-4/5 lg:w-3/4 text-center mb-0">
							<div class="flex flex-col">
								{siteConfig.banner.homeText?.title && (
									<h1 class="banner-title text-6xl lg:text-8xl text-white drop-shadow-lg mb-2 lg:mb-4">
										{siteConfig.banner.homeText.title}
									</h1>
								)}
								{siteConfig.banner.homeText?.subtitle && (
									<h2 class="banner-subtitle text-xl lg:text-3xl text-white/90 drop-shadow-md">
										<span class="inline-block min-h-[1.2em]">
											{siteConfig.banner.homeText
												.typewriter?.enable ? (
												<TypewriterText
													text={
														siteConfig.banner
															.homeText.subtitle
													}
													speed={
														siteConfig.banner
															.homeText.typewriter
															.speed
													}
													deleteSpeed={
														siteConfig.banner
															.homeText.typewriter
															.deleteSpeed
													}
													pauseTime={
														siteConfig.banner
															.homeText.typewriter
															.pauseTime
													}
												/>
											) : Array.isArray(
													siteConfig.banner.homeText
														.subtitle,
											  ) ? (
												siteConfig.banner.homeText
													.subtitle[0]
											) : (
												siteConfig.banner.homeText
													.subtitle
											)}
										</span>
									</h2>
								)}
							</div>
						</div>
					</div>
				</div>
			)
		}
	</div>

	<!-- Main content -->
	<div
		id="main-content-shell"
		class={`absolute w-full z-30 pointer-events-none ${transparentClass}`}
		style={`top: ${finalMainPanelTop}`}
	>
		<!-- The pointer-events-none here prevent blocking the click event of the TOC -->
		<div class="relative max-w-(--page-width) mx-auto pointer-events-auto">
			<div
				id="main-grid"
				class={`transition duration-700 w-full left-0 right-0 grid ${gridCols} grid-rows-none md:grid-rows-[auto] md:items-start mx-auto gap-4 px-2 md:px-4 ${!mobileShowSidebar || !hasMobileDrawerComponents ? "mobile-no-sidebar" : ""} ${hasRightSidebarComponents ? "mobile-both-sidebar" : ""}`}
				data-layout-mode="list"
			>
				<!-- Banner image credit -->
				{
					hasBannerCredit && (
						<a
							href={siteConfig.banner.credit.url}
							id="banner-credit"
							target="_blank"
							rel="noopener"
							aria-label="Visit image source"
							class:list={[
								"group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
									"px-3 right-4 -top-13 bg-black/60 hover:bg-black/70 h-9",
								{
									"hover:pr-9 active:bg-black/80":
										hasBannerLink,
								},
							]}
						>
							<Icon
								class="text-white/75 text-[1.25rem] mr-1"
								name="material-symbols:copyright-outline-rounded"
							/>
							<div class="text-white/75 text-xs">
								{siteConfig.banner.credit.text}
							</div>
							<Icon
								class:list={[
									"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
									{
										"group-hover:opacity-100":
											hasBannerLink,
									},
								]}
								name="fa7-solid:arrow-up-right-from-square"
							/>
						</a>
					)
				}

				{
					/* 濠电偞鎸婚惃婊堝			{
				/* 左侧边栏 - 根据配置条件渲染 */
				}
				{
					(mobileShowSidebar ||
						tabletShowSidebar ||
						desktopShowSidebar) && (
						<div id="left-sidebar-wrapper" class="contents">
							<div
								id="left-sidebar-column"
								class={`${sidebarClass} ${transparentClass} flex flex-col w-full pt-0 self-start lg:sticky lg:top-0`}
							>
								<SideBar
									class="w-full"
									headings={headings}
									isPostPage={isPostPage}
								/>
								<slot name="left-sidebar" />
							</div>
						</div>
					)
				}

				{
					hasRightSidebarComponents && (
						<div id="right-sidebar-static" class="contents">
							<div
								id="right-sidebar-column"
								class={`right-sidebar-container ${rightSidebarClass} ${transparentClass} flex flex-col w-full pt-0 self-start xl:sticky xl:top-0`}
							>
								<RightSideBar headings={headings} />
							</div>
						</div>
					)
				}

				<main
					id="swup-container"
					data-is-post-page={isPostPage ? "true" : "false"}
					class={`${mainContentClass} transition-main`}
				>
					<div
						id="content-wrapper"
						class="onload-animation transition-leaving"
					>
						<!-- the overflow-hidden here prevent long text break the layout-->
						<!-- make id different from windows.swup global property -->
						<slot />
						<div
							class="footer col-span-full onload-animation hidden lg:block"
						>
							<Footer />
						</div>
					</div>
					{
						siteConfig.toc.enable && isFloatTOC && !isPostPage && (
							<FloatingTOC />
						)
					}
				</main>

				<div
					class="footer col-span-full onload-animation block lg:hidden"
				>
					<Footer />
				</div>
			</div>
		</div>
	</div>

	{
		siteConfig.toc.enable && isSidebarTOC && (
			<div class="absolute w-full z-0 hidden 2xl:block">
				<div class="relative max-w-(--page-width) mx-auto">
					<div
						id="toc-wrapper"
						class:list={[
							"hidden xl:block transition absolute top-0 w-(--toc-width) items-center",
							"-left-(--toc-width)",
							{
								"toc-hide":
									siteConfig.wallpaperMode.defaultMode ===
									"banner",
							},
						]}
					>
						<div
							id="toc-inner-wrapper"
							class="fixed top-14 w-(--toc-width) h-[calc(100vh-10rem)] overflow-hidden"
						>
							<div
								id="toc-container"
								class="h-full w-full transition-swup-fade"
							>
								<TOC headings={headings} />
							</div>
						</div>
					</div>
				</div>
			</div>
		)
	}

	<!-- 空 TOC 容器占位 - 在非 sidebar-TOC 模式下保留节点供 Swup 切换时识别 -->
	{
		(!siteConfig.toc.enable || isFloatTOC) && (
			<div id="toc-container" class="hidden" />
		)
	}
</Layout>
