---
import ConfigCarrier from "@components/ConfigCarrier.astro";
import BackToTop from "@components/control/BackToTop.astro";
import GlobalStyles from "@components/layout/GlobalStyles.astro";
import SilkWeaveFilter from "@components/layout/SilkWeaveFilter.astro";
import SkipToContent from "@components/layout/SkipToContent.astro";
import ThemeBootstrap from "@components/layout/ThemeBootstrap.astro";
import ViewportHeightRuntime from "@components/layout/ViewportHeightRuntime.astro";
import HeadMeta from "@components/seo/HeadMeta.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import MusicPlayer from "@components/widget/MusicPlayer.svelte";
import { musicPlayerConfig, profileConfig, siteConfig } from "@/config";
import { pathsEqual, url } from "../utils/url-utils";
interface Props {
  title?: string;
  description?: string;
  lang?: string;
  setOGTypeArticle?: boolean;
  postSlug?: string;
  canonicalUrl?: string;
}
let { title, description, lang, setOGTypeArticle, postSlug } = Astro.props;
const canonicalUrl = Astro.props.canonicalUrl || Astro.url.toString();
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));
const configHue = siteConfig.themeColor.hue;
let pageTitle: string;
if (title) {
  pageTitle = `${title} - ${siteConfig.title}`;
} else {
  pageTitle = siteConfig.subtitle
    ? `${siteConfig.title} - ${siteConfig.subtitle}`
    : siteConfig.title;
}
let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
  ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}
if (!lang) {
  lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");
const isChineseSite = siteLang.toLowerCase().startsWith("zh");
const skipToContentLabel = isChineseSite
  ? "\u8df3\u8f6c\u5230\u6b63\u6587"
  : "Skip to content";
---

<!doctype html>
<html lang={siteLang} class="bg-(--page-bg) text-[13px] md:text-[16px]">
  <head>
    <HeadMeta
      canonicalUrl={canonicalUrl}
      description={description}
      ogImageUrl={ogImageUrl}
      pageTitle={pageTitle}
      setOGTypeArticle={setOGTypeArticle}
    />
    <ThemeBootstrap configHue={configHue} />
    <slot name="head" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={profileConfig.name}
      href={`${Astro.site}rss.xml`}
    />

    <JsonLd type={setOGTypeArticle ? "article" : "website"} />
  </head>
  <body
    class:list={[
      "min-h-screen",
      {
        "is-home-page": isHomePage,
      },
    ]}
  >
    <SkipToContent label={skipToContentLabel} />
    <script>
      import "../scripts/page-lifecycle.ts";
    </script>
    <SilkWeaveFilter />
    <ConfigCarrier />
    <slot />
    <BackToTop />
    <script>
      import "../scripts/theme.ts";
    </script>

    {musicPlayerConfig.enable && <MusicPlayer client:idle />}

    <div id="page-height-extend" class="hidden h-[300vh]"></div>
  </body>
</html>

<GlobalStyles configHue={configHue} />

<script>
  import "../scripts/layout-runtime.ts";
</script>

<ViewportHeightRuntime />

<script>
  import "../scripts/deferred-page-scripts.ts";
</script>
