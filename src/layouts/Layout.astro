---
import ConfigCarrier from "@components/ConfigCarrier.astro";
import BackToTop from "@components/control/BackToTop.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import MusicPlayer from "@components/widget/MusicPlayer.svelte";
import { musicPlayerConfig, profileConfig, siteConfig } from "@/config";
import { commentConfig } from "@/config";

const BANNER_HEIGHT = 40;
const BANNER_HEIGHT_EXTEND = 20;
const BANNER_HEIGHT_HOME = BANNER_HEIGHT + BANNER_HEIGHT_EXTEND;

import {
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
	PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "../constants/icon";
import type { Favicon } from "../types/config";
import { pathsEqual, url } from "../utils/url-utils";
import "../styles/mobile-navbar.css";
import "../styles/panel-animations.css";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
}

let { title, banner, description, lang, setOGTypeArticle, postSlug } =
	Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));

// defines global css variables
// why doing this in Layout instead of GlobalStyles: https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;

// Resolve the banner source for desktop and mobile variants.
const getBannerSrc = (
	src: typeof siteConfig.banner.src,
	type: "desktop" | "mobile",
): string => {
	if (!src) return `/assets/${type}-banner/banner1.webp`;
	if (typeof src === "string") return src;
	if (Array.isArray(src)) return src[0] || `/assets/${type}-banner/banner1.webp`;
	if (typeof src === "object" && src[type]) {
		const typeSrc = src[type];
		if (typeof typeSrc === "string") return typeSrc;
		if (Array.isArray(typeSrc) && typeSrc.length > 0) return typeSrc[0];
	}
	// Fall back to the other variant if the preferred one is not available.
	const fallbackType = type === "desktop" ? "mobile" : "desktop";
	if (typeof src === "object" && src[fallbackType]) {
		const fallbackSrc = src[fallbackType];
		if (typeof fallbackSrc === "string") return fallbackSrc;
		if (Array.isArray(fallbackSrc) && fallbackSrc.length > 0)
			return fallbackSrc[0];
	}
	return `/assets/${type}-banner/banner1.webp`;
};

const getDesktopBanner = () => getBannerSrc(siteConfig.banner.src, "desktop");
const getMobileBanner = () => getBannerSrc(siteConfig.banner.src, "mobile");
const getDefaultBanner = () => getDesktopBanner();

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = getDefaultBanner();
}

const enableBanner = !!siteConfig.banner.src;

let pageTitle: string;
if (title) {
	pageTitle = `${title} - ${siteConfig.title}`;
} else {
	pageTitle = siteConfig.subtitle
		? `${siteConfig.title} - ${siteConfig.subtitle}`
		: siteConfig.title;
}

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}

const favicons: Favicon[] =
	siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

if (!lang) {
	lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
	top: `${BANNER_HEIGHT_EXTEND}vh`,
	center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
	bottom: "0",
};
const bannerOffset =
	bannerOffsetByPosition[siteConfig.banner.position || "center"];

---

<!doctype html>
<html
	lang={siteLang}
	class="bg-(--page-bg) text-[14px] md:text-[16px]"
>
	<head>
		<title>{pageTitle}</title>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="canonical" href={Astro.url} />
		<meta name="description" content={description || pageTitle} />
		<meta name="google" content="notranslate" />
		<meta name="googlebot" content="notranslate" />

		<!-- DNS 预解析和预连接优化 -->
		<link rel="dns-prefetch" href="https://code.iconify.design" />
		<link rel="preconnect" href="https://code.iconify.design" crossorigin />
		<link rel="preconnect" href="https://api.i-meto.com" crossorigin />
		{commentConfig.enable && (
			<link rel="preconnect" href={commentConfig.envId} crossorigin />
		)}

		<!-- 关键页面 prefetch（仅首页加载时启用） -->
		{isHomePage && (
			<>
				<link rel="prefetch" href={url("/archive/")} />
				<link rel="prefetch" href={url("/about/")} />
				<link rel="prefetch" href={url("/friends/")} />
			</>
		)}

		<!-- 字体使用 font-display: swap 延迟加载，不阻塞首屏渲染 -->

		<!-- Preload banner images to protect LCP. -->
		{
			siteConfig.banner.src && (
				<>
					<link
						rel="preload"
						as="image"
						href={url(getDesktopBanner())}
						media="(min-width: 768px)"
						fetchpriority="high"
						crossorigin="anonymous"
					/>
					<link
						rel="preload"
						as="image"
						href={url(getMobileBanner())}
						media="(max-width: 767px)"
						fetchpriority="high"
						crossorigin="anonymous"
					/>
				</>
			)
		}

		{
			siteConfig.keywords && siteConfig.keywords.length > 0 && (
				<meta
					name="keywords"
					content={siteConfig.keywords.join(", ")}
				/>
			)
		}
		<meta name="author" content={profileConfig.name} />
		<meta property="og:site_name" content={siteConfig.title} />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description || pageTitle} />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{ogImageUrl && <meta property="og:image:width" content="1200" />}
		{ogImageUrl && <meta property="og:image:height" content="630" />}
		{ogImageUrl && <meta property="og:image:alt" content={pageTitle} />}
		{
			setOGTypeArticle ? (
				<meta property="og:type" content="article" />
			) : (
				<meta property="og:type" content="website" />
			)
		}
		<meta name="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description || pageTitle} />
		{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
		{ogImageUrl && <meta name="twitter:image:alt" content={pageTitle} />}
		<meta name="generator" content={Astro.generator} />
		{
			favicons.map((favicon) => (
				<link
					rel="icon"
					href={
						favicon.src.startsWith("/")
							? url(favicon.src)
							: favicon.src
					}
					sizes={favicon.sizes}
					media={
						favicon.theme &&
						`(prefers-color-scheme: ${favicon.theme})`
					}
				/>
			))
		}

		<!-- Set the theme before the page is rendered to avoid a flash -->
		<script
			is:inline
			define:vars={{
				DEFAULT_THEME,
				LIGHT_MODE,
				DARK_MODE,
				BANNER_HEIGHT_EXTEND,
				PAGE_WIDTH,
				configHue,
				pageScaling: siteConfig.pageScaling,
			}}
		>
			const storedTheme = localStorage.getItem("theme");
			const initialColorScheme =
				DEFAULT_THEME === LIGHT_MODE || DEFAULT_THEME === DARK_MODE
					? DEFAULT_THEME
					: "";

			function getPreferredTheme() {
				if (storedTheme === LIGHT_MODE || storedTheme === DARK_MODE) {
					return storedTheme;
				}
				if (initialColorScheme) {
					return initialColorScheme;
				}
				return window.matchMedia("(prefers-color-scheme: dark)").matches
					? DARK_MODE
					: LIGHT_MODE;
			}

			const themeValue = getPreferredTheme();
			const isDark = themeValue === DARK_MODE;
			document.documentElement.classList.toggle("dark", isDark);
			document.documentElement.setAttribute(
				"data-theme",
				isDark ? "github-dark" : "github-light",
			);

			window.theme = {
				themeValue,
				getTheme: () => window.theme.themeValue,
				setTheme: (value) => {
					window.theme.themeValue = value;
				},
			};

			// Load the hue from local storage
			const hue = localStorage.getItem("hue") || configHue;
			document.documentElement.style.setProperty("--hue", hue);

			// 根据主题色设置背景材质
			// 朱砂赤 (hue: 10) → 缣帛 (silk)
			// 提尔紫 (hue: 325) → 羊皮纸 (parchment)
			const material = hue === "10" ? "silk" : "parchment";
			document.documentElement.setAttribute("data-theme-material", material);

			// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
			let offset = Math.floor(
				window.innerHeight * (BANNER_HEIGHT_EXTEND / 100),
			);
			offset = offset - (offset % 4);
			document.documentElement.style.setProperty(
				"--banner-height-extend",
				`${offset}px`,
			);

			// Apply desktop page scaling early to avoid a visible relayout flash.
			(function () {
				if (pageScaling && pageScaling.enable) {
					function adjustPageScale() {
						const isTouch =
							(window.matchMedia &&
								(window.matchMedia("(pointer:coarse)")
									.matches ||
									window.matchMedia("(hover: none)")
										.matches)) ||
							"ontouchstart" in window;
						const isPortrait =
							window.matchMedia &&
							window.matchMedia("(orientation: portrait)")
								.matches;
						const isTabletLike =
							isTouch || window.innerWidth <= 1280;
						if (isTabletLike || isPortrait) {
							document.documentElement.style.fontSize = "";
							return;
						}
						const targetWidth = pageScaling.targetWidth || 2000;
						const currentWidth =
							document.documentElement.clientWidth;
						let scale = currentWidth / targetWidth;
						if (scale > 1) scale = 1;
						if (scale < 0.85) scale = 0.85;
						document.documentElement.style.fontSize = `${scale * 100}%`;
					}

					adjustPageScale();

					// Keep scaling in sync after viewport changes and swup navigation.
					window.addEventListener("resize", adjustPageScale);

					document.addEventListener(
						"swup:page:view",
						adjustPageScale,
					);
					window.addEventListener(
						"orientationchange",
						adjustPageScale,
					);
				}
			})();
		</script>
		<style
			define:vars={{
				configHue,
				"page-width": `${PAGE_WIDTH}rem`,
			}}
		></style>

		<!-- defines global css variables. This will be applied to <html> <body> and some other elements idk why -->
		<slot name="head" />

		<link
			rel="alternate"
			type="application/rss+xml"
			title={profileConfig.name}
			href={`${Astro.site}rss.xml`}
		/>

		<!-- 结构化数据 -->
		<JsonLd type={setOGTypeArticle ? "article" : "website"} />
	</head>
	<body
		class="min-h-screen"
		class:list={[{ "is-home": isHomePage, "enable-banner": enableBanner }]}
	>
		<ConfigCarrier />
		<slot />
		<BackToTop />
		<script>
			import "../scripts/theme.ts";
		</script>

		<!-- Load the music player when the browser is idle to keep TBT low. -->
		{musicPlayerConfig.enable && <MusicPlayer client:idle />}

		<!-- increase the page height during page transition to prevent the scrolling animation from jumping -->
		<div id="page-height-extend" class="hidden h-[300vh]"></div>
	</body>
</html>

<style
	is:global
	define:vars={{
		bannerOffset,
		"banner-height-home": `${BANNER_HEIGHT_HOME}vh`,
		"banner-height": `${BANNER_HEIGHT}vh`,
		hue: configHue,
	}}
>
	@reference "../styles/main.css";

	:root {
		--hue: var(--hue, ${configHue});
	}

	/* Hide Google Translate UI overlays if injected by the browser or extensions */
	.goog-te-banner-frame,
	.goog-te-menu-frame,
	.goog-te-balloon-frame,
	#goog-gt-tt,
	.goog-tooltip,
	.goog-text-highlight {
		display: none !important;
	}

	body {
		top: 0 !important;
	}

	@layer components {
		.enable-banner #banner-wrapper {
			@apply lg:h-[var(--banner-height)];
		}
		.enable-banner.is-home #banner-wrapper {
			@apply lg:h-(--banner-height-home) lg:translate-y-[var(--banner-height-extend)];
		}
		.enable-banner.is-home #banner-container {
			@apply lg:h-(--banner-height-home) lg:translate-y-0;
		}
		.enable-banner #banner-container {
			@apply lg:h-(--banner-height-home) lg:translate-y-[var(--bannerOffset)];
		}
		.enable-banner #top-row {
			@apply lg:h-[calc(var(--banner-height-home)-4.5rem)] transition-all duration-300;
		}
		.navbar-hidden {
			@apply opacity-0 -translate-y-16;
		}
	}
</style>

<script>
	import "../scripts/layout-runtime.ts";
</script>

<!-- 非首屏关键脚本延迟加载 -->
<script>
	// 使用 requestIdleCallback 延迟加载非关键脚本，进一步减少主线程阻塞
	function scheduleIdleTask(callback: () => void, timeout = 3000) {
		if ("requestIdleCallback" in window) {
			window.requestIdleCallback(callback, { timeout });
		} else {
			setTimeout(callback, timeout);
		}
	}

	// 页面加载完成后延迟加载非关键脚本
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () => {
				scheduleIdleTask(() => {
					import("../scripts/asset-demystification-calculator.js");
					import("../scripts/btc-analysis-chart.js");
					import("../scripts/code-collapse.js");
					import("../scripts/copy-code-buttons.js");
				});
			});
		} else {
			scheduleIdleTask(() => {
				import("../scripts/asset-demystification-calculator.js");
				import("../scripts/btc-analysis-chart.js");
				import("../scripts/code-collapse.js");
				import("../scripts/copy-code-buttons.js");
				import("../scripts/web-vitals-monitor.ts");
			});
		}
</script>
