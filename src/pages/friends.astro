---
import { friendsData } from "../data/friends";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const title = i18n(I18nKey.friends);
const subtitle = i18n(I18nKey.friendsSubtitle);
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<!-- 标题区域 -->
			<header class="mb-8">
				<div class="flex items-center justify-between flex-wrap gap-4">
					<div>
						<h1
							class="text-[2rem] font-bold text-90 mb-3 relative
                      before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
                      before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
						>
							友情链接
						</h1>
						<p class="text-60">发现优质博客，结交有趣灵魂</p>
					</div>
					<button
						class="random-btn"
						id="random-friend-btn"
						type="button"
					>
						<svg
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
						>
							<path
								d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"
							></path>
						</svg>
						<span>随机访问</span>
					</button>
				</div>
			</header>

			<!-- 友链卡片网格 -->
			<div class="friends-grid-wrapper">
				<section class="friends-grid" id="friends-grid">
					{
						friendsData.map((friend, index) => (
							<a
								href={friend.url}
								target="_blank"
								rel="noopener noreferrer"
								class="friend-card group"
								data-title={friend.name}
								data-desc={friend.description}
								style={`--delay: ${index * 0.05}s`}
							>
								<div class="card-avatar-wrapper">
									<img
										src={friend.avatar}
										alt={friend.name}
										class="card-avatar"
										loading="lazy"
										data-fallback={friend.name}
									/>
								</div>
								<div class="card-content">
									<h3 class="card-name">{friend.name}</h3>
									<p class="card-desc">
										{friend.description}
									</p>
								</div>
								<div class="card-arrow-wrapper">
									<svg
										class="card-arrow"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<path d="M7 17L17 7M17 7H7M17 7V17" />
									</svg>
								</div>
							</a>
						))
					}
				</section>
			</div>

			<!-- 申请友链区域 -->
			<section class="apply-section">
				<div class="apply-container">
					<div class="apply-header">
						<div class="apply-icon-wrapper">
							<svg
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<path
									d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
								></path>
								<circle cx="8.5" cy="7" r="4"></circle>
								<line x1="20" y1="8" x2="20" y2="14"></line>
								<line x1="23" y1="11" x2="17" y2="11"></line>
							</svg>
						</div>
						<div class="apply-title-group">
							<h2 class="apply-title">申请友链</h2>
							<p class="apply-subtitle">期待与你成为朋友</p>
						</div>
					</div>

					<div class="apply-body">
						<div class="quote-card">
							<div class="quote-mark">"</div>
							<p>好的友链是互相认可，是惺惺相惜。</p>
							<p>如果你也热爱分享、坚持输出，欢迎交换友链。</p>
						</div>

						<div class="steps-grid">
							<div class="step-card">
								<div class="step-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
									</svg>
								</div>
								<h4>添加本站</h4>
								<p>先在你的网站添加本站友链</p>
							</div>
							<div class="step-card">
								<div class="step-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<path
											d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
										></path>
										<polyline points="14,2 14,8 20,8"></polyline>
										<line x1="16" y1="13" x2="8" y2="13"></line>
									</svg>
								</div>
								<h4>提交申请</h4>
								<p>按格式准备信息并发送申请</p>
							</div>
							<div class="step-card">
								<div class="step-icon">
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<path
											d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
										></path>
										<polyline points="22,4 12,14.01 9,11.01"></polyline>
									</svg>
								</div>
								<h4>互相添加</h4>
								<p>确认后双方互挂友链</p>
							</div>
						</div>

						<div class="format-section">
							<div class="format-header">
								<span class="format-label">JSON 格式</span>
								<button
									class="format-copy-btn"
									id="copy-format-btn"
									type="button"
								>
									<svg
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
									>
										<rect
											x="9"
											y="9"
											width="13"
											height="13"
											rx="2"></rect>
										<path
											d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
										></path>
									</svg>
									<span>复制</span>
								</button>
							</div>
							<div class="format-code">
								<pre><code set:html={`{
  "name": "博客名称",
  "url": "https://your-blog.com",
  "avatar": "https://your-blog.com/avatar.png",
  "description": "一句话介绍（20字内）"
}`} /></pre>
							</div>
						</div>

						<a
							href="https://github.com/ChaoNous/ChaoNous-Blog/discussions/new?category=general"
							target="_blank"
							rel="noopener noreferrer"
							class="apply-cta"
						>
							<svg viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
								></path>
							</svg>
							<span>前往 GitHub Discussions 申请</span>
							<svg
								class="arrow-icon"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
							>
								<line x1="5" y1="12" x2="19" y2="12"></line>
								<polyline points="12,5 19,12 12,19"></polyline>
							</svg>
						</a>
					</div>
				</div>
			</section>
		</div>
	</div>
</MainGridLayout>

<style>
	/* ========== 随机访问按钮 ========== */
	.random-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 1.25rem;
		background: var(--primary);
		border: none;
		border-radius: var(--radius-large);
		color: white;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.25s ease;
		flex-shrink: 0;
	}

	.random-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px -4px hsl(var(--primary) / 0.4);
	}

	.random-btn svg {
		width: 1rem;
		height: 1rem;
	}

	/* ========== 友链网格容器 ========== */
	.friends-grid-wrapper {
		border: none;
		border-radius: var(--radius-large);
		padding: 1rem;
		background: hsl(var(--primary) / 0.02);
	}

	/* ========== 友链网格 - 两列布局 ========== */
	.friends-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	/* ========== 友链卡片 - 长条横向布局 ========== */
	.friend-card {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1rem;
		padding: 1rem;
		background: var(--card-bg);
		border: none;
		border-radius: 1rem;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		animation: card-in 0.4s ease backwards;
		animation-delay: var(--delay);
		overflow: hidden;
	}

	@keyframes card-in {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.friend-card:hover {
		border-color: var(--primary);
		transform: translateY(-2px);
		box-shadow: 0 8px 24px -8px hsl(var(--primary) / 0.15);
	}

	.card-avatar-wrapper {
		width: 4rem;
		height: 4rem;
		flex-shrink: 0;
		overflow: hidden;
		border-radius: 0.75rem;
		background: linear-gradient(
			135deg,
			hsl(var(--primary) / 0.08),
			hsl(var(--primary) / 0.02)
		);
	}

	.card-avatar {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.friend-card:hover .card-avatar {
		transform: scale(1.05);
	}

	.card-content {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.card-name {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-90);
		margin: 0 0 0.25rem;
		transition: color 0.2s;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.friend-card:hover .card-name {
		color: var(--primary);
	}

	.card-desc {
		font-size: 0.8125rem;
		color: var(--text-50);
		margin: 0;
		line-height: 1.4;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.card-arrow-wrapper {
		width: 1.75rem;
		height: 1.75rem;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: hsl(var(--primary) / 0.1);
		border-radius: 0.5rem;
		opacity: 0;
		transform: translateX(8px);
		transition: all 0.25s ease;
	}

	.friend-card:hover .card-arrow-wrapper {
		opacity: 1;
		transform: translateX(0);
	}

	.card-arrow {
		width: 1rem;
		height: 1rem;
		color: var(--primary);
	}

	/* ========== 申请友链区域 ========== */
	.apply-section {
		margin-top: 2.5rem;
		padding-top: 2.5rem;
		border-top: none;
	}

	.apply-container {
		max-width: 800px;
	}

	.apply-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.apply-icon-wrapper {
		position: relative;
		width: 3rem;
		height: 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--primary);
		border-radius: 0.75rem;
		color: white;
	}


	.apply-icon-wrapper svg {
		position: relative;
		z-index: 1;
		width: 1.5rem;
		height: 1.5rem;
	}

	.apply-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--text-90);
		margin: 0;
	}

	.apply-subtitle {
		font-size: 0.8125rem;
		color: var(--text-50);
		margin: 0.25rem 0 0;
	}

	.apply-body {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.quote-card {
		position: relative;
		padding: 1.25rem 1.5rem;
		background: linear-gradient(
			135deg,
			hsl(var(--primary) / 0.05) 0%,
			transparent 100%
		);
		border-left: none;
		border-radius: 0 0.75rem 0.75rem 0;
	}

	.quote-mark {
		position: absolute;
		top: 0.5rem;
		left: 0.75rem;
		font-size: 2.5rem;
		font-family: "Crimson Pro", "Zhuque Fangsong UI";
		color: var(--primary);
		opacity: 0.3;
		line-height: 1;
	}

	.quote-card p {
		position: relative;
		z-index: 1;
		margin: 0;
		font-size: 0.9375rem;
		color: var(--text-70);
		line-height: 1.6;
	}

	.quote-card p:first-of-type {
		font-weight: 500;
		color: var(--text-90);
		margin-bottom: 0.25rem;
	}

	.steps-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.step-card {
		text-align: center;
		padding: 1.25rem 1rem;
		background: var(--card-bg);
		border: none;
		border-radius: 0.75rem;
		transition: all 0.3s ease;
	}

	.step-card:hover {
		border-color: var(--primary);
		transform: translateY(-2px);
	}

	.step-icon {
		width: 2.5rem;
		height: 2.5rem;
		margin: 0 auto 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: hsl(var(--primary) / 0.1);
		border: none;
		border-radius: 0.625rem;
		color: var(--primary);
	}

	.step-icon svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.step-card h4 {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--text-90);
		margin: 0 0 0.25rem;
	}

	.step-card p {
		font-size: 0.8125rem;
		color: var(--text-50);
		margin: 0;
	}

	.format-section {
		background: var(--card-bg);
		border: none;
		border-radius: 0.75rem;
		overflow: hidden;
	}

	.format-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		background: hsl(var(--primary) / 0.05);
		border-bottom: none;
	}

	.format-label {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--text-70);
	}

	.format-copy-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.75rem;
		background: var(--card-bg);
		border: none;
		border-radius: 0.375rem;
		color: var(--text-60);
		font-size: 0.75rem;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.format-copy-btn:hover {
		border-color: var(--primary);
		color: var(--primary);
	}

	.format-copy-btn svg {
		width: 0.875rem;
		height: 0.875rem;
	}

	.format-code {
		padding: 1rem;
		margin: 0;
		overflow-x: auto;
	}

	.format-code code {
		font-family: var(--font-content);
		font-size: 0.8125rem;
		color: var(--text-80);
		line-height: 1.6;
	}

	.apply-cta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 1.5rem;
		background: var(--primary);
		border: none;
		border-radius: 0.75rem;
		color: white;
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.apply-cta:hover {
		background: hsl(var(--primary) / 0.9);
		transform: translateY(-2px);
		box-shadow: 0 8px 20px -4px hsl(var(--primary) / 0.35);
	}

	.apply-cta svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.arrow-icon {
		transition: transform 0.3s ease;
	}

	.apply-cta:hover .arrow-icon {
		transform: translateX(4px);
	}

	/* ========== 响应式 ========== */
	@media (max-width: 768px) {
		.friends-grid {
			grid-template-columns: 1fr;
		}

		.steps-grid {
			grid-template-columns: 1fr;
		}

		.card-avatar-wrapper {
			width: 3rem;
			height: 3rem;
		}

		.card-name {
			font-size: 0.9375rem;
		}

		.card-desc {
			font-size: 0.75rem;
		}

		.random-btn {
			width: 100%;
			justify-content: center;
			margin-top: 0.5rem;
		}
	}
</style>

<script>
	// 随机访问友链
	document
		.getElementById("random-friend-btn")
		?.addEventListener("click", () => {
			const friends = document.querySelectorAll(".friend-card");
			if (friends.length > 0) {
				const randomIndex = Math.floor(Math.random() * friends.length);
				const randomFriend = friends[randomIndex] as HTMLAnchorElement;
				if (randomFriend.href) {
					window.open(randomFriend.href, "_blank");
				}
			}
		});

	// 复制格式
	document
		.getElementById("copy-format-btn")
		?.addEventListener("click", async () => {
			const formatText = `{
  "name": "博客名称",
  "url": "https://your-blog.com",
  "avatar": "https://your-blog.com/avatar.png",
  "description": "一句话介绍（20字内）"
}`;
			try {
				await navigator.clipboard.writeText(formatText);
				const btn = document.getElementById("copy-format-btn");
				if (btn) {
					const originalHTML = btn.innerHTML;
					btn.innerHTML =
						'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:0.875rem;height:0.875rem"><polyline points="20,6 9,17 4,12"/></svg><span>已复制</span>';
					setTimeout(() => {
						btn.innerHTML = originalHTML;
					}, 2000);
				}
			} catch (err) {
				console.error("复制失败:", err);
			}
		});

	// 头像加载失败
	document.querySelectorAll(".card-avatar[data-fallback]").forEach((img) => {
		img.addEventListener("error", function (this: HTMLImageElement) {
			const fallback = this.dataset.fallback;
			if (fallback) {
				this.src = `https://api.dicebear.com/7.x/shapes/svg?seed=${encodeURIComponent(fallback)}`;
			}
		});
	});
</script>