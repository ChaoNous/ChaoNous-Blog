---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../config";
import { booksData } from "../data/books";
import MainGridLayout from "../layouts/MainGridLayout.astro";

export const prerender = true;

if (!siteConfig.featurePages.devices) {
	return Astro.redirect("/404/");
}

const pageTitle = "书籍";
const pageSubtitle = "按类型整理的阅读清单";
const viewDetailsText = "查看书籍";
const categories = Object.keys(booksData);
const initialCategory = categories[0];
---

<MainGridLayout title={pageTitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div class="flex w-full overflow-hidden relative min-h-32 rounded-(--radius-large)">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="flex flex-col items-start justify-center mb-8">
				<h1
					class="text-4xl font-bold text-90 mb-2 relative before:w-1 before:h-8 before:rounded-md before:bg-(--primary) before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
				>
					{pageTitle}
				</h1>
				<p class="text-lg text-60">{pageSubtitle}</p>
			</div>

			<div class="mb-6">
				<div class="filter-container flex flex-wrap gap-2">
					{
						categories.map((category, index) => (
							<button
								data-category={category}
								class={`filter-tag px-6 py-2.5 rounded-lg font-medium transition-all ${
									index === 0 ? "active" : ""
								}`}
							>
								{category}
							</button>
						))
					}
				</div>
			</div>

			<div id="books-container" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
				{
					initialCategory &&
						booksData[initialCategory].map((book, index) => (
							<a
								href={book.link}
								target="_blank"
								rel="noopener noreferrer"
								class="book-card group relative overflow-hidden rounded-xl border border-(--line-divider) bg-(--card-bg) transition-all duration-300 hover:border-(--primary)/50 hover:shadow-md hover:shadow-black/5 dark:hover:shadow-white/5 hover:scale-[1.02] hover:-translate-y-0.5 block cursor-pointer"
								style={`animation-delay: ${index * 100}ms`}
							>
								<div class="relative p-6 pb-0">
									<div class="flex justify-center items-center h-56 bg-linear-to-br from-(--card-bg) to-(--btn-regular-bg) rounded-lg overflow-hidden relative">
										<div class="absolute inset-0 bg-(--primary)/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
										<img
											src={book.image}
											alt={book.name}
											class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500 drop-shadow-md relative z-10"
										/>
									</div>
								</div>

								<div class="p-6 pt-4 relative z-10">
									<div class="flex items-start justify-between mb-3 gap-3">
										<h3 class="text-lg font-bold text-90 group-hover:text-(--primary) transition-colors duration-300">
											{book.name}
										</h3>
										<div class="p-1.5 rounded-full bg-(--primary)/10 text-(--primary) opacity-0 group-hover:opacity-100 transition-opacity duration-300">
											<Icon name="material-symbols:open-in-new" class="text-lg" />
										</div>
									</div>

									<div class="mb-4">
										<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-(--btn-regular-bg) text-70 text-sm mb-3">
											<Icon name="material-symbols:menu-book-outline" class="text-sm" />
											<span class="font-medium">{book.specs}</span>
										</div>

										<p class="text-sm text-60 leading-relaxed line-clamp-2">
											{book.description}
										</p>
									</div>

									<div class="flex items-center justify-between pt-3 border-t border-(--line-divider) border-dashed opacity-0 group-hover:opacity-100 transition-all duration-300">
										<span class="text-sm font-medium text-(--primary)">{viewDetailsText}</span>
										<Icon name="material-symbols:arrow-forward-rounded" class="text-lg text-(--primary)" />
									</div>
								</div>
							</a>
						))
				}
			</div>
		</div>
	</div>

	<script is:inline define:vars={{ booksData, viewDetailsText }}>
		const categoryTabs = document.querySelectorAll(".filter-tag");
		const booksContainer = document.getElementById("books-container");

		categoryTabs.forEach((tab) => {
			tab.addEventListener("click", () => {
				const category = tab.dataset.category;

				categoryTabs.forEach((item) => item.classList.remove("active"));
				tab.classList.add("active");

				const currentBooks = booksData[category] || [];
				booksContainer.innerHTML = currentBooks
					.map(
						(book, index) => `
							<a
								href="${book.link}"
								target="_blank"
								rel="noopener noreferrer"
								class="book-card group relative overflow-hidden rounded-xl border border-(--line-divider) bg-(--card-bg) transition-all duration-300 hover:border-(--primary)/50 hover:shadow-md hover:shadow-black/5 dark:hover:shadow-white/5 hover:scale-[1.02] hover:-translate-y-0.5 block cursor-pointer"
								style="animation-delay: ${index * 100}ms; animation: fadeInUp 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) forwards; opacity: 0;"
							>
								<div class="relative p-6 pb-0">
									<div class="flex justify-center items-center h-56 bg-linear-to-br from-(--card-bg) to-(--btn-regular-bg) rounded-lg overflow-hidden relative">
										<div class="absolute inset-0 bg-(--primary)/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
										<img
											src="${book.image}"
											alt="${book.name}"
											class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500 drop-shadow-md relative z-10"
										/>
									</div>
								</div>
								<div class="p-6 pt-4 relative z-10">
									<div class="flex items-start justify-between mb-3 gap-3">
										<h3 class="text-lg font-bold text-90 group-hover:text-(--primary) transition-colors duration-300">
											${book.name}
										</h3>
										<div class="p-1.5 rounded-full bg-(--primary)/10 text-(--primary) opacity-0 group-hover:opacity-100 transition-opacity duration-300">
											<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 3h7v7m0-7L10 14" />
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5h5M5 12h3m-3 7h14" />
											</svg>
										</div>
									</div>
									<div class="mb-4">
										<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-(--btn-regular-bg) text-70 text-sm mb-3">
											<svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 19.5A2.5 2.5 0 016.5 17H20" />
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.5 17A2.5 2.5 0 014 14.5v-9A2.5 2.5 0 016.5 3H20v14" />
											</svg>
											<span class="font-medium">${book.specs}</span>
										</div>
										<p class="text-sm text-60 leading-relaxed line-clamp-2">
											${book.description}
										</p>
									</div>
									<div class="flex items-center justify-between pt-3 border-t border-(--line-divider) border-dashed opacity-0 group-hover:opacity-100 transition-all duration-300">
										<span class="text-sm font-medium text-(--primary)">${viewDetailsText}</span>
										<svg class="w-5 h-5 text-(--primary)" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
										</svg>
									</div>
								</div>
							</a>
						`,
					)
					.join("");
			});
		});
	</script>

	<style>
		.filter-container {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-bottom: 1rem;
		}

		.filter-tag {
			padding: 0.625rem 1.25rem;
			border: 1px solid var(--line-divider);
			border-radius: var(--radius-large);
			background: var(--btn-regular-bg);
			color: var(--btn-content);
			font-size: 0.875rem;
			font-weight: 500;
			cursor: pointer;
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			white-space: nowrap;
			position: relative;
			overflow: hidden;
		}

		.filter-tag:hover:not(.active) {
			background: var(--btn-hover-bg);
			border-color: var(--primary);
			transform: translateY(-2px);
			box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
		}

		.filter-tag.active {
			background: var(--primary);
			color: white;
			border-color: var(--primary);
			transform: translateY(-1px);
			box-shadow: 0 4px 12px rgba(var(--color-primary-rgb), 0.3);
		}

		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(20px);
			}

			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.line-clamp-2 {
			display: -webkit-box;
			-webkit-line-clamp: 2;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.book-card::after {
			content: "";
			position: absolute;
			inset: 0;
			border-radius: 0.75rem;
			background: linear-gradient(135deg, rgba(var(--color-primary-rgb), 0.05), transparent);
			opacity: 0;
			transition: opacity 0.4s ease;
			pointer-events: none;
		}

		.book-card:hover::after {
			opacity: 1;
		}

		@media (max-width: 768px) {
			.filter-container {
				gap: 0.5rem;
			}

			.filter-tag {
				padding: 0.5rem 1rem;
				font-size: 0.8rem;
			}
		}
	</style>
</MainGridLayout>
