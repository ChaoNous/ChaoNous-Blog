---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const sortedPostsList = await getSortedPostsList();

const posts = sortedPostsList.map((post) => ({
	...post,
	data: {
		...post.data,
		category: post.data.category === null ? undefined : post.data.category,
	},
}));

const categories = [
	...new Set(
		posts
			.map((post) => post.data.category)
			.filter((c): c is string => typeof c === "string"),
	),
];
---

<MainGridLayout title={i18n(I18nKey.archive)}>
    <script>
        import("../scripts/right-sidebar-layout.js");
    </script>

    <ArchivePanel
            sortedPosts={posts}
            categories={categories}
            client:only="svelte"
    ></ArchivePanel>
</MainGridLayout>
